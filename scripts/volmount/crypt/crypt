# ## Overview:
#
# We support dcp and caam both for mainline and nxp variant; versatile is always mainline
#   - dcp: requires mode 'mainline' or 'nxp'. mainline uses trusted key subsystem (trusted.source=dcp).
#          nxp mode uses legacy x--pv-dcp-tool. mainline mode auto-migrates nxp key blobs via dcp-blob-create.
#   - caam: has caam mainline and nxp implementation. To allow better transition
#           the caam mainline type is identified through a new 'mode=mainline' field
#           in pantavisor device.json disk definition. the legacy disk must specify "nxp"
#           from now on. caam disk definition without mode will fail to mount.
#           As extra safety measure the path will be prefixed with a - for caam disks now
#           Disks without - prefix will fail to mount. This ensures that the old crypt mount
#           code that cannot distinguish mode yet, will eaccidentially create a crypt disk
#           using the wrong mode - because the script will fail early.
#   - the field 'path' must have the following syntax for all 'caam' disks: "-v2 <imgpath>,<size-in-MB>,<keyname>"
#   - 'mode' is required for caam and dcp types. valid values are 'mainline' and 'nxp'
#
# Usage:
#   crypt <action> --type <type> --mode <mode> [--read-only] [--no-create] [--specialrun <run>] <path> <mntpath>
#
#   action:       mount or umount (positional)
#   --type:       dm-crypt type (dcp, caam, versatile)
#   --mode:       encryption mode (mainline, nxp)
#   --read-only:  set up dm-crypt device as read-only
#   --copy-from:  on first init, copy content from this mounted path instead of empty mkfs
#   --specialrun: internal flag for recovery retries (fsck, bak)
#   path:         disk image path (positional)
#   mntpath:      mount target path (positional)
#

set -e

# parse arguments: first positional is action, flags in the middle, trailing positionals are path and mntpath
op=$1
shift

dm_type=""
mode=""
specialrun=""
read_only=""
no_create=""

while [ $# -gt 0 ]; do
	case "$1" in
		--type)
			dm_type="$2"
			shift 2
			;;
		--mode)
			mode="$2"
			shift 2
			;;
		--specialrun)
			specialrun="$2"
			shift 2
			;;
		--read-only)
			read_only="yes"
			shift
			;;
		--no-create)
			no_create="yes"
			shift
			;;
		--)
			shift
			break
			;;
		-*)
			echo "ERROR: unknown flag: $1"
			exit 1
			;;
		*)
			break
			;;
	esac
done

path=$1
origpath=$1
mntpath=$2

if [ -z "$op" ] || [ -z "$dm_type" ] || [ -z "$path" ]; then
	echo "ERROR: missing required arguments"
	echo "Usage: crypt <mount|umount> --type <type> --mode <mode> [--read-only] [--no-create] <path> <mntpath>"
	exit 1
fi

if [ "$op" = "mount" ] && [ -z "$mntpath" ]; then
	echo "ERROR: mount requires a <mntpath> argument"
	exit 1
fi

case "$dm_type" in
	caam|caam-mainline|dcp|versatile) ;;
	*)
		echo "ERROR: unknown --type '$dm_type' (valid: caam, caam-mainline, dcp, versatile)"
		exit 1
		;;
esac

# caam and dcp disks require an explicit --mode
case "$dm_type" in
	caam*|dcp)
		case "$mode" in
			mainline|nxp) ;;
			*)
				echo "ERROR: $dm_type disk '$path' requires --mode (mainline or nxp) but got '${mode:-<empty>}'"
				echo "       add '\"mode\": \"mainline\"' or '\"mode\": \"nxp\"' to the disk definition in device.json"
				exit 1
				;;
		esac
		;;
esac

# caam disks require -v2 path prefix as safety measure
case "$dm_type" in
	caam*)
		newpath=${path#-v2 }
		if [ "$newpath" = "$path" ]; then
			echo "ERROR: caam disk path must start with '-v2 ' but got: $path"
			echo "       expected format: -v2 <imgpath>,<size-in-MB>,<keyname>"
			exit 1
		fi
		path="$newpath"
		;;
esac

CAAM_KEYGEN=caam-keygen

MKFS_OPTS_EXT4=${MKFS_OPTS_EXT4:-"-b 1024"}
MNT_OPTS_EXT4=${MNT_OPTS_EXT4:-"-o noatime"}

# ensure that devicemapper builds with udev support
# don't believe that udev will create the /dev/mapper/* nodes
DM_DISABLE_UDEV=1
export DM_DISABLE_UDEV

PATH=$LIBPVPATH:$LIBPVPATH/volmount/crypt:$PATH
export PATH

export LD_LIBRARY_PATH="/x86_64-linux-gnu:$LD_LIBRARY_PATH"

# do the same as losetup -f but also return the path of loop device on stdout
# if successful.
atomic_losetup()
{
	_imgfile=$1
	if ! losetup -f "$_imgfile"; then
		echo "ERROR: unable to setup loop device for $_imgfile"
		return 122
	fi
	if ! _l=$(losetup -a | grep "${_imgfile}$" | tail -n 1); then
		echo "ERROR: unable to setup loop device for $_imgfile"
		return 122
	fi
	echo "$_l" | sed -e 's/: [0-9][0-9]* .*//'
}

# Copy all files from $1 (source dir) to $2 (destination dir) and verify checksums.
# Both directories must already be mounted.
do_crypt_init()
{

	base=$(basename "$1")
	dir=$(dirname "$1")

	mkdir -p "$dir"

	keyname=$(echo "$base" | awk '{split($0,a,","); print a[3]}')
	img_file=$(echo "$base" | awk '{split($0,a,","); print a[1]}')
	img_size=$(echo "$base" | awk '{split($0,a,","); print a[2]}')

	# Phase 1: Key creation.
	# If the key already exists but init_done is missing, we are recovering
	# from a power loss. Skip key creation but load the key for formatting.
	case "${dm_type_mode}" in
		caam__nxp)
			if [ ! -f "$dir/$keyname.bb" ]; then
				# creates $keyname.. and $keyname in /data/caam (tmpfs, lost on reboot)
				# copy to persistent storage atomically
				"$CAAM_KEYGEN" create "$keyname" ecb -s 16
				if ! keyctl padd logon $KEY_NAME @u < /data/caam/"$keyname"; then
					echo "ERROR: CAAM: Unable to load key"
					exit 1
				fi
				cp -f /data/caam/"$keyname".bb "$dir/$keyname.bb.tmp"
				sync
				mv "$dir/$keyname.bb.tmp" "$dir/$keyname.bb"
				sync
			else
				echo "WARN: CAAM NXP key exists but init_done missing, recovering init"
				mkdir -p /data/caam
				cp "$dir/$keyname.bb" /data/caam/
				if ! ( cd /data/caam && "$CAAM_KEYGEN" import "$keyname.bb" "$keyname.import" ); then
					echo "ERROR: CAAM: Unable to import black blob during init recovery"
					exit 1
				fi
				if ! keyctl padd logon $KEY_NAME @u < /data/caam/"$keyname.import"; then
					echo "ERROR: CAAM: Unable to load key during init recovery"
					exit 1
				fi
			fi
			;;
		caam__mainline|caam-mainline__*)
			if [ ! -f "$dir/$keyblob" ]; then
				if ! TKEY=$(keyctl add "${KEY_TYPE}" "${KEY_NAME}" "new ${key_size}" @u); then
					echo "ERROR: Cannot create trusted key ${KEY_TYPE}:${KEY_NAME} with size ${key_size} and put it to keyring!"
					exit 1
				fi
				if ! keyctl pipe "$TKEY" > "$dir/$keyblob.tmp"; then
					echo "ERROR: CAAM: Unable persist keyblob: $keyblob"
					exit 1
				fi
				sync
				mv "$dir/$keyblob.tmp" "$dir/$keyblob"
			else
				echo "WARN: CAAM mainline keyblob exists but init_done missing, recovering init"
				read -r trusted_key 2> /dev/null < "$dir/$keyblob" || true
				if ! keyctl add "$KEY_TYPE" "$KEY_NAME" "load $trusted_key" @u; then
					echo "ERROR: CAAM: Unable to load trusted key during init recovery"
					exit 1
				fi
			fi
			;;
		dcp__mainline)
			if [ ! -f "$dir/$keyblob" ]; then
				if ! TKEY=$(keyctl add "${KEY_TYPE}" "${KEY_NAME}" "new ${key_size}" @u); then
					echo "ERROR: Cannot create trusted key ${KEY_TYPE}:${KEY_NAME} with size ${key_size}!"
					exit 1
				fi
				if ! keyctl pipe "$TKEY" > "$dir/$keyblob.tmp"; then
					echo "ERROR: DCP: Unable to persist keyblob: $keyblob"
					exit 1
				fi
				sync
				mv "$dir/$keyblob.tmp" "$dir/$keyblob"
			else
				echo "WARN: DCP mainline keyblob exists but init_done missing, recovering init"
				read -r trusted_key 2> /dev/null < "$dir/$keyblob" || true
				if ! keyctl add "$KEY_TYPE" "$KEY_NAME" "load $trusted_key" @u; then
					echo "ERROR: DCP: Unable to load trusted key during init recovery"
					exit 1
				fi
			fi
			;;
		dcp__nxp)
			if [ ! -f "$dir/$keyname" ]; then
				if ! dd if=/dev/random bs=32 count=1 | x--pv-dcp-tool \
					encrypt "$dir/$keyname.new"; then
					echo "ERROR: DCP: Unable to create grey blob"
					exit 1
				fi
				sync
				mv "$dir/$keyname.new" "$dir/$keyname"
			else
				echo "WARN: DCP key exists but init_done missing, recovering init"
			fi
			;;
		versatile__*)
			if [ ! -f "$dir/$keyname.txt" ]; then
				if test -c /dev/hwrng && dd if=/dev/hwrng of="$dir/$keyname.txt.tmp" bs=32 count=1; then
					echo "Successfully seeded from hwrng"
				else
					echo "WARNING: /dev/hwrng not available; using urandom for versatile crypt key"
					dd if=/dev/urandom of="$dir/$keyname.txt.tmp" bs=32 count=1
				fi
				sync
				mv "$dir/$keyname.txt.tmp" "$dir/$keyname.txt"
			else
				echo "WARN: versatile key exists but init_done missing, recovering init"
			fi
			;;
		*)
			echo "Unknown device mapper target"
			exit 1
	esac

	# sync after keyname files got created
	sync

	# Phase 2: Image creation, formatting, and optional copy.
	# Only needed when the image file does not exist yet.
	# If the image already exists but init_done is missing, we are
	# recovering from a power loss after formatting — just re-touch init_done.
	if ! [ -f "$dir/$img_file" ]; then
		_img_file_new=$img_file.new
		dd if=/dev/zero of="$dir/$_img_file_new" bs=1M count="$img_size"
		sync

		case "${dm_type_mode}" in
			caam*|dcp__mainline)
				if ! CAAM_LOOP=$(atomic_losetup "$dir/$_img_file_new"); then
					echo "ERROR: Unable to loop setup"
					exit 1
				fi
				;;
		esac

		device_name=$(echo "$img_file" | awk '{split($0,a,"."); print a[1]}')
		case "${dm_type_mode}" in
			caam__nxp)
				if ! dmsetup -v create "$device_name" --table "0 $(blockdev --getsz "$CAAM_LOOP") crypt capi:tk(cbc(aes))-plain :36:logon:$KEY_NAME 0 $CAAM_LOOP 0 1 sector_size:512"; then
					echo "ERROR: $dm_type: Unable to create/open crypt device"
					exit 1
				fi
				;;
			caam__mainline|caam-mainline__*|dcp__mainline)
				if ! dmsetup -v create "$device_name" --table "0 $(blockdev --getsz "$CAAM_LOOP") crypt $cipher :$key_size:$KEY_TYPE:$KEY_NAME 0 $CAAM_LOOP 0 1 sector_size:512"; then
					echo "ERROR: $dm_type: Unable to create/open crypt device"
					exit 1
				fi
				;;
			dcp__nxp)
				keyfile=$(mktemp)
				x--pv-dcp-tool decrypt "$dir/$keyname" > "$keyfile"
				if ! cryptsetup open -s 256 -c "capi:cbc(aes)-essiv:sha256" --type plain --key-file="$keyfile" "$dir/$_img_file_new" "$device_name"; then
					rm -f "$keyfile"
					echo "ERROR: $dm_type: Unable to create/open crypt device"
					exit 1
				fi
				rm -f "$keyfile"
				;;
			versatile__*)
				if ! cryptsetup open -s 256 -c "aes-cbc-essiv:sha256" --type plain --key-file="$dir/$keyname.txt" "$dir/$_img_file_new" "$device_name"; then
					echo "ERROR: $dm_type: Unable to create/open crypt device"
					exit 1
				fi
				;;
			*)
				echo "Unknown device mapper target"
				exit 1
				;;
		esac

		# shellcheck disable=SC2086
		if [ "$read_only" = "yes" ]; then
			echo "ERROR: cannot format read-only disk."
			exit 1
		elif ! mkfs.ext4 $MKFS_OPTS_EXT4 /dev/mapper/"$device_name"; then
			echo "ERROR: Unable to format to ext4"
			exit 1
		fi

		# Tear down dm-crypt device and loop after formatting
		sync
		case "${dm_type_mode}" in
			caam__nxp)
				dmsetup remove "$device_name"
				rm -rf /data
				losetup -d "$CAAM_LOOP"
				;;
			caam__mainline|caam-mainline__*|dcp__mainline)
				dmsetup remove "$device_name"
				losetup -d "$CAAM_LOOP"
				;;
			dcp__nxp)
				cryptsetup close "$device_name"
				;;
			versatile__*)
				cryptsetup close "$device_name"
				;;
			*)
				echo "Unknown device mapper target"
				exit 1
				;;
		esac

		mv "$dir/$_img_file_new" "$dir/$img_file"
	fi

	# Unlink the key loaded during Phase 1 (fresh or recovery);
	# do_mount_disk will re-load it for the actual mount.
	case "${dm_type_mode}" in
		caam__nxp)
			keyctl unlink $(keyctl search @u logon $KEY_NAME) @u 2>/dev/null || true
			;;
		caam__mainline|caam-mainline__*|dcp__mainline)
			keyctl unlink $(keyctl search @u $KEY_TYPE $KEY_NAME) @u 2>/dev/null || true
			;;
	esac

	sync
	touch "$dir/$keyname.init_done"
}

do_dm_sanity()
{
	case "${dm_type}__${mode}" in
		caam__nxp)
			which "$CAAM_KEYGEN" >/dev/null 2>&1 || exit 111
			which dmsetup >/dev/null 2>&1 || exit 111
			which keyctl >/dev/null 2>&1 || exit 111
			;;
		caam__mainline|caam-mainline__*|dcp__mainline)
			which dmsetup >/dev/null 2>&1 || exit 111
			which keyctl >/dev/null 2>&1 || exit 111
			;;
		dcp__nxp)
			which cryptsetup >/dev/null 2>&1 || exit 111
			;;
		versatile__*)
			which cryptsetup >/dev/null 2>&1 || exit 111
			;;
		*)
			echo "Unknown device mapper target"
			exit 111
			;;
	esac

	which losetup >/dev/null 2>&1 || exit 111
	which dd >/dev/null 2>&1 || exit 111
	which mkfs.ext4 >/dev/null 2>&1 || exit 111
}

clean_disk()
{
	name="$1"

	case "$dm_type_mode" in
		caam*|dcp__mainline)
			if dmsetup info -c "$name" >/dev/null 2>&1; then
				echo "WARN: dm $name still exists"
				dmsetup remove "$name" > /dev/null 2>&1 || true
			fi
			;;
		dcp__nxp|versatile__*)
			if cryptsetup status "$name" > /dev/null 2>&1; then
				echo "WARN: cryptdisk $1 still exists"
				cryptsetup close "$name" > /dev/null 2>&1 || true
			fi
			;;
	esac
}

# Open the dm-crypt device.  $1 is extra dmsetup/cryptsetup flags (e.g. --readonly).
# Expects: device_name, CAAM_LOOP, dm_type_mode, KEY_NAME, cipher, key_size,
#          KEY_TYPE, keyname, dir, img_file  — all set by do_mount_disk.
_do_crypt_open()
{
	_crypt_flags=$1
	case "${dm_type_mode}" in
		caam__nxp)
			if ! dmsetup create $_crypt_flags "$device_name" --table "0 $(blockdev --getsz "$CAAM_LOOP") crypt capi:tk(cbc(aes))-plain :36:logon:$KEY_NAME 0 $CAAM_LOOP 0 1 sector_size:512"; then
				echo "ERROR: $dm_type: Unable to create/open crypt device"
				exit 3
			fi
			;;
		caam__mainline|caam-mainline__*|dcp__mainline)
			if ! dmsetup create $_crypt_flags "$device_name" --table "0 $(blockdev --getsz "$CAAM_LOOP") crypt $cipher :$key_size:$KEY_TYPE:$KEY_NAME 0 $CAAM_LOOP 0 1 sector_size:512"; then
				echo "ERROR: $dm_type: Unable to create/open crypt device"
				exit 3
			fi
			;;
		dcp__nxp)
			keyfile=$(mktemp)
			x--pv-dcp-tool decrypt "$dir/$keyname" > "$keyfile"
			if ! cryptsetup open $_crypt_flags -s 256 -c "capi:cbc(aes)-essiv:sha256" --type plain --key-file="$keyfile" "$dir/$img_file" "$device_name"; then
				rm -f "$keyfile"
				echo "ERROR: $dm_type: Unable to create/open crypt device"
				exit 3
			fi
			rm -f "$keyfile"
			;;
		versatile__*)
			if ! cryptsetup open $_crypt_flags -s 256 -c "aes-cbc-essiv:sha256" --type plain --key-file="$dir/$keyname.txt" "$dir/$img_file" "$device_name"; then
				echo "ERROR: $dm_type: Unable to create/open crypt device"
				exit 3
			fi
			;;
		*)
			echo "Unknown device mapper type_mode: ${dm_type_mode}"
			exit 2
			;;
	esac

	for _ in 1 2 3; do
		if [ -b /dev/mapper/"$device_name" ]; then
			break
		fi
		sleep 1
	done
	if [ ! -b /dev/mapper/"$device_name" ]; then
		echo "ERROR: could not find the matching crypt mapper device /dev/mapper/$device_name"
		return 2
	fi
}

# Close the dm-crypt device.
_do_crypt_close()
{
	case "${dm_type_mode}" in
		caam*|dcp__mainline)
			dmsetup remove "$device_name"
			;;
		dcp__nxp|versatile__*)
			cryptsetup close "$device_name"
			;;
	esac
}

do_mount_disk()
{
	do_dm_sanity

	base=$(basename "$path")
	dir=$(dirname "$path")

	keyname=$(echo "$base" | awk '{split($0,a,","); print a[3]}')
	dm_type_mode="${dm_type}__${mode}"
	case "${dm_type_mode}" in
		caam__nxp|dcp__nxp)
			KEY_NAME="logkey:$keyname"
			if [ ! -f "$dir/$keyname.init_done" ]; then
				[ "$no_create" = "yes" ] && return 1
				do_crypt_init "$path"
			fi
			;;
		versatile__*)
			KEY_NAME="logkey:$keyname"
			if [ ! -f "$dir/$keyname.init_done" ]; then
				[ "$no_create" = "yes" ] && return 1
				do_crypt_init "$path"
			fi
			;;
		caam__mainline|caam-mainline__*)
			cipher="capi:cbc(aes)-plain64"
			key_size=32
			KEY_TYPE="trusted"
			KEY_NAME="logkey:$keyname"

			keyblob="${keyname}.bb"
			if [ ! -f "$dir/$keyname.init_done" ]; then
				[ "$no_create" = "yes" ] && return 1
				do_crypt_init "$path"
			fi
			;;
		dcp__mainline)
			cipher="capi:cbc(aes)-essiv:sha256"
			key_size=32
			KEY_TYPE="trusted"
			KEY_NAME="logkey:$keyname"

			keyblob="${keyname}.bb"
			_dcp_migrating=""

			# key migration: convert nxp grey blob to mainline trusted key blob
			# blob is kept as .bb.pending until first successful mount
			if [ ! -f "$dir/$keyblob" ] && [ -f "$dir/$keyname" ]; then
				# remove stale pending blob from previous failed attempt
				rm -f "$dir/$keyblob.pending"
				echo "DCP: migrating nxp key to mainline trusted key blob..."
				if ! x--pv-dcp-tool decrypt "$dir/$keyname" | \
					dcp-blob-create > "$dir/$keyblob.pending.tmp"; then
					echo "ERROR: DCP: key migration failed"
					rm -f "$dir/$keyblob.pending.tmp"
					exit 2
				fi
				sync
				mv "$dir/$keyblob.pending.tmp" "$dir/$keyblob.pending"
				sync
				echo "DCP: pending blob created, will finalize after successful mount"
				_dcp_migrating="yes"
			fi

			# use pending blob if migrating
			if [ "$_dcp_migrating" = "yes" ]; then
				keyblob="${keyname}.bb.pending"
			fi

			if [ ! -f "$dir/$keyname.init_done" ]; then
				[ "$no_create" = "yes" ] && return 1
				do_crypt_init "$path"
			fi
			;;
		*)
			echo "ERROR: crypt vol dm_type_mode '${dm_type_mode}' not support"
			exit 2
			;;
	esac

	cd "$dir" || { echo "ERROR: cannot cd to $dir"; exit 1; }
	case "${dm_type_mode}" in
		caam__nxp)
			# remove legacy raw key file from old installs
			rm -f "$dir/$keyname"
			mkdir -p /data/caam
			cp "$keyname.bb" /data/caam/
			if ! "$CAAM_KEYGEN" import "$keyname.bb" "$keyname.import"; then
				echo "ERROR: CAAM: Unable to import black blob"
				exit 2
			fi
			if ! keyctl padd logon $KEY_NAME @u < /data/caam/"$keyname.import"; then
				echo "ERROR: CAAM: Unable to load logon key"
				exit 2
			fi
			;;
		caam__mainline|caam-mainline__*|dcp__mainline)
			if [ -f "$keyblob" ]; then
				# The "trusted load" interface requires a string explicitly. The read command
				# doesn't handle string input without a line feed gracefully, but still assigns
				# the content to the variable. Therefore, we use 2> /dev/null and || true.
				read -r trusted_key 2> /dev/null < "$keyblob" || true
				if ! keyctl add "$KEY_TYPE" "$KEY_NAME" "load $trusted_key" @u; then
					echo "ERROR: $dm_type: Unable to load trusted key"
					exit 2
				fi
			else
				echo "ERROR: $dm_type: no trusted key $keyblob found in storage" && exit 2
			fi
			;;
	esac

	img_file=$(echo "$base" | awk '{split($0,a,","); print a[1]}')
	cp -f "$dir/$img_file" "$dir/$img_file.prebak"
	if ! CAAM_LOOP=$(atomic_losetup "$dir/$img_file"); then
		echo "ERROR: could not loosetup"
		return 1;
	fi

	device_name=$(echo "$img_file" | awk '{split($0,a,"."); print a[1]}')
	clean_disk "$device_name"

	# For read-only disks, first do a RW mount/umount cycle to replay the
	# ext4 journal.  Without this, a dirty journal from an unclean shutdown
	# (e.g. factory power-cut) makes the ro mount fail with EINVAL.
	if [ "$read_only" = "yes" ]; then
		_do_crypt_open "" # RW
		_recovery_tmp=$(mktemp -d)
		if mount /dev/mapper/"$device_name" "$_recovery_tmp" 2>/dev/null; then
			echo "read-only: journal recovery mount succeeded"
			umount "$_recovery_tmp"
		else
			echo "WARN: read-only: journal recovery mount failed, trying fsck"
			fsck.ext4 -y /dev/mapper/"$device_name" || true
		fi
		rm -rf "$_recovery_tmp"
		_do_crypt_close
	fi

	_dm_ro=""
	if [ "$read_only" = "yes" ]; then
		_dm_ro="--readonly"
	fi
	_do_crypt_open "$_dm_ro"

	mkdir -p "$mntpath"
	_mnt_ro=""
	if [ "$read_only" = "yes" ]; then
		_mnt_ro="-o ro"
	fi
	# shellcheck disable=SC2086
	if mount $MNT_OPTS_EXT4 $_mnt_ro /dev/mapper/"$device_name" "$mntpath"; then
		# only backup if a clean run success
		[ -z "$specialrun" ] && [ ! -f "$dir/$img_file.goodbak" ] && cp -f "$dir/$img_file.prebak" "$dir/$img_file.goodbak"
		# finalize DCP key migration: pending blob is proven to work
		if [ "$_dcp_migrating" = "yes" ]; then
			mv "$dir/${keyname}.bb.pending" "$dir/${keyname}.bb"
			sync
			echo "DCP: key migration verified and finalized"
		fi
		sync
		return 0
	fi

	# mount failed: if we were migrating, remove the unverified pending blob
	# next boot will recreate from scratch
	if [ "$_dcp_migrating" = "yes" ]; then
		rm -f "$dir/${keyname}.bb.pending"
		echo "WARN: DCP migration blob failed to mount, removed pending blob"
	fi

	echo "ERROR: could not setup dm-crypt volume"
	if [ "$specialrun" = "fsck" ] && [ -f "$dir/$img_file.goodbak" ]; then
		echo "Specialrun $specialrun did not succeed ... trying from goodbackup"
		cp -f "$dir/$img_file.goodbak" "$dir/$img_file"
		_do_crypt_close || true
		do_mount_disk_retry bak || return $?
		echo "do_mount_disk from backup suceeded..."
		return 0
	elif [ "$specialrun" = "fsck" ]; then
		# later here we could remove .init_done file to trigger full reinit on next powercycle
		echo "do_mount_disk failed, no backup available, giving up!"
		return 5
	elif [ "$specialrun" = "bak" ]; then
		# later here we could remove .init_done file to trigger full reinit on next powercycle
		echo "do_mount_disk specialrun 'bak' failed. giving up ..."
		return 6
	fi

	echo "Trying fsck ...."
	fsck.ext4 -y /dev/mapper/"$device_name" || true
	_do_crypt_close || true
	sync
	do_mount_disk_retry fsck || return $?
	return 0
}

# Internal helper for recovery retries. Re-invokes the script with --specialrun.
do_mount_disk_retry()
{
	_retry_specialrun=$1
	_retry_ro=""
	if [ "$read_only" = "yes" ]; then
		_retry_ro="--read-only"
	fi
	"$0" mount --type "$dm_type" --mode "$mode" --specialrun "$_retry_specialrun" $_retry_ro -- "$origpath" "$mntpath"
}

do_umount_disk()
{
	# idempotent: if not mounted, succeed immediately
	_real_mntpath=$(realpath "$mntpath" 2>/dev/null || echo "$mntpath")
	if ! grep -q " $_real_mntpath " /proc/mounts 2>/dev/null; then
		echo "disk not mounted at $mntpath, nothing to unmount"
		return 0
	fi

	base=$(basename "$path")
	img_file=$(echo "$base" | awk '{split($0,a,","); print a[1]}')
	keyname=$(echo "$base" | awk '{split($0,a,","); print a[3]}')
	dm_type_mode="${dm_type}__${mode}"

	device_name=$(echo "$img_file" | awk '{split($0,a,"."); print a[1]}')
	umount "$mntpath"
	rm -r "$mntpath"
	case "$dm_type_mode" in
		caam__nxp)
			dmsetup remove "$device_name"
			keyctl unlink $(keyctl search @u logon logkey:$keyname) @u
			rm -rf /data
			;;
		caam__mainline|caam-mainline__*|dcp__mainline)
			dmsetup remove "$device_name"
			keyctl unlink $(keyctl search @u trusted logkey:$keyname) @u
			;;
		dcp__nxp)
			cryptsetup close "$device_name"
			;;
		versatile__*)
			cryptsetup close "$device_name"
			;;
		*)
			echo "Unknown device mapper target"
			exit 4
			;;
	esac
	loop_dev=$(losetup -a | grep "$img_file" | awk '{split($0,a,":"); print a[1]}')
	losetup -d "$loop_dev"
}

case $op in
	mount)
		do_mount_disk
		;;
	umount)
		do_umount_disk
		;;
	*)
		echo "ERROR: unknown action '$op'"
		echo "Usage: crypt <mount|umount> --type <type> --mode <mode> [--read-only] [--no-create] <path> <mntpath>"
		exit 5
		;;
esac
