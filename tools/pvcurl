#!/bin/sh
# pvcurl - Pantavisor curl replacement using nc

usage() {
    echo "Usage: pvcurl --unix-socket [SOCK] [URL]"
    echo "Options: -X, -H, --data, --upload-file, -T, -s, -i, -v, -o, -w, --connect-timeout"
    exit 0
}

[ "$#" -eq 0 ] && usage

# (The content of pvcurl as seen before)
METHOD="GET"
DATA=""
UPLOAD_FILE=""
SOCKET=""
URL=""
HEADERS=""
SHOW_HEADERS=false
SILENT=false
VERBOSE=false
WRITE_OUT=""
OUTPUT_FILE=""
CONNECT_TIMEOUT=5

export PATH=/usr/bin:/bin:/usr/sbin:/sbin

log_err() { [ "$SILENT" = false ] && echo "$@" >&2; }

while [ "$#" -gt 0 ]; do
    case "$1" in
        -X) METHOD="$2"; shift 2 ;;
        -H|--header) HEADERS="${HEADERS}${2}\r\n"; shift 2 ;;
        --data|--data-binary) DATA="$2"; shift 2 ;;
        --upload-file|-T) UPLOAD_FILE="$2"; shift 2 ;;
        --unix-socket) SOCKET="$2"; shift 2 ;;
        --connect-timeout) CONNECT_TIMEOUT="$2"; shift 2 ;;
        --max-time) shift 2 ;;
        -s|--silent) SILENT=true; shift ;;
        -v|--verbose) VERBOSE=true; shift ;;
        -o|--output) OUTPUT_FILE="$2"; shift 2 ;;
        -i|--include) SHOW_HEADERS=true; shift ;;
        -w|--write-out) WRITE_OUT="$2"; shift 2 ;;
        --no-progress-meter) shift ;;
        -h|--help) usage ;;
        *)
            case "$1" in -*) log_err "Error: Unrecognized option '$1'"; exit 1 ;; esac
            if [ -z "$URL" ]; then
                URL=$(echo "$1" | sed -e 's|^http://localhost||' -e 's|^http://||')
            fi
            shift ;;
    esac
done

URL="${URL:-/}"
[ "${URL#/}" = "$URL" ] && URL="/$URL"

if [ -z "$SOCKET" ]; then
    log_err "Error: --unix-socket is required."
    exit 1
fi

if ! echo "$HEADERS" | grep -qi "Content-Type:"; then
    HEADERS="${HEADERS}Content-Type: application/json\r\n"
fi

{
    printf "%s %s HTTP/1.0\r\n" "$METHOD" "$URL"
    printf "Host: localhost\r\n"
    printf "%b" "$HEADERS"
    
    if [ -n "$UPLOAD_FILE" ]; then
        if ! FILE_SIZE=$(stat -c%s "$UPLOAD_FILE" 2>/dev/null); then
            FILE_SIZE=$(ls -l "$UPLOAD_FILE" | awk '{print $5}')
        fi
        printf "Content-Length: %s\r\n\r\n" "$FILE_SIZE"
        cat "$UPLOAD_FILE"
    elif [ -n "$DATA" ]; then
        printf "Content-Length: %s\r\n\r\n" "${#DATA}"
        printf "%s" "$DATA"
    else
        printf "Content-Length: 0\r\n\r\n"
    fi
} > /tmp/http_req

log_verbose() { [ "$VERBOSE" = true ] && echo "* $@" >&2; }

log_verbose "Connecting to $SOCKET..."
log_verbose "> $METHOD $URL HTTP/1.0"

NC_EXIT=0
# Use -N (close write on stdin EOF) for non-streaming requests.
# For streaming downloads (-o), omit -N to keep connection alive for chunked data.
if [ -n "$OUTPUT_FILE" ]; then
    nc -w "$CONNECT_TIMEOUT" -U "$SOCKET" < /tmp/http_req > /tmp/http_res 2>/tmp/nc_err || NC_EXIT=$?
else
    nc -N -w "$CONNECT_TIMEOUT" -U "$SOCKET" < /tmp/http_req > /tmp/http_res 2>/tmp/nc_err || NC_EXIT=$?
fi

if [ "$NC_EXIT" -ne 0 ]; then
    [ "$SILENT" = false ] && [ -f /tmp/nc_err ] && cat /tmp/nc_err >&2
    rm -f /tmp/http_req /tmp/http_res /tmp/nc_err
    exit "$NC_EXIT"
fi

if [ "$VERBOSE" = true ]; then
    head -n 1 /tmp/http_res | tr -d '\r' >&2
fi

extract_body() {
    # Binary-safe header stripping: find byte offset of \r\n\r\n
    # Headers are always ASCII text, so we count header bytes safely
    HBYTES=0
    while IFS= read -r line; do
        HBYTES=$((HBYTES + ${#line} + 1))
        case "$line" in
            ""| "$(printf '\r')") break ;;
        esac
    done < /tmp/http_res
    tail -c +$((HBYTES + 1)) /tmp/http_res
}

if [ -n "$OUTPUT_FILE" ]; then
    extract_body > "$OUTPUT_FILE"
elif [ "$SHOW_HEADERS" = true ]; then
    cat /tmp/http_res
else
    sed '1,/^\r\{0,1\}$/d' /tmp/http_res
fi

if [ -n "$WRITE_OUT" ]; then
    HTTP_STATUS_LINE=$(head -n 1 /tmp/http_res)
    HTTP_CODE=$(echo "$HTTP_STATUS_LINE" | awk '{print $2}')
    # Strip surrounding single quotes (from pvcontrol word-splitting)
    CLEAN_FMT=$(echo "$WRITE_OUT" | sed "s/^'//;s/'$//")
    OUT_STR=$(echo "$CLEAN_FMT" | sed "s/%{http_code}/${HTTP_CODE:-000}/g")
    printf "%b" "$OUT_STR"
fi

rm -f /tmp/http_req /tmp/http_res /tmp/nc_err
