#!/bin/sh

PVTEST_LOG_SOURCE=pvtest-run
source @CMAKE_INSTALL_FULL_DATADIR@/@PROJECT_NAME@/pvtest/utils

usage() {
	echo ""
	echo "Usage: $0 [-v] (driven by INTERACTIVE/MANUAL/OVERWRITE/VERBOSE/NETSIM plus one dispatch mode)"
	echo ""
	echo "Slot-pool mode (persistent model): set PVTEST_QUEUE to the test.json list and"
	echo "PVTEST_CTRL to the host control dir; PVTEST_SLOTS workers force each test's"
	echo "config.env, asking the host to re-type their slot's container on demand."
	echo ""
	echo "Single-device mode: set PVTEST_QUEUE and PVTEST_DEVICE_TARGET to the device"
	echo "name (plus PVTEST_EXEC/PVTEST_HOST to reach it). Every queued test runs"
	echo "sequentially against the one device. If PVTEST_DEV_HOOK_CTRL is set (the"
	echo "manifest configured hook=), a required-config mismatch re-types the device"
	echo "through the hook; otherwise such tests are SKIPPED. Also the volatile"
	echo "model's one-test-per-container path. See docs/overview/testing/device-target.md."
	echo ""
	echo "Interactive/manual mode: set PVTEST_APPENGINES to the appengine name(s) and"
	echo "INTERACTIVE=true; drops into the tester console instead of running tests."
	echo ""
}

parse_test() {
	local j="$test_dir/test.json"
	if [ ! -e "$j" ]; then
		pvtest_log ERROR "'$j' not found"
		return 1
	fi

	description=$(jq -r '.description' "$j")
	# config.env: the config a test runs under — forced per test in the persistent
	# model; on a real device (no boot-time config injection) it's matched against
	# `conf ls` instead, SKIPping the test on mismatch (see run_single_device).
	# config.usrmeta: per-test runtime metadata, applied after ready, removed in teardown.
	required_env=$(jq -r '.setup.config.env // ""' "$j")
	usrmeta=$(jq -r '.setup.config.usrmeta // ""' "$j")
	tarballs=$(jq -r '.setup.containers.tarballs[]? // empty' "$j")
	# commit-initial: whether the initial revision has to be committed.
	commit_initial=$(jq -r '.setup."commit-initial" // "true"' "$j")
	self_claim=$(jq -r '.setup."self-claim"' "$j")
	test_script=$(jq -r '."test-script"' "$j")
	return 0
}

# self-claimed devices pending delete; swept on exit if a test was killed mid-run
# (this-run scope only, safe on shared Hub account)
PVTEST_CLAIMED_DEVICES_FILE="/tmp/pvtest_claimed_devices.$$"
: > "$PVTEST_CLAIMED_DEVICES_FILE" 2>/dev/null || true

cleanup() {
	_sweep_tracked_devices
	kill $(jobs -p) 2>/dev/null
}
trap cleanup EXIT

initial_setup() {
	if [ "$netsim" = "true" ]; then
		wait_for_status "ip link set wlan1 name wlan0" 0 5 > /dev/null 2>&1
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "could not setup wlan0 interface for tester"
			exit 1
		fi
	fi
}

exec_interactive() {
	echo ""
	echo "Welcome to pvtest tester!"
	echo ""

	if [ "$manual" = "true" ]; then
		echo "No pantavisor target is configured (manual mode)."
		echo "Connect to a device manually and set PVTEST_EXEC before running your test."
	else
		echo "Pantavisor is starting in the appengine container (no state deployed yet)."
		echo "Run pvtest-run to wait for device ready, deploy test state, and execute tests."
	fi
	echo ""

	# INTERACTIVE=false so a nested pvtest-run call runs tests, not another shell
	export INTERACTIVE=false
	# Signal pool mode to skip auto-shutdown — we send it on console exit instead.
	export PVTEST_CONSOLE=1
	local _rc
	_rc=$(mktemp /tmp/pvtest_rc.XXXXXX)
	printf '. @CMAKE_INSTALL_FULL_DATADIR@/@PROJECT_NAME@/pvtest/utils\n' > "$_rc"
	bash --rcfile "$_rc" -i
	rm -f "$_rc"
}

# build SSH exec cmd for appengine name; PVTEST_EXEC used verbatim if set; else empty = local
_ae_exec_cmd() {
	local ae="$1"
	if [ -n "$PVTEST_EXEC" ]; then
		printf '%s' "$PVTEST_EXEC"
	elif [ -n "$PVTEST_SSH_KEY" ]; then
		# bound SSH attempts to a few seconds so polling during reboots fails fast, not hangs
		printf 'ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o BatchMode=yes -o ConnectTimeout=5 -o ServerAliveInterval=3 -o ServerAliveCountMax=2 -i %s -p 8222 _pv_@%s' \
			"$PVTEST_SSH_KEY" "$ae"
	else
		printf ''
	fi
}

# Resolve the pvr HTTP host for a given appengine name.
_ae_host() {
	local ae="$1"
	if [ -n "$PVTEST_HOST" ]; then
		printf '%s' "$PVTEST_HOST"
	else
		printf '%s' "$ae"
	fi
}

# path to the stored `conf ls` JSON for a given appengine name, used by the config matcher
_ae_conf_file() {
	local ae="$1" ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')
	printf '/tmp/pvtest_device_conf_%s.json' "$ae_safe"
}

# per-device pristine factory clone path (init_device); test setup clones from here to avoid trail buildup
_ae_factory_dir() {
	local ae="$1" ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')
	printf '/tmp/pvtest_factory_%s' "$ae_safe"
}

# per-device pvr HOME, keyed by appengine name — avoids concurrent pool slots racing on shared ~/.pvr
_ae_pvr_home() {
	local ae="${1:-$PVTEST_AE}" ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')
	printf '/tmp/pvtest_pvrhome_%s' "${ae_safe:-default}"
}

# normalize required-config to a stable signature (mirrors normalize_reqcfg in test.docker.sh)
_reqcfg_norm() {
	printf '%s\n' $1 | grep -v '^$' | grep -v '^PV_LXC_LOG_LEVEL=' | sort | tr '\n' ' ' | sed 's/ *$//'
}

# run a pvr command authenticated against the Hub in this device's isolated HOME
_pvr_auth() {
	# refuse unauthenticated pvr — it hangs ~5min in an interactive browser login otherwise
	if [ -z "$PH_USER" ] || [ -z "$PH_PASS" ]; then
		pvtest_log ERROR "PH_USER/PH_PASS not set; refusing unauthenticated 'pvr $*'"
		return 1
	fi
	local home; home="$(_ae_pvr_home)"
	mkdir -p "$home" 2>/dev/null
	(
		export HOME="$home"
		if ! PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" pvr login > /dev/null 2>&1; then
			pvtest_log ERROR "pvr login failed; refusing 'pvr $*'"
			exit 1
		fi
		pvr "$@"
	)
}

# _pvr_auth wrapper that logs output on failure so Hub ops aren't silent when they fail
_pvr_logged() {
	local out rc
	out=$(_pvr_auth "$@" 2>&1)
	rc=$?
	if [ $rc -ne 0 ]; then
		pvtest_log ERROR "pvr $* failed (exit $rc)${out:+: $out}"
	fi
	return $rc
}

# delete Hub user-meta key via PATCH null (-> Mongo $unset); pvr has no delete verb.
# best-effort, needs PH creds.
_hub_usrmeta_delete() {
	local device_id="$1" key="$2" home tok
	{ [ -n "$PH_USER" ] && [ -n "$PH_PASS" ] && [ -n "$device_id" ]; } || return 0
	home="$(_ae_pvr_home)"; mkdir -p "$home" 2>/dev/null
	( export HOME="$home"
	  PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" pvr login > /dev/null 2>&1 )
	tok=$(jq -r 'first(.tokens[]) | .["access-token"] // empty' \
		"$home/.pvr/auth.json" 2>/dev/null)
	[ -n "$tok" ] || return 0
	curl -s -X PATCH \
		-H "Authorization: Bearer $tok" -H "Content-Type: application/json" \
		-d "{\"$key\": null}" \
		"${PVTEST_HUB_URL:-https://api.pantahub.com}/devices/$device_id/user-meta" \
		> /dev/null 2>&1
}

# set Hub user-meta key (PATCH), retried — ownership propagation lag right after claim
_hub_usrmeta_set() {
	local device_id="$1" key="$2" value="$3" home tok attempt=1
	{ [ -n "$PH_USER" ] && [ -n "$PH_PASS" ] && [ -n "$device_id" ]; } || return 0
	home="$(_ae_pvr_home)"; mkdir -p "$home" 2>/dev/null
	( export HOME="$home"
	  PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" pvr login > /dev/null 2>&1 )
	tok=$(jq -r 'first(.tokens[]) | .["access-token"] // empty' \
		"$home/.pvr/auth.json" 2>/dev/null)
	[ -n "$tok" ] || return 1
	while [ $attempt -le 4 ]; do
		curl -sf -X PATCH \
			-H "Authorization: Bearer $tok" -H "Content-Type: application/json" \
			-d "{\"$key\": \"$value\"}" \
			"${PVTEST_HUB_URL:-https://api.pantahub.com}/devices/$device_id/user-meta" \
			> /dev/null 2>&1 && return 0
		attempt=$((attempt + 1))
		[ $attempt -le 4 ] && sleep 5
	done
	return 1
}

# wait for pantahub.state to settle to a terminal claim state ("claim"=unclaimed, "idle"=claimed);
# echoes it, or nothing on timeout. Needed since the client takes time to register after boot.
_wait_pantahub_terminal_state() {
	local timeout="${1:-120}" counter=0 st
	while [ "$counter" -lt "$timeout" ]; do
		st=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantahub.state"] // empty')
		case "$st" in
		claim | idle)
			printf '%s' "$st"
			return 0
			;;
		esac
		sleep 2
		counter=$((counter + 2))
	done
	return 1
}

# track ($1=add) / untrack ($1=del) a self-claimed device id ($2), flock-serialised for the pool
_track_device() {
	local op="$1" dev="$2" f="$PVTEST_CLAIMED_DEVICES_FILE"
	[ -n "$f" ] && [ -n "$dev" ] || return 0
	(
		flock -x 8
		case "$op" in
			add) grep -qxF "$dev" "$f" 2>/dev/null || printf '%s\n' "$dev" >> "$f" ;;
			del) [ -f "$f" ] && { grep -vxF "$dev" "$f" > "$f.tmp" 2>/dev/null; mv "$f.tmp" "$f" 2>/dev/null; } ;;
		esac
	) 8>>"$f.lock"
}

# delete any still-tracked self-claimed devices (a test killed before teardown); EXIT trap
_sweep_tracked_devices() {
	local f="$PVTEST_CLAIMED_DEVICES_FILE" d
	[ -n "$f" ] && [ -s "$f" ] || return 0
	while IFS= read -r d; do
		[ -n "$d" ] || continue
		pvtest_log WARN "sweeping leftover self-claimed device $d"
		_pvr_auth dev delete -y "$d" > /dev/null 2>&1
	done < "$f"
	: > "$f" 2>/dev/null || true
}

# Echo the value of config key $1 from a `conf ls` JSON file $2 (empty if absent).
# conf ls format: [{"key":"PV_CONTROL_REMOTE","value":"0","modified":"..."}, ...]
_conf_value() {
	jq -r --arg k "$1" 'if type=="array" then (.[] | select(.key==$k) | .value) // empty else empty end' \
		"$2" 2>/dev/null
}

# True when the device's captured `conf ls` ($2) already satisfies every KEY=VALUE
# in the normalized required-config ($1). Unlike an appengine container — booted
# with required-config injected as env — a real device's config can't be changed
# per test, so a test whose required-config the device doesn't already have is
# SKIPPED rather than run (see run_test_attempt / docs/testing/device-target.md).
_reqcfg_satisfied() {
	local kv k v actual
	for kv in $(_reqcfg_norm "$1"); do
		k=${kv%%=*}
		v=${kv#*=}
		actual=$(_conf_value "$k" "$2")
		[ "$actual" = "$v" ] || return 1
	done
	return 0
}

# persistent pool only: does the container's currently-loaded config already
# satisfy this test's required config ($1)? If not, power off and signal the
# caller to re-type (the single power cycle setup_test merges with the
# initial revision's commit reboot). Returns 0 (proceed) or 3 (caller must
# re-type).
_reqcfg_gate() {
	local _next_cfg="$1"
	[ -n "$_next_cfg" ] || return 0
	pvcontrol conf ls > "$(_ae_conf_file "$PVTEST_AE")" 2>/dev/null || true
	if ! _reqcfg_satisfied "$_next_cfg" "$(_ae_conf_file "$PVTEST_AE")"; then
		pvtest_log INFO "test needs a different config; powering off..."
		pv_ctrl cmd poweroff "pvtest: test needs different config" > /dev/null 2>&1 || true
		return 3
	fi
	return 0
}

# pvcontrol wrapper: retries on 75/503 (slot busy); -q silences WARNs, keeps retry.
# The last response body is left in pv_ctrl_out for callers that need to
# tell benign rejections apart from real failures.
pv_ctrl() {
	local quiet=
	[ "$1" = "-q" ] && { quiet=1; shift; }
	local max_attempts=4 delay=5 attempt=1 out rc
	local _via="${PVTEST_EXEC:+ [via SSH]}"
	pvtest_log DEBUG "pvcontrol $*${_via}"
	while [ $attempt -le $max_attempts ]; do
		out=$(pvcontrol "$@" 2>&1)
		rc=$?
		pv_ctrl_out="$out"
		[ $rc -eq 0 ] && return 0
		if [ $rc -eq 75 ]; then
			[ -n "$quiet" ] || pvtest_log WARN "pvcontrol $*${_via} rejected (503, attempt $attempt/$max_attempts)${out:+: $out}; retrying in ${delay}s..."
			attempt=$((attempt + 1))
			[ $attempt -le $max_attempts ] && sleep $delay
		else
			[ -n "$quiet" ] || pvtest_log WARN "pvcontrol $*${_via} failed (exit $rc)${out:+: $out}"
			return $rc
		fi
	done
	[ -n "$quiet" ] || pvtest_log WARN "pvcontrol $* failed after $max_attempts attempts (503)"
	return 75
}

stop_pv() {
	pvtest_log DEBUG "stop_pv: requesting lenient pantavisor shutdown..."
	pv_ctrl cmd poweroff "pvtest: run complete"
}

int_handler() {
	pvtest_log DEBUG "Stopping Pantavisor..."
	stop_pv
	exit 2
}

# post-flash init for a single device: wait for pantavisor to respond, collect device info
init_device() {
	local ae="$1"
	local ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')

	export PVTEST_EXEC="$(_ae_exec_cmd "$ae")"
	export PVTEST_HOST="$(_ae_host "$ae")"

	trap 'int_handler' INT

	wait_for_target_ready "init" "" "DONE|UPDATED" || return 1

	# capture device's live config once; tests matched against it via setup.config.env
	pvtest_log INFO "init: storing config [via SSH]..."
	pvcontrol conf ls > "$(_ae_conf_file "$ae")" 2>/dev/null || true

	pvtest_log INFO "init: collecting device info [via SSH]..."
	pvcontrol devmeta ls > "/tmp/pvtest_device_info_${ae_safe}.json" 2>/dev/null || true
	jq -r '"  revision=\(.["pantavisor.revision"])  arch=\(.["pantavisor.arch"])  version=\(.["pantavisor.version"])"' \
		"/tmp/pvtest_device_info_${ae_safe}.json" 2>/dev/null || true

	# volatile boots straight into the test's revision
	if [ "$PVTEST_MODEL" = "volatile" ]; then
		pvtest_log INFO "init: done"
		return 0
	fi

	# pristine clone of the factory revision; each test's setup starts from a copy of this
	pvtest_log INFO "init: cloning factory revision [via pvr HTTP]..."
	local factory_dir; factory_dir="$(_ae_factory_dir "$ae")"
	rm -rf "$factory_dir" "$factory_dir.home"
	mkdir -p "$factory_dir.home"
	if ! ( export HOME="$factory_dir.home"; pvr clone "http://$(_ae_host "$ae"):12368/cgi-bin/pvr" "$factory_dir" > /dev/null 2>&1 ); then
		pvtest_log ERROR "failed to clone factory revision"
		return 1
	fi

	# export of the pristine clone; seeds pvtx setups (immune to on-device GC)
	pvtest_log INFO "init: exporting factory revision..."
	rm -f "$factory_dir.tgz"
	if ! ( export HOME="$factory_dir.home"; cd "$factory_dir" && pvr export "$factory_dir.tgz" > /dev/null 2>&1 ); then
		pvtest_log ERROR "failed to export factory revision"
		return 1
	fi

	pvtest_log INFO "init: done"
	return 0
}

# run the synchronous garbage collector, logging the reclaimed bytes
_dev_gc() {
	local _out
	_out=$(pvcontrol storage gc 2>&1)
	if [ $? -ne 0 ]; then
		pvtest_log WARN "sync gc failed${_out:+: $_out}"
		return 1
	fi
	pvtest_log INFO "gc finished${_out:+: $_out}"
	return 0
}

# One-time courtesy reset, run only at the very end of a real-device
# (--devices) run: return the target to a pristine, gc'd factory state,
# installing a FRESH randomly-named child of the factory clone — never
# re-runs the cached factory revision by name, since a prior sync gc may have
# reclaimed it. Per-test resets no longer go through here: setup_test installs
# and commits each test's own initial revision directly (see setup_test).
#  1. drain whatever the last test left running
#  2. install a fresh, randomly-named child of the factory clone (pvtx/pvr;
#     no test tarballs — a bare reset) and wait for it like any posted revision
#  3. commit it with a reboot if it comes back UPDATED, otherwise nothing left to do
#  4. confirm back (best-effort READY) and synchronous gc
# Returns 0 settled+gc'd, 1 error.
_settle_to_factory() {
	local factory_dir _new_rev _st _saved_tarballs

	factory_dir="$(_ae_factory_dir "$PVTEST_AE")"
	if [ ! -d "$factory_dir" ]; then
		pvtest_log WARN "no factory clone; skipping factory reset"
		return 0
	fi

	# 1. drain whatever the last test left running
	wait_for_current_settled \
		|| pvtest_log WARN "device did not settle before factory reset; continuing"

	# 2. install a fresh, randomly-named child of the factory clone (no test
	# tarballs — a bare reset), then wait for it like any posted revision
	_saved_tarballs="$tarballs"; tarballs=""
	if _have_pvtx; then
		pvtest_log DEBUG "resetting to factory with pvtx"
		_install_initial_pvtx "" || { tarballs="$_saved_tarballs"; return 1; }
		_new_rev="$_pvtx_rev"
	elif command -v pvr > /dev/null 2>&1; then
		pvtest_log INFO "pvtx not available on device; falling back to pvr HTTP-post"
		_install_initial_pvr "$factory_dir" "" || { tarballs="$_saved_tarballs"; return 1; }
		_new_rev="$_pvr_rev"
	else
		tarballs="$_saved_tarballs"
		pvtest_log ERROR "cannot reset to factory: neither pvtx nor pvr available"
		return 1
	fi
	tarballs="$_saved_tarballs"

	if [ -z "$_new_rev" ]; then
		pvtest_log ERROR "factory-reset revision was installed without a name"
		return 1
	fi
	wait_for_target_ready "factory revision" "$_new_rev" "DONE|UPDATED" || return 1
	_st=$(pvcontrol steps show-progress "$_new_rev" 2>/dev/null | jq -r '.status' 2>/dev/null)

	# 3. commit the fresh revision with a reboot if it's still pending
	# (UPDATED), otherwise there is nothing left to do
	if [ "$_st" = "UPDATED" ]; then
		pvtest_log INFO "factory revision needs a reboot to commit; rebooting..."
		pv_ctrl cmd reboot "pvtest: committing factory reset" || return 1
		wait_for_down 30 || pvtest_log WARN "device did not confirm down after reboot; continuing"
		wait_for_target_ready "factory reset" "$_new_rev" DONE || return 1
	fi

	# 4. confirm back and gc
	wait_for_current_settled || true
	_dev_gc || true
	return 0
}

# Read a file from the device, routing over SSH when PVTEST_EXEC is set.
_dev_read_file() {
	if [ -n "$PVTEST_EXEC" ]; then
		$PVTEST_EXEC "cat $1" 2>/dev/null
	else
		cat "$1" 2>/dev/null
	fi
}

_dev_unclaim() {
	local dev="${1:-$(_dev_read_file /var/run/pantavisor/pv/device-id)}"

	# an update in flight (e.g. the test's own revision still applying) makes
	# pv reject unclaim with 503 — drain it first
	wait_for_current_settled \
		|| pvtest_log WARN "device did not settle before unclaim; trying anyway"

	if ! pv_ctrl -q cmd unclaim; then
		case "$pv_ctrl_out" in
		*"already unclaimed"*)
			pvtest_log INFO "device already unclaimed"
			return 0
			;;
		esac
		pvtest_log ERROR "pvcontrol cmd unclaim failed: $pv_ctrl_out"
		return 1
	fi
	if [ -n "$dev" ]; then
		pvtest_log INFO "deleting device $dev from Hub"
		_pvr_logged dev delete -y "$dev"
		_track_device del "$dev"
	fi
	pvtest_log INFO "device unclaimed"
	return 0
}

# claim the device this slot points at, leaving it idle (claimed); non-zero on failure.
# called once per slot attach to a claim=yes runner-type, not per test.
_dev_claim() {
	local state
	state=$(_wait_pantahub_terminal_state 120)
	if [ "$state" != "claim" ]; then
		pvtest_log ERROR "cannot claim: pantahub.state='${state:-<none>}' (expected claim)"
		return 1
	fi
	# the device-id/challenge hint files are written just after pantahub.state
	# flips to claim — wait for both instead of failing the first attempt
	local device_id challenge _waited=0
	while [ $_waited -lt 60 ]; do
		device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
		challenge=$(_dev_read_file /var/run/pantavisor/pv/challenge)
		[ -n "$device_id" ] && [ -n "$challenge" ] && break
		sleep 2
		_waited=$((_waited + 2))
	done
	if [ -z "$device_id" ] || [ -z "$challenge" ]; then
		pvtest_log ERROR "cannot claim: missing device-id ('$device_id') or challenge after ${_waited}s"
		return 1
	fi

	# retry a few times, re-reading the challenge each attempt — Hub 400 or challenge rotation are transient
	local _try _claimed=
	for _try in 1 2 3; do
		device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
		challenge=$(_dev_read_file /var/run/pantavisor/pv/challenge)
		if [ -z "$device_id" ] || [ -z "$challenge" ]; then
			pvtest_log ERROR "cannot claim (attempt $_try): missing device-id ('$device_id') or challenge"
		else
			pvtest_log INFO "claiming device $device_id (attempt $_try)..."
			if _pvr_logged claim -c "$challenge" "$device_id"; then
				_claimed=1; break
			fi
		fi
		[ "$_try" != 3 ] && sleep 2
	done
	if [ -z "$_claimed" ]; then
		pvtest_log ERROR "claim failed after 3 attempts"
		return 1
	fi
	_track_device add "$device_id"
	if ! wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantahub.state\"]'" "idle" 120; then
		pvtest_log ERROR "timed out waiting for pantahub.state=idle after claim"
		return 1
	fi
	pvtest_log INFO "claimed device $device_id"
	return 0
}

# Delete the device this slot currently points at from the Hub, without rebooting.
# Called once when a slot detaches from a claim=yes runner-type.
_dev_delete_only() {
	local device_id
	device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
	[ -n "$device_id" ] || return 0
	pvtest_log INFO "deleting claimed device $device_id"
	_pvr_logged dev delete -y "$device_id"
	_track_device del "$device_id"
}

# self-claim=false with a device still claimed by a previous test: unclaim it BEFORE
# go-remote, while the Hub client is down — a stale in-flight trail update cannot resume
# then, so it can neither reject the unclaim with 503 ("update ongoing") nor apply over
# the just-installed test revision. Claimed is detected from the hint files: pv writes
# the device-id at boot only when pantahub.config carries creds, and the challenge file
# is non-empty only while the device is registered-but-unclaimed. Hub-side deletion is
# deferred to handle_self_claim.
handle_pre_remote_unclaim() {
	pre_unclaimed_device=

	case " $(_reqcfg_norm "$required_env") " in
	*" PV_CONTROL_REMOTE=1 "*) ;;
	*) return 0 ;;
	esac
	[ "$self_claim" = "false" ] || return 0

	local dev challenge
	dev=$(_dev_read_file /var/run/pantavisor/pv/device-id)
	challenge=$(_dev_read_file /var/run/pantavisor/pv/challenge)
	{ [ -n "$dev" ] && [ -z "$challenge" ]; } || return 0

	pvtest_log INFO "device claimed from a previous test; unclaiming ($dev) before go-remote..."
	if ! pv_ctrl -q cmd unclaim; then
		# an aborted previous setup can leave the device already unclaimed
		# with the hint files not yet renewed — benign, nothing to delete
		case "$pv_ctrl_out" in
		*"already unclaimed"*)
			pvtest_log INFO "device already unclaimed"
			return 0
			;;
		esac
		pvtest_log ERROR "pvcontrol cmd unclaim failed: $pv_ctrl_out"
		return 1
	fi
	pre_unclaimed_device="$dev"
	return 0
}

# bring the device into the claim state required by setup.self-claim; no-op for local devices.
# Runs for every model at the end of setup_test, after go-remote, so the Hub client is up
# and the committed DONE revision satisfies the unclaimed register/claim walk. State-driven,
# so adjacent tests sharing a claim state (persistent pool's rank-0 block) are cheap no-ops.
# a device claimed here (self-claim=true) is recorded in claimed_device for teardown deletion.
handle_self_claim() {
	claimed_device=

	# no-op for tests that don't run under PV_CONTROL_REMOTE: pantahub.state never
	# appears for those, so there's nothing to wait for or claim/unclaim
	case " $(_reqcfg_norm "$required_env") " in
	*" PV_CONTROL_REMOTE=1 "*) ;;
	*) return 0 ;;
	esac

	# right after boot, pantahub.state can take a few seconds to appear once the
	# Hub client comes up — wait for it instead of a one-shot check
	local state
	state=$(_wait_pantahub_terminal_state 120)
	if [ -z "$state" ]; then
		pvtest_log ERROR "pantahub.state did not settle"
		return 1
	fi

	# drop the identity a pre-go-remote unclaim (handle_pre_remote_unclaim)
	# left behind; _dev_claim below re-checks the state it needs
	if [ -n "$pre_unclaimed_device" ]; then
		pvtest_log INFO "deleting device $pre_unclaimed_device from Hub"
		_pvr_logged dev delete -y "$pre_unclaimed_device"
		_track_device del "$pre_unclaimed_device"
		pre_unclaimed_device=
	fi

	local device_id
	device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)

	if [ "$state" = "idle" ] && [ "$self_claim" = "false" ] && [ -n "$device_id" ]; then
		pvtest_log INFO "self-claim=false but device claimed; unclaiming ($device_id)..."
		_dev_unclaim "$device_id" || return 1
	elif [ "$state" = "claim" ] && [ "$self_claim" = "true" ]; then
		local _claim_start
		_claim_start=$(date +%s)
		_dev_claim || return 1
		claimed_device=$(_dev_read_file /var/run/pantavisor/pv/device-id)
		# report claim result-style so it lands in SUMMARY alongside PASSED/FAILED
		pvtest_log INFO "'$PVTEST_AE' claimed ($(( $(date +%s) - _claim_start )) s)"
	fi
	return 0
}

# apply usrmeta per key; set both locally (immediate effect) and on Hub (survives remote sync overwrite).
# Hub set is best-effort — self-claim=false tests don't own the device yet.
apply_usrmeta() {
	applied_usrmeta_keys=
	[ -n "$usrmeta" ] || return 0
	local device_id=""
	if [ "$self_claim" = "true" ] && [ -n "$PH_USER" ] && [ -n "$PH_PASS" ]; then
		device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
	fi
	local kv k v
	for kv in $usrmeta; do
		k=${kv%%=*}
		v=${kv#*=}
		[ -n "$k" ] || continue
		pvtest_log INFO "usrmeta save $k=$v"
		pv_ctrl -q usrmeta save "$k" "$v"
		if [ -n "$device_id" ]; then
			_hub_usrmeta_set "$device_id" "$k" "$v" \
				|| pvtest_log WARN "could not set Hub user-meta $k=$v"
		fi
		applied_usrmeta_keys="${applied_usrmeta_keys:+$applied_usrmeta_keys }$k"
	done
}

# Build the initial revision on the device with pvtx (begin empty + add each
# self-contained tarball), like pv-appengine first boot. Sets _pvtx_rev.
_install_initial_pvtx() {
	local rev_name="$1"
	local _out
	_pvtx_rev=""

	pvtx abort > /dev/null 2>&1
	pvtest_log DEBUG "pvtx begin empty [via SSH]"
	if ! _out=$(pvtx begin empty 2>&1); then
		pvtest_log ERROR "pvtx begin empty failed: $_out"
		return 1
	fi

	local t tarball_path remote_tarball

	# seed with the factory export: initial revision = cloned device state + extras
	local factory_tgz
	factory_tgz="$(_ae_factory_dir "$PVTEST_AE").tgz"
	if [ -f "$factory_tgz" ]; then
		remote_tarball="/tmp/pvtest_pvtx_$$_factory.tgz"
		pvtest_log DEBUG "pvtx add factory export [via SSH]"
		if ! $PVTEST_EXEC "cat > '$remote_tarball'" < "$factory_tgz"; then
			pvtest_log ERROR "failed to stage factory export to device"
			pvtx abort > /dev/null 2>&1
			return 1
		fi
		_out=$(pvtx add "$remote_tarball" 2>&1) || {
			pvtest_log ERROR "pvtx add failed for factory export: $_out"
			$PVTEST_EXEC "rm -f '$remote_tarball'" > /dev/null 2>&1
			pvtx abort > /dev/null 2>&1
			return 1
		}
		$PVTEST_EXEC "rm -f '$remote_tarball'" > /dev/null 2>&1
	else
		pvtest_log WARN "no factory export found; building initial revision from tarballs only"
	fi

	for t in $tarballs; do
		if [ "${t#/}" = "$t" ]; then
			tarball_path="$test_dir/$t"
		else
			tarball_path="$t"
		fi
		# pvtx seeks the tarball fd, so stage to a real file first (SSH stdin is a pipe)
		remote_tarball="/tmp/pvtest_pvtx_$$_${t##*/}"
		pvtest_log DEBUG "pvtx add ${tarball_path##*/} [via SSH]"
		if ! $PVTEST_EXEC "cat > '$remote_tarball'" < "$tarball_path"; then
			pvtest_log ERROR "failed to stage ${tarball_path##*/} to device"
			pvtx abort > /dev/null 2>&1
			return 1
		fi
		_out=$(pvtx add "$remote_tarball" 2>&1) || {
			pvtest_log ERROR "pvtx add failed for ${tarball_path##*/}: $_out"
			$PVTEST_EXEC "rm -f '$remote_tarball'" > /dev/null 2>&1
			pvtx abort > /dev/null 2>&1
			return 1
		}
		$PVTEST_EXEC "rm -f '$remote_tarball'" > /dev/null 2>&1
	done

	pvtest_log DEBUG "pvtx commit $rev_name [via SSH]"
	if ! _out=$(pvtx commit "$rev_name" 2>&1); then
		pvtest_log ERROR "pvtx commit failed: $_out"
		pvtx abort > /dev/null 2>&1
		return 1
	fi
	_pvtx_rev=$(printf '%s' "$_out" | tr -d '\r' | grep -v '^$' | tail -n1)
	if [ -z "$_pvtx_rev" ]; then
		pvtest_log ERROR "pvtx commit produced no revision"
		return 1
	fi
	pvtest_log INFO "pvtx committed initial revision $_pvtx_rev"

	pvtest_log DEBUG "pvcontrol cmd run $_pvtx_rev [via SSH]"
	if ! _out=$(pvcontrol cmd run "$_pvtx_rev" 2>&1); then
		pvtest_log ERROR "failed to run revision $_pvtx_rev: $_out"
		return 1
	fi
	return 0
}

# fallback: build the initial revision in a private tester-side pvr repo (child of the
# factory clone) and post it to the device. Used when pvtx can't.
# rev_name empty = let the device assign one (sets _pvr_rev); pvr's local-endpoint
# post has no documented "assigned name" stdout message to parse (unlike the Hub's
# "Successfully posted Revision N", which pvr_post_rev in utils.in parses — a
# different target/format), so the assigned name is instead observed as whichever
# new value pantavisor.revision takes on right after the post succeeds.
_install_initial_pvr() {
	local factory_dir="$1" rev_name="$2"
	_pvr_rev=""

	local setup_parent setup_dir
	setup_parent=$(mktemp -d /tmp/pvtest_setup.XXXXXX)
	setup_dir="$setup_parent/repo"
	mkdir -p "$setup_dir"

	# isolated HOME/.pvr cache per test — pool slots share a tester container and would
	# otherwise race on the global content-addressed object cache during concurrent pvr ops.
	# seed from the device's pristine factory clone so the revision replaces, not accumulates on, the last test's
	pvtest_log DEBUG "seeding $setup_dir from factory clone $factory_dir"
	if [ ! -d "$factory_dir/.pvr" ] || ! cp -a "$factory_dir/." "$setup_dir/" 2>/dev/null; then
		pvtest_log ERROR "failed to copy factory clone"
		rm -rf "$setup_parent"
		return 1
	fi

	local t tarball_path frag_dir
	for t in $tarballs; do
		if [ "${t#/}" = "$t" ]; then
			tarball_path="$test_dir/$t"
		else
			tarball_path="$t"
		fi
		frag_dir=$(mktemp -d /tmp/pvtest_frag.XXXXXX)
		tar xzf "$tarball_path" -C "$frag_dir" > /dev/null 2>&1
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "failed to extract tarball: $tarball_path"
			rm -rf "$frag_dir" "$setup_parent"
			return 1
		fi
		pvtest_log DEBUG "pvr merge ${tarball_path##*/}"
		( export HOME="$setup_parent"; cd "$setup_dir" && pvr merge "$frag_dir" > /dev/null 2>&1 )
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "pvr merge failed for $tarball_path"
			rm -rf "$frag_dir" "$setup_parent"
			return 1
		fi
		rm -rf "$frag_dir"
	done

	# checkout materialises the merged files so the following commit captures the full revision
	pvtest_log DEBUG "pvr checkout && pvr commit"
	( export HOME="$setup_parent"; cd "$setup_dir" && pvr checkout > /dev/null 2>&1 && pvr commit > /dev/null 2>&1 )
	if [ $? -ne 0 ]; then
		pvtest_log ERROR "pvr checkout/commit failed"
		rm -rf "$setup_parent"
		return 1
	fi

	if [ -n "$rev_name" ]; then
		pvtest_log DEBUG "posting initial revision $rev_name [via pvr HTTP]"
		( export HOME="$setup_parent"; cd "$setup_dir" && pvr post --rev "$rev_name" "http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr" > /dev/null 2>&1 )
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "pvr post failed for $rev_name"
			rm -rf "$setup_parent"
			return 1
		fi
	else
		local _prev_rev
		_prev_rev=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantavisor.revision"] // empty')
		pvtest_log DEBUG "posting revision (device-assigned name) [via pvr HTTP]"
		( export HOME="$setup_parent"; cd "$setup_dir" && pvr post "http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr" > /dev/null 2>&1 )
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "pvr post failed"
			rm -rf "$setup_parent"
			return 1
		fi
		if ! wait_for_status "test \"\$(pvcontrol devmeta ls 2>/dev/null | jq -r '.[\"pantavisor.revision\"] // empty')\" != \"$_prev_rev\"" 0 30; then
			pvtest_log ERROR "posted revision never became current"
			rm -rf "$setup_parent"
			return 1
		fi
		_pvr_rev=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantavisor.revision"] // empty')
	fi

	rm -rf "$setup_parent"
	return 0
}

# mid-setup re-type (persistent pool): the slot's container was already powered
# off by _reqcfg_gate; ask the host for a new generation with this test's config
# on the same storage — it boots straight into the pending initial revision $1
# and commits it, merging the config change and the commit reboot into one power
# cycle. Re-keys the per-name artifacts (factory clone/export, conf snapshot)
# and re-targets run_test_attempt's device-log tail (ae_log/ae_tail_pid/
# PVTEST_ACTIVE_TESTLOG, reached via dynamic scoping) at the new container's
# log. Clears PVTEST_AE when the slot is left without a usable container so the
# worker re-attaches fresh on its next pick.
_setup_retype() {
	local _rev="$1" _old="$PVTEST_AE" _new

	pvtest_log INFO "re-typing on storage w${PVTEST_SLOT} cfg=[$(_reqcfg_norm "$required_env")]"
	_new=$(_retype_slot "$PVTEST_SLOT" "$required_env" "w${PVTEST_SLOT}")
	if [ -z "$_new" ]; then
		pvtest_log ERROR "re-type failed"
		export PVTEST_AE=""
		return 1
	fi

	# per-name artifacts follow the container name; their content (factory
	# clone/export of this same storage) is identical across generations
	mv "$(_ae_factory_dir "$_old")" "$(_ae_factory_dir "$_new")" 2>/dev/null
	mv "$(_ae_factory_dir "$_old").home" "$(_ae_factory_dir "$_new").home" 2>/dev/null
	mv "$(_ae_factory_dir "$_old").tgz" "$(_ae_factory_dir "$_new").tgz" 2>/dev/null

	_slot_bind_ae "$_new"

	# re-target the device-log tail at the new generation's log (fresh file)
	if [ -n "$ae_tail_pid" ]; then
		kill "$ae_tail_pid" 2>/dev/null
		wait "$ae_tail_pid" 2>/dev/null || true
		ae_log="$APPENGINE_LOGS/${_new}.log"
		ae_tail_pid=""
		if [ -f "$ae_log" ]; then
			tail -n +1 -f "$ae_log" >> "$PVTEST_ACTIVE_TESTLOG" 2>/dev/null &
			ae_tail_pid=$!
		fi
	fi

	if ! wait_for_target_ready "re-type '$_new'" "$_rev" DONE; then
		export PVTEST_AE=""
		return 1
	fi

	# refresh the stored conf snapshot for the newly loaded config
	pvcontrol conf ls > "$(_ae_conf_file "$_new")" 2>/dev/null || true
	return 0
}

# real device (persistent model, --devices with a manifest hook=): the config
# mismatch already power-cycles as part of the hook itself (unlike the pool's
# _reqcfg_gate, which powers off first and waits for a fresh container to boot
# it back up), so this asks the host to run the hook and then fences the same
# target's reboot directly — no new container identity to disambiguate against,
# just this device going down and coming back with the new config.
_setup_device_retype() {
	local _rev="$1" _id _resp _status _waited=0

	pvtest_log INFO "device retype: requesting hook cfg=[$(_reqcfg_norm "$required_env")]"

	_id="req.$$.$(date +%s%N)"
	{ printf 'cfg=%s\n' "$required_env"; } > "$PVTEST_DEV_HOOK_CTRL/req/.tmp.$_id"
	mv "$PVTEST_DEV_HOOK_CTRL/req/.tmp.$_id" "$PVTEST_DEV_HOOK_CTRL/req/$_id"

	_resp="$PVTEST_DEV_HOOK_CTRL/resp/$_id"
	while [ ! -f "$_resp" ]; do
		sleep 1
		_waited=$((_waited + 1))
		if [ "$_waited" -gt 300 ]; then
			pvtest_log ERROR "device retype: host did not respond"
			return 1
		fi
	done
	_status=$(sed -n 's/^status=//p' "$_resp")
	rm -f "$_resp"

	case "$_status" in
		ok) ;;
		nohook)
			pvtest_log ERROR "device retype: no hook configured (should have been caught by the SKIP gate)"
			return 1
			;;
		*)
			pvtest_log ERROR "device retype: hook failed (status=$_status; see host-side log)"
			return 1
			;;
	esac

	# the hook already power-cycled the board; the "down" window may already
	# be over by the time we start polling — best-effort fence, not a hard gate
	pvtest_log INFO "device retype: waiting for device to go down..."
	wait_for_down 30 || pvtest_log WARN "device did not confirm down within 30s; continuing"

	wait_for_target_ready "device retype" "$_rev" DONE || return 1

	pvcontrol conf ls > "$(_ae_conf_file "$PVTEST_AE")" 2>/dev/null || true
	return 0
}

_install_initial_rev() {
	local rev="$1"

	pvtest_log INFO "installing initial revision for $test_id..."

	local factory_dir
	factory_dir="$(_ae_factory_dir "$PVTEST_AE")"

	# every test builds on the pristine factory clone captured by init_device;
	# without it the revision cannot replace the previous test's state
	if [ ! -d "$factory_dir" ]; then
		pvtest_log ERROR "no factory clone for '$PVTEST_AE'"
		return 1
	fi

	# drain leftover activity from the previous test (or, for the first test
	# after an attach, from init_device's factory clone/export) before
	# installing this test's own revision
	pvtest_log INFO "waiting for device to settle from previous test [via SSH]..."
	wait_for_current_settled \
		|| pvtest_log WARN "device did not fully settle before initial revision; continuing"

	# Prefer pvtx — a single fast on-device transaction (matters on low-spec
	# targets like M2); fall back to a tester-side pvr HTTP-post when the device
	# rootfs lacks the pvtx binary; abort if neither path is available.
	if _have_pvtx; then
		pvtest_log DEBUG "installing initial revision with pvtx"
		_install_initial_pvtx "$rev" || return 1
	elif command -v pvr > /dev/null 2>&1; then
		pvtest_log INFO "pvtx not available on device; falling back to pvr HTTP-post"
		_install_initial_pvr "$factory_dir" "$rev" || return 1
	else
		pvtest_log ERROR "cannot install initial revision: neither pvtx (on the device) nor pvr (on the tester) is available"
		return 1
	fi

	wait_for_target_ready "initial revision" "$rev" "DONE|UPDATED" || return 1

	# single merged power cycle: a config change re-types the container (the new
	# generation boots straight into the pending revision, committing it);
	# otherwise a still-pending (UPDATED) revision is committed with a plain
	# reboot, so a later test that deliberately triggers a rollback lands on
	# this test's own named revision, not whatever was current before it
	local _st _grc=0
	_st=$(pvcontrol steps show-progress "$rev" 2>/dev/null | jq -r '.status' 2>/dev/null)
	if [ -n "$PVTEST_CTRL" ] && [ -n "$PVTEST_SLOT" ]; then
		# persistent pool: _reqcfg_gate powers off before returning 3
		_reqcfg_gate "$required_env"; _grc=$?
	elif [ -n "$PVTEST_DEV_HOOK_CTRL" ]; then
		# real device with a manifest hook=: check mismatch, signal retype via a
		# distinct sentinel (4) rather than reusing _reqcfg_gate's 3 — do NOT
		# pre-poweroff like the pool does, the hook's own power-cycle assumes
		# the board's current live state.
		pvcontrol conf ls > "$(_ae_conf_file "$PVTEST_AE")" 2>/dev/null || true
		if ! _reqcfg_satisfied "$required_env" "$(_ae_conf_file "$PVTEST_AE")"; then
			_grc=4
		fi
	else
		# no re-type mechanism (real device without an env hook; volatile is
		# booted with its own config): a mismatch that slipped past the
		# required-config SKIP gate aborts the test
		pvcontrol conf ls > "$(_ae_conf_file "$PVTEST_AE")" 2>/dev/null || true
		if ! _reqcfg_satisfied "$required_env" "$(_ae_conf_file "$PVTEST_AE")"; then
			pvtest_log ERROR "required config not satisfied and no re-type mechanism: $required_env"
			return 1
		fi
	fi
	if [ "$_grc" = 3 ]; then
		_setup_retype "$rev" || return 1
	elif [ "$_grc" = 4 ]; then
		_setup_device_retype "$rev" || return 1
	elif [ "$_st" = "UPDATED" ] && [ "$commit_initial" = "false" ]; then
		pvtest_log DEBUG "initial revision left UPDATED (commit-initial=false)"
	elif [ "$_st" = "UPDATED" ]; then
		pvtest_log INFO "initial revision needs a reboot to commit; rebooting..."
		pv_ctrl cmd reboot "pvtest: committing initial revision for $test_id" || return 1
		wait_for_down 30 || pvtest_log WARN "device did not confirm down after reboot; continuing"
		wait_for_target_ready "commit reboot" "$rev" DONE || return 1
	fi
	return 0
}

setup_test() {
	# deterministic name so golden outputs see a stable "locals/<id>", not a random pvtx name
	local rev
	rev="locals/$(printf '%s' "$test_id" | tr '/' '_' | tr '-' '_')"

	# volatile factory revision should be already the test initial revision
	if [ "$PVTEST_MODEL" = "volatile" ]; then
		local _cur
		_cur=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantavisor.revision"]' 2>/dev/null | tr -d '\r')
		if [ "$_cur" != "$rev" ]; then
			pvtest_log ERROR "expected to boot into initial revision $rev, found '${_cur:-<none>}'"
			return 1
		fi
		pvtest_log INFO "booted into initial revision $rev for $test_id"

		# conf snapshot was taken by init_device on this same boot
		if ! _reqcfg_satisfied "$required_env" "$(_ae_conf_file "$PVTEST_AE")"; then
			pvtest_log ERROR "required config not satisfied: $required_env"
			return 1
		fi
	else
		_install_initial_rev "$rev" || return 1
	fi

	_dev_gc || true

	# strip a leftover claim before go-remote brings the Hub client up (see
	# handle_pre_remote_unclaim)
	handle_pre_remote_unclaim || return 1

	# best-effort: every initial revision is locals/<id>, which forces
	# remote_mode=false on RUN entry unless PV_CONTROL_REMOTE_ALWAYS=1 — rather
	# than setting ALWAYS=1 on every remote test's config, go remote once here.
	# Skipped when the config guarantees a rejection: remote disabled, or
	# already remote via ALWAYS=1. Test scripts that themselves reboot onto
	# another locals/ revision still need their own go-remote afterward (this
	# one only covers the state setup_test hands off).
	local _cf
	_cf="$(_ae_conf_file "$PVTEST_AE")"
	if [ "$(_conf_value PV_CONTROL_REMOTE "$_cf")" = "0" ]; then
		pvtest_log DEBUG "remote disabled by config; skipping go-remote"
	elif [ "$(_conf_value PV_CONTROL_REMOTE_ALWAYS "$_cf")" = "1" ]; then
		pvtest_log DEBUG "remote mode forced by config; skipping go-remote"
	else
		pv_ctrl cmd go-remote || true
	fi

	# claim state last, once the Hub client is up (go-remote above) and the
	# committed DONE revision allows the unclaimed register/claim walk
	handle_self_claim || return 1

	# revision is DONE and the device is in its final claim state, so both the
	# local and the Hub-side usrmeta stick for the test body
	apply_usrmeta

	pvtest_log INFO "done — installed initial revision $rev for $test_id"
}

teardown_test() {

	# remove usrmeta applied for this test, locally and on the Hub, so the next test starts clean
	if [ -n "$applied_usrmeta_keys" ]; then
		local device_id=""
		if [ "$self_claim" = "true" ] && [ -n "$PH_USER" ] && [ -n "$PH_PASS" ]; then
			device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
		fi
		local k
		for k in $applied_usrmeta_keys; do
			pvtest_log INFO "usrmeta delete $k"
			pv_ctrl -q usrmeta delete "$k"
			[ -n "$device_id" ] && _hub_usrmeta_delete "$device_id" "$k"
		done
		applied_usrmeta_keys=
	fi

	# volatile model only: the container is torn down right after this one test,
	# so its claim dies with it here; in persistent the claim persists across
	# adjacent tests and is settled at worker detach (persistent_worker)
	if [ "$PVTEST_MODEL" = "volatile" ] && [ -n "$claimed_device" ]; then
		pvtest_log INFO "deleting self-claimed device $claimed_device and unclaiming"
		_dev_unclaim "$claimed_device"
		claimed_device=
	fi
}

exec_test() {
	pvtest_log INFO "executing test script for $test_id..."
	if [ ! -f "$test_dir/$test_script" ]; then
		pvtest_log ERROR "'$test_dir/$test_script' does not exist"
		return 1
	fi

	# test script runs in the tester; pre-authenticate its isolated pvr HOME so it never has to call `pvr login`
	local pvrhome=""
	if [ -n "$PH_USER" ] && [ -n "$PH_PASS" ]; then
		pvrhome="$(_ae_pvr_home)"
		mkdir -p "$pvrhome" 2>/dev/null
		HOME="$pvrhome" PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" \
			pvr login > /dev/null 2>&1 \
			|| pvtest_log WARN "pvr login failed for test script"
	fi

	tmp_script_path=$(mktemp /tmp/pv_appengine_script.XXXXXX)
	{
		[ -n "$pvrhome" ] && printf 'export HOME=%s\n' "$pvrhome"
		# source utils so pvcurl/pvcontrol/pventer route via PVTEST_EXEC in this subprocess
		echo ". @CMAKE_INSTALL_FULL_DATADIR@/@PROJECT_NAME@/pvtest/utils"
		cat "$test_dir/$test_script"
	} > "$tmp_script_path"
	chmod +x "$tmp_script_path"

	tmp_out_path=$(mktemp /tmp/pv_appengine_output.XXXXXX)
	tmp_err_path=$(mktemp /tmp/pv_appengine_stderr.XXXXXX)
	mkdir -p "$run_dir/$test_id"
	# pty capture, tee'd to tmp_out_path (diff) and test.log; live passthrough to
	# the run console only in verbose mode — on failure the diff is printed anyway.
	# timeout caps a wedged script; partial output just fails the diff.
	# only stdout is compared against the golden output: device-side tool stderr
	# (e.g. a BSP pvcontrol warning, or a test's own "ERROR: ..." message) must not
	# pollute the diff, so it's kept off the pty entirely — captured to tmp_err_path
	# instead. eval_test appends it to the diff output when the test FAILED (so the
	# failure reason sits right next to the diff, not scattered elsewhere in the
	# log); it's also appended to test.log below either way for full context.
	local _live=/dev/null
	[ "$verbose" = "true" ] && _live=/dev/stdout
	timeout -k 10 --foreground "${PVTEST_TEST_TIMEOUT:-600}" \
		script -q -c "bash -c \"$tmp_script_path\" 2> \"$tmp_err_path\"" \
		| tee "$tmp_out_path" \
		| tee -a "$run_dir/$test_id/test.log" > "$_live"
	local _script_rc=${PIPESTATUS[0]}
	[ -s "$tmp_err_path" ] && cat "$tmp_err_path" >> "$run_dir/$test_id/test.log"
	if [ "$_script_rc" = 124 ] || [ "$_script_rc" = 137 ]; then
		pvtest_log ERROR "test script for $test_id timed out after ${PVTEST_TEST_TIMEOUT:-600}s (killed)"
	fi
	pvtest_log INFO "test script complete"

	if [ "$overwrite" = "true" ]; then
		pvtest_log INFO "overwriting expected output"
		cat "$tmp_out_path" > "$test_dir/output"
	fi
	rm -f "$tmp_script_path"
}

eval_test() {
	if [ "$overwrite" = "true" ]; then
		rm -f "$tmp_err_path"
		return 0
	fi

	local diff_out
	diff_out=$(diff "$test_dir/output" "$tmp_out_path")
	local rc=$?
	if [ $rc -ne 0 ]; then
		# pass/fail is decided above on stdout alone (unaffected by this); for
		# DISPLAY only, diff against stdout+stderr concatenated so a captured
		# "ERROR: ..." shows up as a real unified-diff addition in the one
		# block, in the position it actually happened (these test scripts always
		# print it right as they exit, so appending is chronologically correct)
		# — instead of a second, disconnected section glued on afterward.
		local _display_path="$tmp_out_path"
		if [ -s "$tmp_err_path" ]; then
			_display_path=$(mktemp /tmp/pv_appengine_combined.XXXXXX)
			cat "$tmp_out_path" "$tmp_err_path" > "$_display_path"
			diff_out=$(diff "$test_dir/output" "$_display_path")
		fi
		echo "--- diff: $test_id ---"
		echo "$diff_out"
		echo "--- end diff ---"
		if [ -n "$run_dir" ]; then
			mkdir -p "$run_dir/$test_id"
			echo "$diff_out" > "$run_dir/$test_id/diff"
		fi
		[ "$_display_path" != "$tmp_out_path" ] && rm -f "$_display_path"
	fi
	rm -f "$tmp_out_path" "$tmp_err_path"
	return $rc
}

# runs one test attempt; returns 0 pass / 1 fail-abort / 2 skip (no retry)
run_test_attempt() {
	local json_path="$1"
	test_dir=$(dirname "$json_path")
	test_id=$(echo "$json_path" | sed 's|^/work/||; s|/test\.json$||')

	# logs are keyed by full container/device name so per-policy runners sharing a
	# trailing index never collide. APPENGINE_LOGS is a single mounted directory
	# (host's $work_path) containing every <name>.log; construct the path
	# directly rather than scanning a list.
	local ae_log="" ae_log_start=0
	if [ -n "$PVTEST_AE" ] && [ -n "$APPENGINE_LOGS" ]; then
		ae_log="$APPENGINE_LOGS/${PVTEST_AE}.log"
		[ -f "$ae_log" ] && ae_log_start=$(wc -l < "$ae_log")
	fi

	if ! parse_test; then
		echo "=== TEST: $test_id ERROR (parse failed) ==="
		return 1
	fi

	local _skip
	_skip=$(jq -r '.skip' "$json_path")
	if [ "$_skip" = "true" ]; then
		if [ "$FAIL_ON_SKIP_FIELD" = "true" ]; then
			pvtest_log ERROR "'$test_id' has skip:true but FAIL_ON_SKIP_FIELD is set (skip is not allowed on master)"
			return 1
		fi
		pvtest_log INFO "'$test_id' SKIPPED"
		return 2
	fi

	if [ -n "$PVTEST_DEVICE" ]; then
		local _devs
		_devs=$(jq -r 'if (.devices // []) == [] then "" else (.devices | join(" ")) end' "$json_path")
		if [ -n "$_devs" ]; then
			case " $_devs " in
				*" $PVTEST_DEVICE "*) ;;
				*)
					pvtest_log INFO "'$test_id' SKIPPED (device=$PVTEST_DEVICE not in: $_devs)"
					return 2
					;;
			esac
		fi
	fi

	# real device (persistent model, --devices) with no manifest hook=: SKIP
	# tests whose config.env the live device doesn't already satisfy — without
	# a hook there's no way to inject boot-time config on hardware. When a hook
	# IS configured (PVTEST_DEV_HOOK_CTRL set), skip this pre-emptive check
	# entirely and let setup_test's _setup_device_retype attempt the retype
	# instead; a retype failure there already aborts the test on its own.
	# Never gates the pool, which boots the config itself.
	if [ "$PVTEST_MODEL" = "persistent" ] && [ -n "$PVTEST_DEVICE_TARGET" ] && [ -n "$required_env" ] && [ -z "$PVTEST_DEV_HOOK_CTRL" ]; then
		if ! _reqcfg_satisfied "$required_env" "$(_ae_conf_file "$PVTEST_AE")"; then
			pvtest_log INFO "'$test_id' SKIPPED (required-config not satisfied by device: $required_env, no hook configured)"
			return 2
		fi
	fi

	if [ "$self_claim" = "true" ] && { [ -z "$PH_USER" ] || [ -z "$PH_PASS" ]; }; then
		pvtest_log ERROR "PH_USER/PH_PASS not set but required by self-claim test(s)"
		pvtest_log INFO "'$test_id' SKIPPED (PH_USER/PH_PASS not set)"
		return 2
	fi

	# per-test log captures setup -> script -> teardown + device log (tailed below).
	# PVTEST_ACTIVE_TESTLOG is a local (not exported) so the test script child doesn't re-mirror it.
	mkdir -p "$run_dir/$test_id"
	local PVTEST_ACTIVE_TESTLOG="$run_dir/$test_id/test.log"

	# follow the device's pantavisor log into test.log for the whole test window (setup through teardown)
	local ae_tail_pid=""
	if [ -n "$ae_log" ] && [ -f "$ae_log" ]; then
		tail -n "+$((ae_log_start + 1))" -f "$ae_log" >> "$PVTEST_ACTIVE_TESTLOG" 2>/dev/null &
		ae_tail_pid=$!
	fi

	pvtest_log INFO "'$test_id' START"
	local _test_start
	_test_start=$(date +%s)

	# emit after teardown so (N s) spans setup -> teardown; teardown_test always runs
	local _outcome test_result=0
	if ! setup_test; then
		_outcome=ABORTED
	elif ! exec_test; then
		_outcome=ABORTED
	else
		eval_test
		test_result=$?
		if [ "$overwrite" = "true" ]; then
			_outcome=RECORDED
		elif [ $test_result -eq 0 ]; then
			_outcome=PASSED
		else
			_outcome=FAILED
		fi
	fi

	teardown_test
	local _test_runtime=$(( $(date +%s) - _test_start ))
	[ -n "$ae_tail_pid" ] && { kill "$ae_tail_pid" 2>/dev/null; wait "$ae_tail_pid" 2>/dev/null || true; }

	case "$_outcome" in
	RECORDED) pvtest_log INFO  "'$test_id' RECORDED ($_test_runtime s)"; return 0 ;;
	PASSED)   pvtest_log INFO  "'$test_id' PASSED ($_test_runtime s)";   return 0 ;;
	ABORTED)  pvtest_log ERROR "'$test_id' ABORTED ($_test_runtime s)";  return 1 ;;
	*)        pvtest_log ERROR "'$test_id' FAILED ($_test_runtime s)";   return 1 ;;
	esac
}

# Slot-pool dispatcher: PVTEST_SLOTS workers pull from a flat queue; host re-types
# each slot's container over PVTEST_CTRL. Tests are grouped into runner-types
# (config + claim-need); a worker has affinity to its type and claims a device
# once per attach, releasing it on switch.

# bind PVTEST_EXEC/HOST/AE to container $1; clear stale values first in container mode
# (PVTEST_SSH_KEY set) so accessors rebuild for $1 instead of short-circuiting on the prior one
_slot_bind_ae() {
	if [ -n "$PVTEST_SSH_KEY" ]; then PVTEST_EXEC=""; PVTEST_HOST=""; fi
	export PVTEST_EXEC="$(_ae_exec_cmd "$1")"
	export PVTEST_HOST="$(_ae_host "$1")"
	export PVTEST_AE="$1"
}

# ask the host to re-type slot $1 to required-config $2 (empty = tear down); echoes new container name.
# optional $3 = storage key: the host keeps /storage under that key across re-types
# (old hosts ignore the field and boot fresh storage — forward-compatible).
# silent on error (caller logs the abort) so it never pollutes the captured name.
_retype_slot() {
	local _slot="$1" _cfg="$2" _storage="$3" _req _resp _waited _status _ae
	_req="$PVTEST_CTRL/req/slot${_slot}"
	_resp="$PVTEST_CTRL/resp/slot${_slot}"
	rm -f "$_resp"
	{
		printf 'slot=%s\ncfg=%s\n' "$_slot" "$_cfg"
		if [ -n "$_storage" ]; then
			printf 'storage=%s\n' "$_storage"
		fi
	} > "$PVTEST_CTRL/req/.tmp.slot${_slot}"
	mv "$PVTEST_CTRL/req/.tmp.slot${_slot}" "$_req"
	_waited=0
	while [ ! -f "$_resp" ]; do
		sleep 1
		_waited=$((_waited + 1))
		[ "$_waited" -gt 300 ] && return 1
	done
	_status=$(sed -n 's/^status=//p' "$_resp")
	_ae=$(sed -n 's/^ae=//p' "$_resp")
	rm -f "$_resp"
	case "$_status" in
		ready) printf '%s' "$_ae"; return 0 ;;
		down)  return 0 ;;
		*)     return 1 ;;
	esac
}

# Emit an ABORTED result line for each test path in "$@" (after $1=reason), so a
# failed attach still produces a SUMMARY record for every test it stranded.
_slot_abort_tests() {
	local _reason="$1" _j _tid
	shift
	for _j in "$@"; do
		_tid=$(echo "$_j" | sed 's|^/work/||; s|/test\.json$||')
		pvtest_log ERROR "'${_tid}' ABORTED (${_reason})"
	done
}

# Single real-device runner (the deliberately-downgraded device path): unlike the
# appengine slot pool, a real device can't be re-booted with new config, so there
# is no pool/re-type/claim-batching — the one device binds once, inits once, then
# every queued test runs against it sequentially via run_test_attempt (which
# applies the skip / devices-filter / required-config matcher and per-test console
# interleaving). setup_test installs and commits each test's own initial
# revision, so no per-test reset happens here. PVTEST_EXEC/PVTEST_HOST are
# already set by test.docker.sh from the manifest; init_device reuses them
# (the appengine accessors pass a pre-set value through). Also doubles as the
# volatile model's one-test-per-container path (PVTEST_MODEL=volatile): a fresh
# container per test makes any factory-reset here (leading or trailing) pure
# waste, since the container is torn down right after — skipped in that case,
# as is the initial-revision install itself (the container boots into it).
run_single_device() {
	local _name="$1"
	local _json _rc _overall=0

	# real devices are slower (real reboots, ssh round-trips per poll)
	export PVTEST_TEST_TIMEOUT="${PVTEST_TEST_TIMEOUT:-1800}"

	export PVTEST_AE="$_name"
	if ! init_device "$_name"; then
		pvtest_log ERROR "init failed"
		return 1
	fi
	pvtest_log INFO "SLOT_ATTACH"

	local _n
	_n=$(printf '%s\n' $test_json_list | grep -c .)
	pvtest_log INFO "=== single device: ${_n} test(s) against $_name ==="

	for _json in $test_json_list; do
		run_test_attempt "$_json"; _rc=$?
		{ [ "$_rc" -ne 0 ] && [ "$_rc" -ne 2 ]; } && _overall=1
	done

	# good manners: leave a real device back on a clean factory state once
	# testing is done. Pointless for volatile model's throwaway container, torn
	# down by the caller right after this returns.
	if [ "$PVTEST_MODEL" != "volatile" ]; then
		_settle_to_factory || pvtest_log WARN "final factory reset failed"
	fi

	pvtest_log INFO "SLOT_DETACH"

	[ "$PVTEST_MODEL" = "volatile" ] && \
		pv_ctrl cmd poweroff "pvtest: volatile test done" > /dev/null 2>&1 || true

	return $_overall
}


# persistent-model dispatcher: one flat queue sorted so claim-needing tests come first
# (one claim per worker held across adjacent tests) and equal-config tests sit
# together (fewest re-types); correctness never depends on the ordering.

# pop the next "<rank>\t<cfg>\t<jsonpath>" line from the persistent queue; empty when drained
_persistent_pick() {
	local _pool="$1"
	(
		flock -x 9
		[ -s "$_pool/queue" ] || exit 0
		head -n1 "$_pool/queue"
		tail -n +2 "$_pool/queue" > "$_pool/queue.tmp" && mv "$_pool/queue.tmp" "$_pool/queue"
	) 9>"$_pool/lock"
}

# One persistent-model worker: every test runs under exactly its config.env. The worker
# keeps ONE storage for the whole run (storage key w<slot>) and power-cycles at
# most once between tests: setup_test merges a needed config change into the
# initial revision's commit reboot, re-typing this worker's slot itself.
persistent_worker() {
	local _slot="$1" _pool="$2" _failed="$3"
	local _ae="" _line _newcfg _json _rc _state

	# setup_test's mid-setup re-type targets this worker's own slot
	export PVTEST_SLOT="$_slot"

	while : ; do
		_line=$(_persistent_pick "$_pool")
		[ -n "$_line" ] || break
		_newcfg=$(printf '%s' "$_line" | cut -f2)
		_json=$(printf '%s' "$_line" | cut -f3)

		# first pick (or recovery after a failed mid-setup re-type): boot the
		# worker's container with this test's config
		if [ -z "$_ae" ]; then
			_ae=$(_retype_slot "$_slot" "$_newcfg" "w${_slot}")
			if [ -z "$_ae" ]; then
				_slot_abort_tests "re-type failed" "$_json"; touch "$_failed"; continue
			fi
			_slot_bind_ae "$_ae"
			if ! init_device "$_ae"; then
				pvtest_log ERROR "init failed"
				_slot_abort_tests "device init failed" "$_json"; touch "$_failed"
				_ae=""; continue
			fi
			pvtest_log INFO "[slot $_slot] SLOT_ATTACH ae=$_ae storage=w${_slot} cfg=[$_newcfg]"
		fi

		_slot_bind_ae "$_ae"
		# config changes and claim state are settled inside setup_test (merged
		# power cycle + end-of-setup handle_self_claim), which may re-type this
		# slot's container — re-read the current name after the attempt
		run_test_attempt "$_json"; _rc=$?
		_ae="$PVTEST_AE"
		{ [ "$_rc" -ne 0 ] && [ "$_rc" -ne 2 ]; } && touch "$_failed"
	done

	# Final detach: remove the device from the Hub (unclaim when it can walk
	# back to claimable; plain Hub delete for a claimed device left in local
	# mode), power off, release the container.
	if [ -n "$_ae" ]; then
		_slot_bind_ae "$_ae"
		_state=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantahub.state"] // empty')
		if [ "$_state" = "idle" ]; then
			_dev_unclaim
		else
			_dev_delete_only
		fi
		pvtest_log INFO "[slot $_slot] SLOT_DETACH ae=$_ae"
		pv_ctrl cmd poweroff "pvtest: worker done" > /dev/null 2>&1 || true
		_retype_slot "$_slot" "" > /dev/null 2>&1 || true
	fi
}

# persistent-model scheduler: flat sorted queue, no runner-type machinery
run_persistent_pool() {
	local _slots="${PVTEST_SLOTS:-1}"
	local _pool _failed _j _req _sc _rank _pids _w
	_pool=$(mktemp -d /tmp/pvtest_persistentpool.XXXXXX)

	# rank 0 = needs a claim (REMOTE=1 + self-claim), 1 = rest; sort by rank,
	# then config, then path — claim block first, equal configs adjacent
	for _j in $test_json_list; do
		_req=$(_reqcfg_norm "$(jq -r '.setup.config.env // ""' "$_j")")
		_sc=$(jq -r '.setup."self-claim" // "false"' "$_j")
		_rank=1
		case " $_req " in
			*" PV_CONTROL_REMOTE=1 "*) [ "$_sc" = "true" ] && _rank=0 ;;
		esac
		printf '%s\t%s\t%s\n' "$_rank" "$_req" "$_j"
	done | sort -t "$(printf '\t')" -k1,1 -k2,2 -k3,3 > "$_pool/queue"

	pvtest_log INFO "=== persistent pool: $(wc -l < "$_pool/queue") test(s) across up to ${_slots} worker(s) ==="

	_failed=$(mktemp); rm -f "$_failed"

	_pids=""; _w=0
	while [ "$_w" -lt "$_slots" ]; do
		persistent_worker "$_w" "$_pool" "$_failed" &
		_pids="${_pids:+$_pids }$!"
		_w=$((_w + 1))
	done
	[ -n "$_pids" ] && wait $_pids

	rm -rf "$_pool"
	if [ -f "$_failed" ]; then rm -f "$_failed"; return 1; fi
	return 0
}


# Pre-parse -v/--verbose flag; remaining args stay positional for compatibility
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
	VERBOSE=true
	shift
fi

# env-first: the tester image entrypoint expands unset envs into SHIFTED
# positionals (unquoted "$TEST_PATH $INTERACTIVE ..."), so the envs — set
# explicitly by every host invocation — are the reliable source; positionals
# are a fallback for hand-run testers only
test_selector=${TEST_PATH:-$1}
interactive=${INTERACTIVE:-$2}
manual=${MANUAL:-$3}
overwrite=${OVERWRITE:-$4}
verbose=${VERBOSE:-$5}
netsim=${NETSIM:-$6}
valgrind=${VALGRIND:-$7}
# /work/run is mounted from work_path/results on the host for per-test result files
run_dir=${RUN_DIR:-/work/run}
# assignment model: persistent = force each test's config.env (also the
# real-device SKIP gate — see run_single_device), volatile = one container per
# test (runs through run_single_device with PVTEST_DEVICE_TARGET set). Unset
# means persistent; the host owns the default.
PVTEST_MODEL="${PVTEST_MODEL:-persistent}"
# APPENGINE_LOGS (if set): mounted host dir containing <name>.log files,
# read directly by run_test_attempt() via $APPENGINE_LOGS/<name>.log

if [ -z "$interactive" ] || [ -z "$manual" ] || [ -z "$overwrite" ] || [ -z "$verbose" ] || [ -z "$netsim" ]; then
	pvtest_log ERROR "missing arguments / envs"
	usage
	exit 1
fi
if [ "$verbose" = "true" ]; then set -x; fi

description=
required_env=
usrmeta=
tarballs=
commit_initial=
self_claim=
claimed_device=
applied_usrmeta_keys=
test_script=
test_dir=
test_id=
tmp_out_path=
tmp_err_path=

# human-readable scope label: drop /work/ prefix and trailing slash; empty = whole suite
_run_scope=${test_selector#/work/}
_run_scope=${_run_scope%/}
pvtest_log INFO "starting test run: ${_run_scope:-all}"
initial_setup

# single real-device mode: flat queue (PVTEST_QUEUE) run sequentially against the
# one device named in PVTEST_DEVICE_TARGET (PVTEST_EXEC/PVTEST_HOST reach it)
if [ -n "$PVTEST_QUEUE" ] && [ -n "$PVTEST_DEVICE_TARGET" ]; then
	test_json_list="$PVTEST_QUEUE"
	run_single_device "$PVTEST_DEVICE_TARGET"
	exit $?
fi

# slot-pool mode: flat queue (PVTEST_QUEUE) dispatched across PVTEST_SLOTS slots
if [ -n "$PVTEST_QUEUE" ] && [ -n "$PVTEST_CTRL" ]; then
	test_json_list="$PVTEST_QUEUE"
	case "$PVTEST_MODEL" in
		persistent) run_persistent_pool ;;
		*)
			pvtest_log ERROR "unknown PVTEST_MODEL '$PVTEST_MODEL'"
			exit 1
			;;
	esac
	exit $?
fi

# interactive/manual single-device mode: host boots one appengine via PVTEST_APPENGINES
if [ -n "$PVTEST_APPENGINES" ]; then
	if [ "$manual" != "true" ] && [ "$interactive" != "true" ]; then
		pvtest_log ERROR "PVTEST_APPENGINES is only supported in interactive/manual mode"
		exit 1
	fi
	first_ae=$(printf '%s' "$PVTEST_APPENGINES" | awk '{print $1}')
	export PVTEST_EXEC="$(_ae_exec_cmd "$first_ae")"
	export PVTEST_HOST="$(_ae_host "$first_ae")"
	if [ "$interactive" = "true" ]; then
		exec_interactive
		# Tester console exited; shutdown all appengines now.
		for ae in $(printf '%s\n' "$PVTEST_APPENGINES"); do
			(
				export PVTEST_EXEC="$(_ae_exec_cmd "$ae")"
				export PVTEST_HOST="$(_ae_host "$ae")"
				export PVTEST_AE="$ae"
				pvtest_log DEBUG "requesting pantavisor shutdown"
				pv_ctrl cmd poweroff "pvtest: console exit"
			) &
		done
		wait
		exit 0
	fi
	sleep 100000
	exit 0
fi

pvtest_log ERROR "no dispatch mode configured (need PVTEST_QUEUE with PVTEST_DEVICE_TARGET or PVTEST_CTRL, or PVTEST_APPENGINES)"
usage
exit 1
