#!/bin/sh

PVTEST_LOG_SOURCE=pvtest-run
source @CMAKE_INSTALL_FULL_DATADIR@/@PROJECT_NAME@/pvtest/utils

usage() {
	echo ""
	echo "Usage: $0 <test-selector> <interactive> <manual> <overwrite> <verbose> <netsim>"
	echo ""
	echo "  test-selector  path to a test dir or a parent dir containing multiple tests"
	echo "                 (relative to /work/ or absolute)"
	echo ""
	echo "Pool mode (N appengines): set PVTEST_APPENGINES to a space-separated list of"
	echo "appengine container names. Each appengine is used as a device slot. Tests are"
	echo "dispatched to free slots in parallel."
	echo ""
}

parse_test() {
	local j="$test_dir/test.json"
	if [ ! -e "$j" ]; then
		pvtest_log ERROR "'$j' not found"
		return 1
	fi

	description=$(jq -r '.description' "$j")
	# Persistent-device model: setup.required-config is the config a device must
	# already have for this test to run on it (matched against `conf ls`), not
	# env to inject. setup.usrmeta is per-test runtime metadata applied via
	# `pvcontrol usrmeta` after the initial revision is ready and removed in
	# teardown. Deprecated keys (cmdline, pantavisor.config, pvs, ready-script)
	# are no longer read.
	required_env=$(jq -r '.setup."required-config" // ""' "$j")
	usrmeta=$(jq -r '.setup.usrmeta // ""' "$j")
	control_container=$(jq -r '.setup.containers.control' "$j")
	tarballs=$(jq -r '.setup.containers.tarballs[]' "$j")
	self_claim=$(jq -r '.setup."self-claim"' "$j")
	test_script=$(jq -r '."test-script"' "$j")
	return 0
}

# Run-scoped record of devices this harness has self-claimed but not yet deleted.
# Cleared per-device on teardown; any survivors (a test killed mid-run) are swept
# on exit. Scoped to this run only — we never touch devices we did not claim, so
# it is safe on a shared Pantahub account.
PVTEST_CLAIMED_DEVICES_FILE="/tmp/pvtest_claimed_devices.$$"
: > "$PVTEST_CLAIMED_DEVICES_FILE" 2>/dev/null || true

cleanup() {
	_sweep_tracked_devices
	kill $(jobs -p) 2>/dev/null
}
trap cleanup EXIT

initial_setup() {
	if [ "$netsim" = "true" ]; then
		wait_for_status "ip link set wlan1 name wlan0" 0 5 > /dev/null 2>&1
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "could not setup wlan0 interface for tester"
			exit 1
		fi
	fi
}

exec_interactive() {
	echo ""
	echo "Welcome to pvtest tester!"
	echo ""

	if [ "$manual" = "true" ]; then
		echo "No pantavisor target is configured (manual mode)."
		echo "Connect to a device manually and set PVTEST_EXEC before running your test."
	else
		echo "Pantavisor is starting in the appengine container (no state deployed yet)."
		echo "Run pvtest-run to wait for device ready, deploy test state, and execute tests."
	fi
	echo ""

	# Clear INTERACTIVE so pvtest-run invoked from this shell runs tests, not another shell
	export INTERACTIVE=false
	# Signal pool mode to skip auto-shutdown — we send it on console exit instead.
	export PVTEST_CONSOLE=1
	local _rc
	_rc=$(mktemp /tmp/pvtest_rc.XXXXXX)
	printf '. @CMAKE_INSTALL_FULL_DATADIR@/@PROJECT_NAME@/pvtest/utils\n' > "$_rc"
	bash --rcfile "$_rc" -i
	rm -f "$_rc"
}

# Build the SSH exec command for a given appengine name.
# For container appengines (PVTEST_SSH_KEY set): derive from container name.
# For external target (PVTEST_EXEC set): use it directly.
# Falls back to empty (direct local execution).
_ae_exec_cmd() {
	local ae="$1"
	if [ -n "$PVTEST_EXEC" ]; then
		printf '%s' "$PVTEST_EXEC"
	elif [ -n "$PVTEST_SSH_KEY" ]; then
		# ConnectTimeout/ServerAlive/BatchMode bound each attempt to a few seconds so
		# that while the device is rebooting (crash tests) a poll fails fast instead
		# of hanging on a dead TCP connect — keeping wait_for_value's 1s cadence real.
		printf 'ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o BatchMode=yes -o ConnectTimeout=5 -o ServerAliveInterval=3 -o ServerAliveCountMax=2 -i %s -p 8222 _pv_@%s' \
			"$PVTEST_SSH_KEY" "$ae"
	else
		printf ''
	fi
}

# Resolve the pvr HTTP host for a given appengine name.
_ae_host() {
	local ae="$1"
	if [ -n "$PVTEST_HOST" ]; then
		printf '%s' "$PVTEST_HOST"
	else
		printf '%s' "$ae"
	fi
}

# Path to the stored `conf ls` JSON for a given appengine name (captured in
# init_device). Used by the config matcher to decide test/device assignment.
_ae_conf_file() {
	local ae="$1" ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')
	printf '/tmp/pvtest_device_conf_%s.json' "$ae_safe"
}

# Path to the per-device pristine factory pvr clone captured in init_device.
# Each test's setup starts from a clean copy of this so the device trail never
# accumulates revisions across tests on the pool.
_ae_factory_dir() {
	local ae="$1" ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')
	printf '/tmp/pvtest_factory_%s' "$ae_safe"
}

# Per-device isolated pvr auth/cache home. Pool slots run pvr concurrently in the
# same tester container; without this they race on the shared ~/.pvr config during
# login/claim/delete. Keyed by the appengine name (falls back to a shared default
# in legacy single-device mode where PVTEST_AE is unset).
_ae_pvr_home() {
	local ae="${1:-$PVTEST_AE}" ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')
	printf '/tmp/pvtest_pvrhome_%s' "${ae_safe:-default}"
}

# Claim role ("yes"/"no") for appengine $1, parsed from PVTEST_AE_CLAIM
# ("ae1=yes ae2=no ..."), the per-runner claim role the host (test.docker.sh)
# assigns from each runner-type's needs-claim. Defaults to "no" (never claim).
_ae_claim_role() {
	local ae="$1" kv
	for kv in $PVTEST_AE_CLAIM; do
		case "$kv" in
			"${ae}="*) printf '%s' "${kv#*=}"; return ;;
		esac
	done
	printf 'no'
}

# Normalize a required-config string to a stable runner-type signature: drop empty
# tokens and any PV_LXC_LOG_LEVEL marker (legacy discriminator), sort the KEY=VALUE
# tokens. Mirrors normalize_reqcfg in test.docker.sh.
_reqcfg_norm() {
	printf '%s\n' $1 | grep -v '^$' | grep -v '^PV_LXC_LOG_LEVEL=' | sort | tr '\n' ' ' | sed 's/ *$//'
}

# Run a pvr command authenticated against the Hub in this device's isolated HOME,
# logging in first when PH creds are set. All self-claim Hub operations (login,
# claim, dev delete) must go through here so concurrent pool slots never share a
# ~/.pvr config.
_pvr_auth() {
	# Hub operations require authentication. Without PH creds — or if login fails —
	# do NOT fall through to `pvr "$@"`: an unauthenticated pvr attempts an
	# interactive browser login that hangs ~5 min before a misleading 401.
	if [ -z "$PH_USER" ] || [ -z "$PH_PASS" ]; then
		pvtest_log ERROR "PH_USER/PH_PASS not set; refusing unauthenticated 'pvr $*'"
		return 1
	fi
	local home; home="$(_ae_pvr_home)"
	mkdir -p "$home" 2>/dev/null
	(
		export HOME="$home"
		if ! PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" pvr login > /dev/null 2>&1; then
			pvtest_log ERROR "pvr login failed; refusing 'pvr $*'"
			exit 1
		fi
		pvr "$@"
	)
}

# _pvr_auth wrapper that captures output and logs it on failure, so Hub
# operations (claim, dev delete) are not silent when they fail. Returns the pvr
# exit code; the captured output is echoed only on error.
_pvr_logged() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }" out rc
	out=$(_pvr_auth "$@" 2>&1)
	rc=$?
	if [ $rc -ne 0 ]; then
		pvtest_log ERROR "${_p}pvr $* failed (exit $rc)${out:+: $out}"
	fi
	return $rc
}

# Wait until the Pantahub client settles into a terminal claim state and echo it
# ("claim" = unclaimed, "idle" = claimed), or nothing on timeout. The client only
# runs while the device is in remote mode and needs time after boot to register,
# so callers must wait for this instead of reading pantahub.state once.
_wait_pantahub_terminal_state() {
	local timeout="${1:-120}" counter=0 st
	while [ "$counter" -lt "$timeout" ]; do
		st=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantahub.state"] // empty')
		case "$st" in
		claim | idle)
			printf '%s' "$st"
			return 0
			;;
		esac
		sleep 2
		counter=$((counter + 2))
	done
	return 1
}

# Track ($1=add) / untrack ($1=del) a self-claimed device id ($2) in the
# run-scoped claimed-devices file, serialised with flock for the parallel pool.
_track_device() {
	local op="$1" dev="$2" f="$PVTEST_CLAIMED_DEVICES_FILE"
	[ -n "$f" ] && [ -n "$dev" ] || return 0
	(
		flock -x 8
		case "$op" in
			add) grep -qxF "$dev" "$f" 2>/dev/null || printf '%s\n' "$dev" >> "$f" ;;
			del) [ -f "$f" ] && { grep -vxF "$dev" "$f" > "$f.tmp" 2>/dev/null; mv "$f.tmp" "$f" 2>/dev/null; } ;;
		esac
	) 8>>"$f.lock"
}

# Delete any still-tracked self-claimed devices (a test killed before teardown).
# Called from the EXIT trap.
_sweep_tracked_devices() {
	local f="$PVTEST_CLAIMED_DEVICES_FILE" d
	[ -n "$f" ] && [ -s "$f" ] || return 0
	while IFS= read -r d; do
		[ -n "$d" ] || continue
		pvtest_log WARN "sweeping leftover self-claimed device $d"
		_pvr_auth dev delete -y "$d" > /dev/null 2>&1
	done < "$f"
	: > "$f" 2>/dev/null || true
}

# Echo the value of config key $1 from a `conf ls` JSON file $2 (empty if absent).
# conf ls format: [{"key":"PV_CONTROL_REMOTE","value":"0","modified":"..."}, ...]
_conf_value() {
	jq -r --arg k "$1" 'if type=="array" then (.[] | select(.key==$k) | .value) // empty else empty end' \
		"$2" 2>/dev/null
}

# Return 0 if device conf file $2 satisfies every KEY=VALUE in the required-config
# string $1 (space-separated). An empty required-config matches any device.
device_matches_env() {
	local _env="$1" _conf="$2" kv k v cv
	[ -s "$_conf" ] || return 1
	for kv in $_env; do
		k=${kv%%=*}
		v=${kv#*=}
		[ -n "$k" ] || continue
		cv=$(_conf_value "$k" "$_conf")
		[ "$cv" = "$v" ] || return 1
	done
	return 0
}

# pvcontrol wrapper that retries on exit 75 (HTTP 503 — command slot busy).
# Use instead of pvcontrol for any command that may race with another in-progress command.
pv_ctrl() {
	local max_attempts=4 delay=5 attempt=1 out rc
	local _via="${PVTEST_EXEC:+ [via SSH]}"
	pvtest_log DEBUG "pvcontrol $*${_via}"
	while [ $attempt -le $max_attempts ]; do
		out=$(pvcontrol "$@" 2>&1)
		rc=$?
		[ $rc -eq 0 ] && return 0
		if [ $rc -eq 75 ]; then
			pvtest_log WARN "pvcontrol $*${_via} rejected (503, attempt $attempt/$max_attempts)${out:+: $out}; retrying in ${delay}s..."
			attempt=$((attempt + 1))
			[ $attempt -le $max_attempts ] && sleep $delay
		else
			pvtest_log WARN "pvcontrol $*${_via} failed (exit $rc)${out:+: $out}"
			return $rc
		fi
	done
	pvtest_log WARN "pvcontrol $* failed after $max_attempts attempts (503)"
	return 75
}

stop_pv() {
	pvtest_log DEBUG "stop_pv: requesting lenient pantavisor shutdown..."
	pv_ctrl cmd poweroff
}

int_handler() {
	pvtest_log DEBUG "Stopping Pantavisor..."
	stop_pv
	exit 2
}

# Step 2: post-flash init for a single device.
# Waits for pantavisor to be responsive and collects device info.
init_device() {
	local ae="$1"
	local ae_safe
	ae_safe=$(printf '%s' "$ae" | tr '/' '_' | tr '-' '_' | tr '.' '_')

	export PVTEST_EXEC="$(_ae_exec_cmd "$ae")"
	export PVTEST_HOST="$(_ae_host "$ae")"

	trap 'int_handler' INT

	pvtest_log INFO "[device $ae] init: waiting for pv-ctrl [via SSH]..."
	wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120
	if [ $? != 0 ]; then
		pvtest_log ERROR "[device $ae] timed out waiting for pv-ctrl"
		return 1
	fi

	pvtest_log INFO "[device $ae] init: waiting for current revision DONE [via SSH]..."
	wait_for_value "pvcontrol steps show-progress current | jq -r .status" "DONE" "120"
	if [ $? != 0 ]; then
		pvtest_log ERROR "[device $ae] timed out waiting for current revision DONE"
		return 1
	fi
	pvtest_log INFO "[device $ae] init: pantavisor ready"

	# Best-effort READY wait. A BSP-only factory revision (no containers) never
	# reaches READY, so this must not be fatal — config is available regardless.
	pvtest_log INFO "[device $ae] init: best-effort wait for READY [via SSH]..."
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" "30" \
		|| pvtest_log WARN "[device $ae] not READY (expected for BSP-only factory revision); continuing"

	# Persistent-device model: capture the device's live config once. Tests are
	# matched against this (their setup.required-config) to decide which device can run them.
	pvtest_log INFO "[device $ae] init: storing config [via SSH]..."
	pvcontrol conf ls > "$(_ae_conf_file "$ae")" 2>/dev/null || true

	pvtest_log INFO "[device $ae] init: collecting device info [via SSH]..."
	pvcontrol devmeta ls > "/tmp/pvtest_device_info_${ae_safe}.json" 2>/dev/null || true
	jq -r '"  revision=\(.["pantavisor.revision"])  arch=\(.["pantavisor.arch"])  version=\(.["pantavisor.version"])"' \
		"/tmp/pvtest_device_info_${ae_safe}.json" 2>/dev/null || true

	# Capture a pristine clone of the device's factory revision once. Each
	# test's setup starts from a clean copy of this (see setup_test), so every
	# test's revision is a direct child of factory and the device trail does not
	# accumulate one test's revision into the next.
	pvtest_log INFO "[device $ae] init: cloning factory revision [via pvr HTTP]..."
	local factory_dir; factory_dir="$(_ae_factory_dir "$ae")"
	rm -rf "$factory_dir" "$factory_dir.home"
	mkdir -p "$factory_dir.home"
	wait_for_status "curl -s 'http://$(_ae_host "$ae"):12368/cgi-bin/pvr' > /dev/null 2>&1; ec=\$?; [ \$ec -eq 0 ] || [ \$ec -eq 52 ]" 0 30
	if ! ( export HOME="$factory_dir.home"; pvr clone "http://$(_ae_host "$ae"):12368/cgi-bin/pvr" "$factory_dir" > /dev/null 2>&1 ); then
		pvtest_log ERROR "[device $ae] failed to clone factory revision"
		return 1
	fi
	# Remember the factory revision name so each test can reset back to it.
	jq -r '.["pantavisor.revision"] // "0"' "/tmp/pvtest_device_info_${ae_safe}.json" 2>/dev/null > "$factory_dir.rev"

	pvtest_log INFO "[device $ae] init: done"
	return 0
}

start_pv() {
	trap 'int_handler' INT

	pvtest_log INFO "waiting for pantavisor pv-ctrl [via pvcontrol]..."
	wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120
	if [ $? != 0 ]; then
		pvtest_log ERROR "timed out waiting for Pantavisor pv-ctrl"
		stop_pv
		exit 1
	fi
	pvtest_log INFO "Pantavisor running"

	pvtest_log INFO "pantavisor is responsive; waiting for current revision DONE [via pvcontrol]..."

	# With no containers (BSP-only revision), pantavisor.status never reaches
	# READY. Wait for the current revision to be DONE instead, which works
	# regardless of how many containers are running.
	wait_for_value "pvcontrol steps show-progress current | jq -r .status" "DONE" "120"
	if [ $? != 0 ]; then
		pvtest_log ERROR "timed out waiting for current revision DONE"
		stop_pv
		exit 1
	fi
	pvtest_log INFO "Pantavisor status: READY"

	pvtest_log INFO "collecting device info [via pvcontrol]..."
	pvcontrol devmeta ls > /tmp/device_info.json 2>/dev/null || true
	factory_revision=$(jq -r '.["pantavisor.revision"]' /tmp/device_info.json 2>/dev/null || echo "0")
	jq -r '"  revision=\(.["pantavisor.revision"])  arch=\(.["pantavisor.arch"])  version=\(.["pantavisor.version"])"' /tmp/device_info.json 2>/dev/null || true
	pvtest_log INFO "done — factory_revision=$factory_revision"
}

# Read a file from the device, routing over SSH when PVTEST_EXEC is set.
_dev_read_file() {
	if [ -n "$PVTEST_EXEC" ]; then
		$PVTEST_EXEC "cat $1" 2>/dev/null
	else
		cat "$1" 2>/dev/null
	fi
}

# Wipe local Pantahub creds so the device re-registers fresh after a reboot.
# NOTE: exact phconfig handling is remote-only and needs verification on a real
# claimed device (see auto-claim test for the inverse operation).
_dev_clean_ph_creds() {
	if [ -n "$PVTEST_EXEC" ]; then
		$PVTEST_EXEC "rm -f /var/run/pantavisor/pv/phconfig/pantahub.config" 2>/dev/null
	else
		rm -f /var/run/pantavisor/pv/phconfig/pantahub.config 2>/dev/null
	fi
}

# Delete device $1 from the Hub and force the appengine back to a registered-but-
# unclaimed baseline (pantahub.state=claim): delete on the Hub, wipe the persisted
# Pantahub creds, reboot, and wait for pantavisor to re-register. Used by both the
# setup unclaim path and teardown so a self-claimed device is fully reset for the
# next test — the two paths must stay symmetric or the next test inherits a dead
# device-id.
_dev_delete_and_reset() {
	local dev="$1"
	[ -n "$dev" ] && _pvr_auth dev delete -y "$dev" > /dev/null 2>&1
	_track_device del "$dev"
	_dev_clean_ph_creds
	pv_ctrl cmd reboot
	wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantahub.state\"]'" "claim" 120
}

# Claim the device this slot points at once and leave it in the idle (claimed)
# state. Waits for the Pantahub client to reach the unclaimed 'claim' state, reads
# the device-id + challenge, runs pvr claim, records the device for cleanup, and
# waits for 'idle'. Returns non-zero on any failure. Called once per device at the
# start of the claim=true phase (run_tests_pool), not per test.
_dev_claim() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"
	local state
	state=$(_wait_pantahub_terminal_state 120)
	if [ "$state" != "claim" ]; then
		pvtest_log ERROR "${_p}cannot claim: pantahub.state='${state:-<none>}' (expected claim)"
		return 1
	fi
	local device_id challenge
	device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
	challenge=$(_dev_read_file /var/run/pantavisor/pv/challenge)
	if [ -z "$device_id" ] || [ -z "$challenge" ]; then
		pvtest_log ERROR "${_p}cannot claim: missing device-id ('$device_id') or challenge"
		return 1
	fi
	pvtest_log INFO "${_p}claiming device $device_id..."
	if ! _pvr_logged claim -c "$challenge" "$device_id"; then
		return 1
	fi
	_track_device add "$device_id"
	if ! wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantahub.state\"]'" "idle" 120; then
		pvtest_log ERROR "${_p}timed out waiting for pantahub.state=idle after claim"
		return 1
	fi
	pvtest_log INFO "${_p}claimed device $device_id"
	return 0
}

# Delete the device this slot currently points at from the Hub, without rebooting.
# Called once per device at the end of the claim=true phase (run_tests_pool).
_dev_delete_only() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"
	local device_id
	device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
	[ -n "$device_id" ] || return 0
	pvtest_log INFO "${_p}deleting claimed device $device_id"
	_pvr_logged dev delete -y "$device_id"
	_track_device del "$device_id"
}

# Bring the device into the claim state required by setup.self-claim.
# pantahub.state: "claim" = unclaimed, "idle" = claimed. No-op for local devices
# (no pantahub.state) and for the matching combinations. A device claimed here
# (self-claim=true) is recorded in claimed_device for deletion in teardown.
handle_self_claim() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"
	claimed_device=

	local state
	state=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantahub.state"] // empty')
	[ -n "$state" ] || return 0

	local device_id
	device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)

	if [ "$state" = "idle" ] && [ "$self_claim" = "false" ]; then
		pvtest_log INFO "${_p}self-claim=false but device claimed; unclaiming ($device_id)..."
		_dev_delete_and_reset "$device_id"
	elif [ "$state" = "claim" ] && [ "$self_claim" = "true" ]; then
		pvtest_log INFO "${_p}self-claim=true and device unclaimed; claiming ($device_id)..."
		local challenge
		challenge=$(_dev_read_file /var/run/pantavisor/pv/challenge)
		if [ -n "$device_id" ] && [ -n "$challenge" ]; then
			_pvr_auth claim -c "$challenge" "$device_id" > /dev/null 2>&1
			claimed_device="$device_id"
			_track_device add "$device_id"
			wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantahub.state\"]'" "idle" 120
		else
			pvtest_log ERROR "${_p}cannot claim: missing device-id or challenge"
			return 1
		fi
	fi
	return 0
}

# Apply per-test runtime metadata (setup.usrmeta, same KEY=VALUE format as env),
# one key at a time. Applied keys are recorded for removal in teardown.
#
# usrmeta keys are delivered to a real device as Hub *user-meta*. A remote device
# (PV_CONTROL_REMOTE_ALWAYS=1) syncs user-meta down from the Hub and would override
# — and wipe — any value set only locally. So set each key BOTH locally (immediate
# effect for the test body) and on the Hub (survives the sync). The Hub set is
# best-effort: self-claim=false tests do not own the device yet and simply skip it.
apply_usrmeta() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"
	applied_usrmeta_keys=
	[ -n "$usrmeta" ] || return 0
	local device_id=""
	if [ -n "$PH_USER" ] && [ -n "$PH_PASS" ]; then
		device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
	fi
	local kv k v
	for kv in $usrmeta; do
		k=${kv%%=*}
		v=${kv#*=}
		[ -n "$k" ] || continue
		pvtest_log INFO "${_p}usrmeta save $k=$v"
		pv_ctrl usrmeta save "$k" "$v"
		if [ -n "$device_id" ]; then
			_pvr_auth device set "$device_id" "$k=$v" > /dev/null 2>&1 \
				|| pvtest_log WARN "${_p}could not set Hub user-meta $k=$v (device not owned yet?)"
		fi
		applied_usrmeta_keys="${applied_usrmeta_keys:+$applied_usrmeta_keys }$k"
	done
}

# Provision the test's initial revision and wait until the device is live on it.
# setup_test only *installs state* — the test body itself runs later in exec_test.
#
# The initial revision is built from a clean copy of the factory clone with
# every tarball fragment (a `json` state file + `objects/`) merged in, checked
# out and committed before posting. This keeps each test's starting state
# self-contained (a child of factory) regardless of the previous test, without
# resetting the device — the device transitions directly to the posted revision.
setup_test() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"

	# Pool mode manages the claim lifecycle per phase, not per test: the claim=true
	# bucket claims each device once up front and deletes it once at the end
	# (run_tests_pool), and remote self-claim=false tests run on dedicated unclaimed
	# containers whose own test script does the claiming. Only the legacy
	# single-device path (PVTEST_AE unset) still claims per test here.
	if [ -z "$PVTEST_AE" ]; then
		handle_self_claim || return 1
	fi

	# No device reset between tests: each test's initial revision is built fresh
	# from the pristine factory clone (see below) and posted, so the device
	# transitions straight from the previous test's revision to this one. This is
	# faster than bouncing through factory, and tests must not rely on the device
	# trail being pruned to [factory] — trail-sensitive tests report only their
	# own current revision instead of the full `steps ls`.

	pvtest_log INFO "${_p}installing initial revision for $test_id [via pvr HTTP]..."

	if [ -z "$tarballs" ]; then
		pvtest_log INFO "${_p}no tarballs declared; running against current state"
		return 0
	fi

	local setup_parent setup_dir
	setup_parent=$(mktemp -d /tmp/pvtest_setup.XXXXXX)
	setup_dir="$setup_parent/repo"
	mkdir -p "$setup_dir"

	# pvr keeps a global, content-addressed object cache at $HOME/.pvr/objects.
	# In pool mode every slot runs pvr in the same tester container, so concurrent
	# `pvr merge`/`post` of the same objects (e.g. bsp.tgz) race on that shared
	# cache. Point HOME at this test's private setup_parent so each pvr pipeline
	# gets its own isolated cache. It is cleaned up with setup_parent below.
	# Start from a clean copy of the device's factory revision clone (captured
	# in init_device) rather than an empty repo, so the test's revision is a
	# direct child of factory and replaces the previous test's revision in the
	# device trail instead of accumulating on top of it.
	local factory_dir; factory_dir="$(_ae_factory_dir "$PVTEST_AE")"
	if [ -n "$PVTEST_AE" ] && [ -d "$factory_dir/.pvr" ]; then
		# Pool mode: seed from the device's pristine factory clone so the
		# revision is a direct child of factory and replaces (not accumulates
		# on) the previous test's revision in the device trail.
		pvtest_log DEBUG "${_p}seeding $setup_dir from factory clone $factory_dir"
		if ! cp -a "$factory_dir/." "$setup_dir/" 2>/dev/null; then
			pvtest_log ERROR "${_p}failed to copy factory clone"
			rm -rf "$setup_parent"
			return 1
		fi
	else
		# Legacy single-device / external-target mode: no factory clone was
		# captured, fall back to an empty repo (pre-pool behaviour).
		pvtest_log DEBUG "${_p}pvr init $setup_dir"
		( export HOME="$setup_parent"; cd "$setup_dir" && pvr init > /dev/null 2>&1 )
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "${_p}pvr init failed"
			rm -rf "$setup_parent"
			return 1
		fi
	fi

	for t in $tarballs; do
		local tarball_path
		if [ "${t#/}" = "$t" ]; then
			tarball_path="$test_dir/$t"
		else
			tarball_path="$t"
		fi
		local frag_dir
		frag_dir=$(mktemp -d /tmp/pvtest_frag.XXXXXX)
		tar xzf "$tarball_path" -C "$frag_dir" > /dev/null 2>&1
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "${_p}failed to extract tarball: $tarball_path"
			rm -rf "$frag_dir" "$setup_parent"
			return 1
		fi
		pvtest_log DEBUG "${_p}pvr merge ${tarball_path##*/}"
		( export HOME="$setup_parent"; cd "$setup_dir" && pvr merge "$frag_dir" > /dev/null 2>&1 )
		if [ $? -ne 0 ]; then
			pvtest_log ERROR "${_p}pvr merge failed for $tarball_path"
			rm -rf "$frag_dir" "$setup_parent"
			return 1
		fi
		rm -rf "$frag_dir"
	done

	# Merge only updates .pvr/json; checkout materialises the merged files into
	# the working tree so the following commit captures the full revision.
	pvtest_log DEBUG "${_p}pvr checkout && pvr commit"
	( export HOME="$setup_parent"; cd "$setup_dir" && pvr checkout > /dev/null 2>&1 && pvr commit > /dev/null 2>&1 )
	if [ $? -ne 0 ]; then
		pvtest_log ERROR "${_p}pvr checkout/commit failed"
		rm -rf "$setup_parent"
		return 1
	fi

	local rev_name
	rev_name="locals/$(printf '%s' "$test_id" | tr '/' '_' | tr '-' '_')"

	# Drain any leftover activity from the PREVIOUS test before posting this test's
	# initial revision: wait for pv-ctrl, the current revision to reach DONE/UPDATED
	# and (unless on BSP-only factory) READY. A previous test that ended in a
	# rollback storm can leave the device briefly busy; waiting here means we do not
	# abort THIS test for the previous test's mess.
	local _cur_rev _factory_rev="" _need_ready=true
	[ -f "$factory_dir.rev" ] && _factory_rev=$(cat "$factory_dir.rev" 2>/dev/null)
	_cur_rev=$(pvcontrol devmeta ls 2>/dev/null | jq -r '.["pantavisor.revision"] // empty')
	[ -n "$_factory_rev" ] && [ "$_cur_rev" = "$_factory_rev" ] && _need_ready=false
	pvtest_log INFO "${_p}waiting for device to settle from previous test (require_ready=$_need_ready) [via pvcontrol]..."
	wait_for_current_settled "$_need_ready" \
		|| pvtest_log WARN "${_p}device did not fully settle before initial revision; continuing"

	# curl returns 52 (empty reply) when the pvr endpoint is up but returns no
	# body to a bare GET — that is normal. Accept 0 or 52 as "server ready".
	pvtest_log DEBUG "${_p}waiting for pvr HTTP endpoint [via pvr HTTP]"
	wait_for_status "curl -s 'http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr' > /dev/null 2>&1; ec=\$?; [ \$ec -eq 0 ] || [ \$ec -eq 52 ]" 0 30
	if [ $? -ne 0 ]; then
		pvtest_log ERROR "${_p}pvr HTTP endpoint not ready"
		rm -rf "$setup_parent"
		return 1
	fi

	pvtest_log DEBUG "${_p}posting initial revision $rev_name [via pvr HTTP]"
	( export HOME="$setup_parent"; cd "$setup_dir" && pvr post --rev "$rev_name" "http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr" > /dev/null 2>&1 )
	if [ $? -ne 0 ]; then
		pvtest_log ERROR "${_p}pvr post failed for $rev_name"
		rm -rf "$setup_parent"
		return 1
	fi

	rm -rf "$setup_parent"

	pvtest_log INFO "${_p}waiting for $rev_name to become ready [via pvcontrol]..."
	wait_for_new_revision "$rev_name" true
	if [ $? -ne 0 ]; then
		pvtest_log ERROR "${_p}timeout waiting for $rev_name to become ready"
		return 1
	fi

	# Apply per-test runtime metadata. The initial revision is now DONE/READY,
	# so usrmeta keys take effect for the test body and are removed in teardown.
	apply_usrmeta

	pvtest_log INFO "${_p}done — installed $rev_name"
}

teardown_test() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"

	# Remove any usrmeta applied for this test so the next test starts clean —
	# locally and on the Hub (clear the value so a remote device's next sync does
	# not re-apply a stale override). Hub clear is best-effort.
	if [ -n "$applied_usrmeta_keys" ]; then
		local device_id=""
		if [ -n "$PH_USER" ] && [ -n "$PH_PASS" ]; then
			device_id=$(_dev_read_file /var/run/pantavisor/pv/device-id)
		fi
		local k
		for k in $applied_usrmeta_keys; do
			pvtest_log INFO "${_p}usrmeta delete $k"
			pv_ctrl usrmeta delete "$k"
			[ -n "$device_id" ] && \
				_pvr_auth device set "$device_id" "$k=" > /dev/null 2>&1
		done
		applied_usrmeta_keys=
	fi

	# Legacy single-device path only: if this test claimed the device per-test
	# (handle_self_claim, PVTEST_AE unset), delete it from the Hub and reset to a
	# registered-but-unclaimed baseline (state=claim). In pool mode claimed_device
	# is never set here — the claim lifecycle is managed per phase in run_tests_pool
	# (claim once / delete once per device), so this block is a no-op.
	if [ -n "$claimed_device" ]; then
		pvtest_log INFO "${_p}deleting self-claimed device $claimed_device and resetting to unclaimed"
		_dev_delete_and_reset "$claimed_device"
		claimed_device=
	fi
}

exec_test() {
	local _p="${PVTEST_AE:+[device $PVTEST_AE] }"
	pvtest_log INFO "${_p}executing test script for $test_id..."
	if [ ! -f "$test_dir/$test_script" ]; then
		pvtest_log ERROR "'$test_dir/$test_script' does not exist"
		return 1
	fi

	# The test script runs in the tester, not on the device, so its pvr/curl-to-Hub
	# calls need a logged-in ~/.pvr. Point HOME at this device's isolated pvr home
	# (per-device, so parallel pool slots never race on ~/.pvr) and log in there, so
	# no remote test script has to call `pvr login` itself.
	local pvrhome=""
	if [ -n "$PH_USER" ] && [ -n "$PH_PASS" ]; then
		pvrhome="$(_ae_pvr_home)"
		mkdir -p "$pvrhome" 2>/dev/null
		HOME="$pvrhome" PVR_USERNAME="$PH_USER" PVR_PASSWORD="$PH_PASS" \
			pvr login > /dev/null 2>&1 \
			|| pvtest_log WARN "${_p}pvr login failed for test script"
	fi

	tmp_script_path=$(mktemp /tmp/pv_appengine_script.XXXXXX)
	{
		# Run with HOME at the pre-authenticated pvr home so the script's pvr/curl
		# Hub calls (and "$HOME/.pvr/auth.json" reads) work without an explicit login.
		[ -n "$pvrhome" ] && printf 'export HOME=%s\n' "$pvrhome"
		# Source utils so pvcurl/pvcontrol/pventer route via PVTEST_EXEC in the
		# test script subprocess (shell functions don't propagate across processes).
		echo ". @CMAKE_INSTALL_FULL_DATADIR@/@PROJECT_NAME@/pvtest/utils"
		cat "$test_dir/$test_script"
	} > "$tmp_script_path"
	chmod +x "$tmp_script_path"

	tmp_out_path=$(mktemp /tmp/pv_appengine_output.XXXXXX)
	mkdir -p "$run_dir/$test_id"
	# script runs the test under a pty (stdout+stderr in console order). Stream it
	# live: tee -> tmp_out_path (for the diff), then append test.log (interleaving
	# with the ae_log tail) AND pass through to our stdout so the run console shows
	# the test script output in real time.
	script -q -c "bash -c \"$tmp_script_path\"" \
		| tee "$tmp_out_path" \
		| tee -a "$run_dir/$test_id/test.log"
	pvtest_log INFO "test script complete"

	if [ "$overwrite" = "true" ]; then
		pvtest_log INFO "overwriting expected output"
		cat "$tmp_out_path" > "$test_dir/output"
	fi
	rm -f "$tmp_script_path"
}

eval_test() {
	if [ "$overwrite" = "true" ]; then
		return 0
	fi

	local diff_out
	diff_out=$(diff "$test_dir/output" "$tmp_out_path")
	local rc=$?
	if [ $rc -ne 0 ]; then
		echo "--- diff: $test_id ---"
		echo "$diff_out"
		echo "--- end diff ---"
		if [ -n "$run_dir" ]; then
			mkdir -p "$run_dir/$test_id"
			echo "$diff_out" > "$run_dir/$test_id/diff"
		fi
	fi
	rm -f "$tmp_out_path"
	return $rc
}

# Run a single test attempt on a specific device.
# Caller is responsible for setting PVTEST_EXEC and PVTEST_HOST in the environment.
# Returns 0 on pass, 1 on fail/abort, 2 on skip (caller should not retry on 2).
run_test_attempt() {
	local json_path="$1"
	test_dir=$(dirname "$json_path")
	test_id=$(echo "$json_path" | sed 's|^/work/||; s|/test\.json$||')

	# Identify this device's appengine log file. Logs are keyed by the full
	# container name (appengine-<container-name>.log) so per-policy containers
	# that share a trailing index (…-local-disabled-0, …-local-strict-0) never
	# collide.
	local ae_log="" ae_log_start=0
	if [ -n "$PVTEST_AE" ] && [ -n "$appengine_logs" ]; then
		for _l in $appengine_logs; do
			case "$_l" in
				*"/appengine-${PVTEST_AE}.log") ae_log="$_l"; break ;;
			esac
		done
		[ -n "$ae_log" ] && [ -f "$ae_log" ] && ae_log_start=$(wc -l < "$ae_log")
	fi

	if ! parse_test; then
		echo "=== TEST: $test_id ERROR (parse failed) ==="
		return 1
	fi

	local _skip
	_skip=$(jq -r '.skip' "$json_path")
	if [ "$_skip" = "true" ]; then
		if [ "$FAIL_ON_SKIP_FIELD" = "true" ]; then
			pvtest_log ERROR "'$test_id' has skip:true but FAIL_ON_SKIP_FIELD is set (skip is not allowed on master)"
			return 1
		fi
		pvtest_log INFO "'$test_id' SKIPPED"
		return 2
	fi

	if [ -n "$PVTEST_DEVICE" ]; then
		local _devs
		_devs=$(jq -r 'if (.devices // []) == [] then "" else (.devices | join(" ")) end' "$json_path")
		if [ -n "$_devs" ]; then
			case " $_devs " in
				*" $PVTEST_DEVICE "*) ;;
				*)
					pvtest_log INFO "'$test_id' SKIPPED (device=$PVTEST_DEVICE not in: $_devs)"
					return 2
					;;
			esac
		fi
	fi

	if [ "$self_claim" = "true" ] && { [ -z "$PH_USER" ] || [ -z "$PH_PASS" ]; }; then
		pvtest_log ERROR "PH_USER/PH_PASS not set but required by self-claim test(s)"
		pvtest_log INFO "'$test_id' SKIPPED (PH_USER/PH_PASS not set)"
		return 2
	fi

	# Per-test log: capture the WHOLE test (setup -> script -> teardown) — the
	# pvtest-run messages (mirrored by pvtest_log via PVTEST_ACTIVE_TESTLOG), the
	# test script output (appended by exec_test), and this device's pantavisor
	# logs (tailed below). PVTEST_ACTIVE_TESTLOG is a local (NOT exported), so the
	# test script child process does not re-mirror its own pvtest_log calls.
	mkdir -p "$run_dir/$test_id"
	local PVTEST_ACTIVE_TESTLOG="$run_dir/$test_id/test.log"

	# Follow this device's pantavisor log into test.log for the whole test window.
	# Started before setup_test (and stopped after teardown_test) so setup and
	# teardown device logs are captured too, not just the test script's.
	local ae_tail_pid=""
	if [ -n "$ae_log" ] && [ -f "$ae_log" ]; then
		tail -n "+$((ae_log_start + 1))" -f "$ae_log" >> "$PVTEST_ACTIVE_TESTLOG" 2>/dev/null &
		ae_tail_pid=$!
	fi

	pvtest_log INFO "'$test_id' START"
	local _test_start
	_test_start=$(date +%s)

	if ! setup_test; then
		local _test_runtime=$(( $(date +%s) - _test_start ))
		pvtest_log ERROR "'$test_id' ABORTED ($_test_runtime s)"
		teardown_test
		[ -n "$ae_tail_pid" ] && { kill "$ae_tail_pid" 2>/dev/null; wait "$ae_tail_pid" 2>/dev/null || true; }
		return 1
	fi

	if ! exec_test; then
		local _test_runtime=$(( $(date +%s) - _test_start ))
		pvtest_log ERROR "'$test_id' ABORTED ($_test_runtime s)"
		teardown_test
		[ -n "$ae_tail_pid" ] && { kill "$ae_tail_pid" 2>/dev/null; wait "$ae_tail_pid" 2>/dev/null || true; }
		return 1
	fi

	eval_test
	local test_result=$?
	local _test_runtime=$(( $(date +%s) - _test_start ))

	if [ "$overwrite" = "true" ]; then
		pvtest_log INFO "'$test_id' RECORDED ($_test_runtime s)"
	elif [ $test_result -eq 0 ]; then
		pvtest_log INFO "'$test_id' PASSED ($_test_runtime s)"
	else
		pvtest_log ERROR "'$test_id' FAILED ($_test_runtime s)"
		teardown_test
		[ -n "$ae_tail_pid" ] && { kill "$ae_tail_pid" 2>/dev/null; wait "$ae_tail_pid" 2>/dev/null || true; }
		return 1
	fi

	teardown_test
	[ -n "$ae_tail_pid" ] && { kill "$ae_tail_pid" 2>/dev/null; wait "$ae_tail_pid" 2>/dev/null || true; }
	return 0
}

# Dispatch a list of tests across a set of devices using a FIFO as a semaphore.
# $1 = space-separated device (appengine) names, $2 = newline/space-separated
# test.json paths. Relies on dynamic scoping for max_retries and failed_flag,
# set by the calling run_tests_pool.
# Use a fixed FD (7) to stay POSIX-sh compatible (no bash {var} FD syntax).
dispatch_tests() {
	local _devices="$1" _tests="$2"
	local ae json_path attempt rc

	local ae_fifo
	ae_fifo=$(mktemp -u /tmp/pvtest_ae_fifo.XXXXXX)
	mkfifo "$ae_fifo"
	exec 7<>"$ae_fifo"
	rm -f "$ae_fifo"

	# Seed pool with this bucket's matching devices.
	for ae in $_devices; do
		printf '%s\n' "$ae" >&7
	done

	# No per-test reset: each test installs its own self-contained initial
	# revision in setup_test (built from its tarballs), so tests don't inherit
	# each other's state. The device is returned to factory once at the end.
	for json_path in $_tests; do
		read -r ae <&7
		(
			export PVTEST_EXEC="$(_ae_exec_cmd "$ae")"
			export PVTEST_HOST="$(_ae_host "$ae")"
			export PVTEST_AE="$ae"

			attempt=0
			rc=1
			while true; do
				run_test_attempt "$json_path"
				rc=$?
				{ [ $rc -eq 0 ] || [ $rc -eq 2 ]; } && break
				attempt=$((attempt + 1))
				[ $attempt -gt $max_retries ] && break
				pvtest_log INFO "[device $ae] retry attempt $attempt/$max_retries for $json_path"
				sleep 5
				# setup_test (re-run inside run_test_attempt) re-installs the
				# test's initial revision, so the retry starts clean.
			done

			{ [ $rc -ne 0 ] && [ $rc -ne 2 ]; } && touch "$failed_flag"

			printf '%s\n' "$ae" >&7
		) &
	done

	wait
	exec 7>&-
}

# ===========================================================================
# Slot-pool dispatcher: a single global FIFO semaphore of PVTEST_SLOTS slots
# over a flat test queue, with the host (test.docker.sh) re-typing each slot's
# appengine container on demand over the PVTEST_CTRL control dir.
#
# Tests are grouped into runner-types (normalized required-config + needs-claim,
# each self-claim=false remote test in its own type so it never shares a claimed
# device). A slot holds one container; a worker stays on its current type while
# it has pending tests (affinity -> claim-once + minimal re-types) and otherwise
# attaches to the non-empty type with the fewest attached workers (tie: longest-
# first order), keeping every slot busy. Claim-once: a claimed device is claimed
# when a worker attaches to its type and deleted when the worker switches away.
# ===========================================================================

# Bind PVTEST_EXEC/HOST/AE to container $1. In container mode (PVTEST_SSH_KEY set)
# clear the previous values first so the per-container accessors rebuild for $1
# instead of short-circuiting on the prior container's exec/host; in external
# mode (host-provided PVTEST_EXEC) leave them as given.
_slot_bind_ae() {
	if [ -n "$PVTEST_SSH_KEY" ]; then PVTEST_EXEC=""; PVTEST_HOST=""; fi
	export PVTEST_EXEC="$(_ae_exec_cmd "$1")"
	export PVTEST_HOST="$(_ae_host "$1")"
	export PVTEST_AE="$1"
}

# Ask the host to re-type slot $1 to required-config $2 (empty = tear the slot's
# container down). Echoes the new container name on success (and nothing else, so
# the caller can capture it); returns non-zero on failure/timeout. Stays silent
# on error so it never pollutes the captured name — the caller logs the abort.
_retype_slot() {
	local _slot="$1" _cfg="$2" _req _resp _waited _status _ae
	_req="$PVTEST_CTRL/req/slot${_slot}"
	_resp="$PVTEST_CTRL/resp/slot${_slot}"
	rm -f "$_resp"
	printf 'slot=%s\ncfg=%s\n' "$_slot" "$_cfg" > "$PVTEST_CTRL/req/.tmp.slot${_slot}"
	mv "$PVTEST_CTRL/req/.tmp.slot${_slot}" "$_req"
	_waited=0
	while [ ! -f "$_resp" ]; do
		sleep 1
		_waited=$((_waited + 1))
		[ "$_waited" -gt 300 ] && return 1
	done
	_status=$(sed -n 's/^status=//p' "$_resp")
	_ae=$(sed -n 's/^ae=//p' "$_resp")
	rm -f "$_resp"
	case "$_status" in
		ready) printf '%s' "$_ae"; return 0 ;;
		down)  return 0 ;;
		*)     return 1 ;;
	esac
}

# Emit an ABORTED result line for each test path in "$@" (after $1=reason), so a
# failed attach still produces a SUMMARY record for every test it stranded.
_slot_abort_tests() {
	local _reason="$1" _j _tid
	shift
	for _j in "$@"; do
		_tid=$(echo "$_j" | sed 's|^/work/||; s|/test\.json$||')
		pvtest_log ERROR "'${_tid}' ABORTED (${_reason})"
	done
}

# Pick the next test for a worker currently on type $2 (empty if unattached),
# from pool dir $1. Under a global lock: stay on the current type while it has
# tests (affinity); else release it (decrement its attached count) and attach to
# the non-empty type with the fewest attached workers (tie: longest-first order).
# Pops and echoes "<token>\t<jsonpath>", or nothing when the queue is drained.
_slot_pick() {
	local _pool="$1" _cur="$2"
	(
		flock -x 9
		local _tok="" _a _best _best_att _t _att _head
		if [ -n "$_cur" ] && [ -s "$_pool/q.$_cur" ]; then
			_tok="$_cur"
		else
			if [ -n "$_cur" ] && [ -f "$_pool/attached.$_cur" ]; then
				_a=$(cat "$_pool/attached.$_cur")
				_a=$((_a - 1)); [ "$_a" -lt 0 ] && _a=0
				printf '%s' "$_a" > "$_pool/attached.$_cur"
			fi
			# Attach to the non-empty type with the fewest attached workers; break
			# ties by the longest-first order of the pool's "order" file (the
			# first such type wins, since we only replace on strictly fewer
			# attached and iterate in that order).
			_best=""; _best_att=2000000000
			while IFS= read -r _t; do
				[ -s "$_pool/q.$_t" ] || continue
				_att=$(cat "$_pool/attached.$_t" 2>/dev/null || echo 0)
				if [ "$_att" -lt "$_best_att" ]; then
					_best="$_t"; _best_att="$_att"
				fi
			done < "$_pool/order"
			[ -n "$_best" ] || exit 0
			_tok="$_best"
			_a=$(cat "$_pool/attached.$_tok" 2>/dev/null || echo 0)
			_a=$((_a + 1))
			printf '%s' "$_a" > "$_pool/attached.$_tok"
		fi
		_head=$(head -n1 "$_pool/q.$_tok")
		tail -n +2 "$_pool/q.$_tok" > "$_pool/q.$_tok.tmp" && mv "$_pool/q.$_tok.tmp" "$_pool/q.$_tok"
		printf '%s\t%s' "$_tok" "$_head"
	) 9>"$_pool/lock"
}

# One slot worker: pull tests from the pool, re-typing the slot's container when
# the next test's type differs, with claim-once managed at attach/detach.
slot_worker() {
	local _slot="$1" _pool="$2" _failed="$3"
	local _max="${MAX_RETRIES:-0}"
	local _tok="" _ae="" _role="no"
	local _sel _newtok _json _attempt _rc

	while : ; do
		_sel=$(_slot_pick "$_pool" "$_tok")
		[ -n "$_sel" ] || break
		_newtok=${_sel%%	*}
		_json=${_sel#*	}

		# (Re)attach when switching type or recovering from a failed attach.
		if [ "$_newtok" != "$_tok" ] || [ -z "$_ae" ]; then
			# Detach the current container first (delete-once if it was claimed).
			if [ -n "$_ae" ]; then
				_slot_bind_ae "$_ae"
				[ "$_role" = yes ] && _dev_delete_only
				pv_ctrl cmd poweroff > /dev/null 2>&1 || true
			fi
			_tok="$_newtok"
			_role=$(cat "$_pool/role.$_newtok")
			_ae=$(_retype_slot "$_slot" "$(cat "$_pool/req.$_newtok")")
			if [ -z "$_ae" ]; then
				_slot_abort_tests "re-type failed" "$_json"; touch "$_failed"; continue
			fi
			_slot_bind_ae "$_ae"
			if ! init_device "$_ae"; then
				pvtest_log ERROR "[device $_ae] init failed"
				_slot_abort_tests "device init failed" "$_json"; touch "$_failed"
				_ae=""; continue
			fi
			if [ "$_role" = yes ] && ! _dev_claim; then
				_slot_abort_tests "claim failed" "$_json"; touch "$_failed"
				_ae=""; continue
			fi
		fi

		# Run the test on this slot's container, with retries.
		_slot_bind_ae "$_ae"
		_attempt=0; _rc=1
		while : ; do
			run_test_attempt "$_json"; _rc=$?
			{ [ "$_rc" -eq 0 ] || [ "$_rc" -eq 2 ]; } && break
			_attempt=$((_attempt + 1))
			[ "$_attempt" -gt "$_max" ] && break
			pvtest_log INFO "[device $_ae] retry attempt $_attempt/$_max for $_json"
			sleep 5
		done
		{ [ "$_rc" -ne 0 ] && [ "$_rc" -ne 2 ]; } && touch "$_failed"
	done

	# Final detach: delete-once if claimed, power off, release the container.
	if [ -n "$_ae" ]; then
		_slot_bind_ae "$_ae"
		[ "$_role" = yes ] && _dev_delete_only
		pv_ctrl cmd poweroff > /dev/null 2>&1 || true
		_retype_slot "$_slot" "" > /dev/null 2>&1 || true
	fi
}

# Group the queued tests into runner-types and dispatch them across the slots.
run_slot_pool() {
	local _slots="${PVTEST_SLOTS:-1}"
	local _pool _failed _j _req _sc _nc _extra _tok _t _pids _s _dur _mx _sm
	_pool=$(mktemp -d /tmp/pvtest_slotpool.XXXXXX)
	: > "$_pool/order"

	for _j in $test_json_list; do
		_req=$(_reqcfg_norm "$(jq -r '.setup."required-config" // ""' "$_j")")
		_sc=$(jq -r '.setup."self-claim" // "false"' "$_j")
		_dur=$(jq -r '.setup."expected-seconds" // 0' "$_j")
		case " $_req " in
			*" PV_CONTROL_REMOTE=1 "*) [ "$_sc" = "true" ] && _nc=yes || _nc=no ;;
			*) _nc=no ;;
		esac
		_extra=""
		case " $_req " in
			*" PV_CONTROL_REMOTE=1 "*)
				[ "$_sc" != "true" ] && _extra="|self=$(echo "$_j" | sed 's|^/work/||; s|/test\.json$||')" ;;
		esac
		_tok=$(printf '%s' "${_nc}|${_req}${_extra}" | cksum | cut -d' ' -f1)
		if [ ! -f "$_pool/req.$_tok" ]; then
			printf '%s' "$_req" > "$_pool/req.$_tok"
			printf '%s' "$_nc" > "$_pool/role.$_tok"
			printf '0' > "$_pool/attached.$_tok"
			printf '%s\n' "$_tok" >> "$_pool/order"
		fi
		printf '%s\t%s\n' "$_dur" "$_j" >> "$_pool/qd.$_tok"
	done

	# Order longest-first (LPT makespan heuristic) so the long tests start at t=0
	# and the short ones backfill the tail, instead of a long test running alone
	# at the end with idle slots. Two levels, both keyed on each test.json's
	# .setup."expected-seconds" hint (0 if absent): each type's queue is sorted
	# longest-test-first, and the type list is ordered by its heaviest single
	# test (tie: larger total) so a cold-start worker grabs the type holding the
	# longest pole and runs that test first. This order also drives the
	# load-balance tie-break in _slot_pick.
	: > "$_pool/order.w"
	while IFS= read -r _t; do
		[ -n "$_t" ] || continue
		sort -k1,1nr "$_pool/qd.$_t" > "$_pool/qd.$_t.s"
		cut -f2- "$_pool/qd.$_t.s" > "$_pool/q.$_t"
		_mx=$(head -n1 "$_pool/qd.$_t.s" | cut -f1)
		_sm=$(awk -F'\t' '{s+=$1} END{print s+0}' "$_pool/qd.$_t")
		rm -f "$_pool/qd.$_t.s"
		printf '%s\t%s\t%s\n' "${_mx:-0}" "$_sm" "$_t" >> "$_pool/order.w"
	done < "$_pool/order"
	sort -k1,1nr -k2,2nr "$_pool/order.w" | cut -f3 > "$_pool/order.sorted"
	mv "$_pool/order.sorted" "$_pool/order"
	rm -f "$_pool/order.w"

	while IFS= read -r _t; do
		pvtest_log INFO "runner-type $_t: claim=$(cat "$_pool/role.$_t") tests=$(wc -l < "$_pool/q.$_t") cfg=[$(cat "$_pool/req.$_t")]"
	done < "$_pool/order"
	pvtest_log INFO "=== slot pool: dispatching across up to ${_slots} slot(s) ==="

	_failed=$(mktemp); rm -f "$_failed"

	_pids=""; _s=0
	while [ "$_s" -lt "$_slots" ]; do
		slot_worker "$_s" "$_pool" "$_failed" &
		_pids="${_pids:+$_pids }$!"
		_s=$((_s + 1))
	done
	[ -n "$_pids" ] && wait $_pids

	rm -rf "$_pool"
	if [ -f "$_failed" ]; then rm -f "$_failed"; return 1; fi
	return 0
}

# Run all selected tests across a HETEROGENEOUS fleet of N appengines. The host
# (test.docker.sh) boots one wave's runners — each configured for a runner-type
# (its required-config, as PV_* env) and tagged with a claim role in
# PVTEST_AE_CLAIM — and passes the exact test list in PVTEST_JSON_LIST.
#
# Tests are grouped into the SAME runner-types (normalized required-config +
# needs-claim). Each ready device is assigned to the type whose config it matches
# AND whose claim role it carries (so two same-config pools — one claimed for
# self-claim=true, one unclaimed for the self-claim=false claim tests — stay
# distinct without any PV_LXC_LOG_LEVEL marker). For each type: claim its devices
# once up front if the type needs claiming, dispatch its tests across its devices
# (one FIFO per type, all types in parallel), then delete the claimed devices.
# Every test runs exactly once.
run_tests_pool() {
	local max_retries="${MAX_RETRIES:-0}"

	# Phase 1: initialise all devices in parallel; collect ready ones.
	local ready_list_file
	ready_list_file=$(mktemp /tmp/pvtest_ready.XXXXXX)
	local ready_lock_file="${ready_list_file}.lock"

	for ae in $PVTEST_APPENGINES; do
		(
			if init_device "$ae"; then
				(flock -x 9; printf '%s\n' "$ae" >> "$ready_list_file") 9>"$ready_lock_file"
			else
				pvtest_log ERROR "device $ae failed initialisation; removing from pool"
			fi
		) &
	done
	wait

	local ready_aes
	ready_aes=$(cat "$ready_list_file")
	rm -f "$ready_list_file" "$ready_lock_file"

	local n_ready
	n_ready=$(printf '%s\n' "$ready_aes" | grep -c .)

	if [ "$n_ready" -eq 0 ]; then
		pvtest_log ERROR "no devices initialised successfully; aborting"
		return 1
	fi

	pvtest_log INFO "pool ready: $n_ready device(s): $(echo $ready_aes)"

	local failed_flag
	failed_flag=$(mktemp /tmp/pvtest_failed.XXXXXX)
	rm -f "$failed_flag"

	# Phase 2: group the selected tests into runner-types under a temp dir, keyed
	# by a checksum of "<needs-claim>|<normalized required-config>". Per type we
	# store its tests, its normalized config, and its claim role.
	local tpool
	tpool=$(mktemp -d /tmp/pvtest_pool.XXXXXX)
	local json_path
	for json_path in $test_json_list; do
		local _req _sc _nc _tok
		_req=$(_reqcfg_norm "$(jq -r '.setup."required-config" // ""' "$json_path")")
		_sc=$(jq -r '.setup."self-claim" // "false"' "$json_path")
		case " $_req " in
			*" PV_CONTROL_REMOTE=1 "*) [ "$_sc" = "true" ] && _nc=yes || _nc=no ;;
			*) _nc=no ;;
		esac
		_tok=$(printf '%s' "${_nc}|${_req}" | cksum | cut -d' ' -f1)
		printf '%s\n' "$json_path" >> "$tpool/tests.$_tok"
		if [ ! -f "$tpool/req.$_tok" ]; then
			printf '%s' "$_req" > "$tpool/req.$_tok"
			printf '%s' "$_nc" > "$tpool/role.$_tok"
		fi
	done

	# Assign each ready device to the most-specific type it matches (by config),
	# constrained to types whose claim role equals the device's role. A device
	# that matches no type is left out (and shut down at the end).
	local f ae
	for ae in $ready_aes; do
		local _role _conf _best="" _bestkeys=-1 _tok _treq _trole _k
		_role=$(_ae_claim_role "$ae")
		_conf=$(_ae_conf_file "$ae")
		for f in "$tpool"/req.*; do
			[ -e "$f" ] || continue
			_tok=${f##*/req.}
			_trole=$(cat "$tpool/role.$_tok")
			[ "$_trole" = "$_role" ] || continue
			_treq=$(cat "$f")
			device_matches_env "$_treq" "$_conf" || continue
			_k=$(printf '%s\n' $_treq | grep -c .)
			if [ "$_k" -gt "$_bestkeys" ]; then _bestkeys=$_k; _best=$_tok; fi
		done
		if [ -n "$_best" ]; then
			printf '%s\n' "$ae" >> "$tpool/devs.$_best"
		else
			pvtest_log WARN "device $ae (claim=$_role) matched no runner-type; excluding"
		fi
	done

	# Phase 3: per type — claim role=yes devices once (in parallel), dispatch the
	# type's tests across its devices (its own FIFO, in a background subshell so
	# every type's FD 7 is independent), then delete the claimed devices once.
	local tf _type_pids=""
	for tf in "$tpool"/tests.*; do
		[ -e "$tf" ] || continue
		local _tok=${tf##*/tests.}
		local _trole; _trole=$(cat "$tpool/role.$_tok")
		local _tests; _tests=$(tr '\n' ' ' < "$tf")
		local _devs=""; [ -f "$tpool/devs.$_tok" ] && _devs=$(tr '\n' ' ' < "$tpool/devs.$_tok")

		if [ -z "$_devs" ]; then
			for json_path in $_tests; do
				pvtest_log INFO "'$(echo "$json_path" | sed 's|^/work/||; s|/test\.json$||')' SKIPPED (no matching runner)"
			done
			continue
		fi
		if [ "$_trole" = yes ] && { [ -z "$PH_USER" ] || [ -z "$PH_PASS" ]; }; then
			pvtest_log ERROR "PH_USER/PH_PASS not set but required by self-claim test(s)"
			for json_path in $_tests; do
				pvtest_log INFO "'$(echo "$json_path" | sed 's|^/work/||; s|/test\.json$||')' SKIPPED (PH_USER/PH_PASS not set)"
			done
			continue
		fi

		(
			local run_devs="$_devs" _ae
			# Claim this type's devices once (remote self-claim=true types only).
			if [ "$_trole" = yes ]; then
				local clf="$tpool/claimed.$_tok"
				: > "$clf"
				pvtest_log INFO "claim phase (type $_tok): claiming $(printf '%s\n' $_devs | grep -c .) device(s)"
				for _ae in $_devs; do
					(
						export PVTEST_EXEC="$(_ae_exec_cmd "$_ae")"
						export PVTEST_HOST="$(_ae_host "$_ae")"
						export PVTEST_AE="$_ae"
						if _dev_claim; then
							(flock -x 9; printf '%s\n' "$_ae" >> "$clf") 9>"$clf.lock"
						else
							pvtest_log ERROR "[device $_ae] claim failed; excluded from dispatch"
						fi
					) &
				done
				wait
				run_devs=$(tr '\n' ' ' < "$clf"); rm -f "$clf" "$clf.lock"
			fi

			if [ -z "$run_devs" ]; then
				for json_path in $_tests; do
					pvtest_log ERROR "'$(echo "$json_path" | sed 's|^/work/||; s|/test\.json$||')' ABORTED (claim failed: no devices could be claimed)"
				done
				touch "$failed_flag"
			else
				pvtest_log INFO "dispatching $(printf '%s\n' $_tests | grep -c .) test(s) across device(s): $run_devs"
				dispatch_tests "$run_devs" "$_tests"
				# Delete each claimed device from the Hub once.
				if [ "$_trole" = yes ]; then
					for _ae in $run_devs; do
						export PVTEST_EXEC="$(_ae_exec_cmd "$_ae")"
						export PVTEST_HOST="$(_ae_host "$_ae")"
						export PVTEST_AE="$_ae"
						_dev_delete_only
					done
				fi
			fi
		) &
		_type_pids="${_type_pids:+$_type_pids }$!"
	done
	[ -n "$_type_pids" ] && wait $_type_pids

	# Phase 4: send a lenient shutdown to all devices. Skipped when running from
	# the tester console; the console exit path handles shutdown on exit/Ctrl-D.
	if [ -z "${PVTEST_CONSOLE:-}" ]; then
		for ae in $ready_aes; do
			(
				export PVTEST_EXEC="$(_ae_exec_cmd "$ae")"
				export PVTEST_HOST="$(_ae_host "$ae")"
				pvtest_log DEBUG "[device $ae] requesting pantavisor shutdown"
				pv_ctrl cmd poweroff
			) &
		done
		wait
	fi

	rm -rf "$tpool"
	if [ -f "$failed_flag" ]; then
		rm -f "$failed_flag"
		return 1
	fi
	return 0
}


# Pre-parse -v/--verbose flag; remaining args stay positional for compatibility
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
	VERBOSE=true
	shift
fi

test_selector=${1:-$TEST_PATH}
interactive=${2-$INTERACTIVE}
manual=${3:-$MANUAL}
overwrite=${4:-$OVERWRITE}
verbose=${5:-$VERBOSE}
netsim=${6:-$NETSIM}
daemon=${7:-$DAEMON}
valgrind=${8:-$VALGRIND}
# /work/run is mounted from work_path/results on the host for per-test result files
run_dir=${RUN_DIR:-/work/run}
appengine_logs=${APPENGINE_LOGS:-}

if [ -z "$test_selector" ] || [ -z "$interactive" ] || [ -z "$manual" ] || [ -z "$overwrite" ] || [ -z "$verbose" ] || [ -z "$netsim" ]; then
	pvtest_log ERROR "missing arguments / envs"
	usage
	exit 1
fi
if [ "$verbose" = "true" ]; then set -x; fi

description=
required_env=
usrmeta=
control_container=
tarballs=
self_claim=
claimed_device=
applied_usrmeta_keys=
test_script=
factory_revision=0
test_dir=
test_id=
tmp_out_path=

pvtest_log INFO "starting test run: $test_selector"
initial_setup

# Slot-pool mode: a flat queue (PVTEST_QUEUE) dispatched across PVTEST_SLOTS
# slots, with the host re-typing each slot's container on demand over PVTEST_CTRL.
if [ -n "$PVTEST_QUEUE" ] && [ -n "$PVTEST_CTRL" ]; then
	test_json_list="$PVTEST_QUEUE"
	run_slot_pool
	exit $?
fi

# Pool mode: PVTEST_APPENGINES is set — use N-device pool.
if [ -n "$PVTEST_APPENGINES" ]; then
	if [ "$manual" = "true" ] || [ "$interactive" = "true" ]; then
		# Interactive/manual: init first device only, then drop into shell.
		first_ae=$(printf '%s' "$PVTEST_APPENGINES" | awk '{print $1}')
		export PVTEST_EXEC="$(_ae_exec_cmd "$first_ae")"
		export PVTEST_HOST="$(_ae_host "$first_ae")"
		if [ "$interactive" = "true" ]; then
			exec_interactive
			# Tester console exited; shutdown all appengines now.
			for ae in $(printf '%s\n' "$PVTEST_APPENGINES"); do
				(
					export PVTEST_EXEC="$(_ae_exec_cmd "$ae")"
					export PVTEST_HOST="$(_ae_host "$ae")"
					pvtest_log DEBUG "[device $ae] requesting pantavisor shutdown"
					pv_ctrl cmd poweroff
				) &
			done
			wait
			exit 0
		fi
		sleep 100000
		exit 0
	fi

	# Explicit test list (from the host's runner-type grouping) takes precedence
	# over the path selector; it lists the exact test.json paths for this wave.
	if [ -n "$PVTEST_JSON_LIST" ]; then
		test_json_list="$PVTEST_JSON_LIST"
		run_tests_pool
		exit $?
	fi

	# Resolve selector to list of test.json paths.
	if [ "${test_selector#/}" = "$test_selector" ]; then
		abs_selector="/work/$test_selector"
	else
		abs_selector="$test_selector"
	fi

	if [ -f "$abs_selector/test.json" ]; then
		test_json_list="$abs_selector/test.json"
	elif [ -d "$abs_selector" ]; then
		test_json_list=$(find "$abs_selector" -name "test.json" | sort)
	else
		pvtest_log ERROR "'$abs_selector' is not a test dir or a directory containing tests"
		exit 1
	fi

	run_tests_pool
	exit $?
fi

# Legacy single-device mode: PVTEST_APPENGINES not set.
# Behaviour is identical to the pre-pool implementation.
if [ "$manual" = "false" ] && [ "$interactive" = "false" ]; then
	start_pv
fi

# Resolve selector to list of test.json paths
# test_selector may be absolute (/work/local/control) or relative (local/control)
if [ "${test_selector#/}" = "$test_selector" ]; then
	abs_selector="/work/$test_selector"
else
	abs_selector="$test_selector"
fi

if [ -f "$abs_selector/test.json" ]; then
	test_json_list="$abs_selector/test.json"
elif [ -d "$abs_selector" ]; then
	test_json_list=$(find "$abs_selector" -name "test.json" | sort)
else
	pvtest_log ERROR "'$abs_selector' is not a test dir or a directory containing tests"
	stop_pv
	exit 1
fi

# Interactive / daemon: use first test only
if [ "$interactive" = "true" ] || [ "$daemon" = "true" ]; then
	first_json=$(printf '%s\n' "$test_json_list" | head -1)
	test_dir=$(dirname "$first_json")
	test_id=$(echo "$first_json" | sed 's|^/work/||; s|/test\.json$||')
	parse_test || { stop_pv; exit 1; }
	if [ "$interactive" = "true" ]; then
		exec_interactive
		exit 0
	fi
	sleep 100000
	stop_pv
	exit 0
fi

# Normal run: loop over all matching tests
overall_result=0
for json_path in $test_json_list; do
	test_dir=$(dirname "$json_path")
	test_id=$(echo "$json_path" | sed 's|^/work/||; s|/test\.json$||')

	if ! parse_test; then
		echo "=== TEST: $test_id ERROR (parse failed) ==="
		overall_result=1
		continue
	fi

	# skip flag
	_skip=$(jq -r '.skip' "$json_path")
	if [ "$_skip" = "true" ]; then
		if [ "$FAIL_ON_SKIP_FIELD" = "true" ]; then
			pvtest_log ERROR "'$test_id' has skip:true but FAIL_ON_SKIP_FIELD is set (skip is not allowed on master)"
			overall_result=1
			continue
		fi
		pvtest_log INFO "'$test_id' SKIPPED"
		continue
	fi

	# device filter
	if [ -n "$PVTEST_DEVICE" ]; then
		_devs=$(jq -r 'if (.devices // []) == [] then "" else (.devices | join(" ")) end' "$json_path")
		if [ -n "$_devs" ]; then
			case " $_devs " in
				*" $PVTEST_DEVICE "*) ;;
				*)
					pvtest_log INFO "'$test_id' SKIPPED (device=$PVTEST_DEVICE not in: $_devs)"
					continue
					;;
			esac
		fi
	fi

	if [ "$self_claim" = "true" ] && { [ -z "$PH_USER" ] || [ -z "$PH_PASS" ]; }; then
		pvtest_log ERROR "PH_USER/PH_PASS not set but required by self-claim test(s)"
		pvtest_log INFO "'$test_id' SKIPPED (PH_USER/PH_PASS not set)"
		continue
	fi

	pvtest_log INFO "'$test_id' START"
	_test_start=$(date +%s)

	if ! setup_test; then
		_test_runtime=$(( $(date +%s) - _test_start ))
		pvtest_log ERROR "'$test_id' ABORTED ($_test_runtime s)"
		overall_result=1
		teardown_test
		continue
	fi

	mkdir -p "$run_dir/$test_id"
	if ! exec_test; then
		_test_runtime=$(( $(date +%s) - _test_start ))
		pvtest_log ERROR "'$test_id' ABORTED ($_test_runtime s)"
		overall_result=1
		teardown_test
		continue
	fi

	eval_test
	test_result=$?

	_test_runtime=$(( $(date +%s) - _test_start ))

	if [ "$overwrite" = "true" ]; then
		pvtest_log INFO "'$test_id' RECORDED ($_test_runtime s)"
	elif [ $test_result -eq 0 ]; then
		pvtest_log INFO "'$test_id' PASSED ($_test_runtime s)"
	else
		pvtest_log ERROR "'$test_id' FAILED ($_test_runtime s)"
		overall_result=1
	fi

	teardown_test
done

stop_pv
exit $overall_result
