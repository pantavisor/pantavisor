#!/bin/sh

pvtest_log() {
	local level=$1; shift
	local line
	line=$(printf '[pvtest] %s %s -- [%s]: %s' "$(date +%s)" "$level" "${PVTEST_LOG_SOURCE:-pvtest}" "$*")
	printf '%s\n' "$line"
	# When a test is active, mirror the message into its per-test test.log so the
	# log holds the whole test (setup -> script -> teardown), not just the script.
	[ -n "$PVTEST_ACTIVE_TESTLOG" ] && printf '%s\n' "$line" >> "$PVTEST_ACTIVE_TESTLOG" 2>/dev/null
	return 0
}

# args are shell-quoted (printf %q) since SSH flattens them into one remote command
_pv_exec() {
	local prog="$1"; shift
	if [ -n "$PVTEST_EXEC" ]; then
		local cmd="$prog"
		for a in "$@"; do
			cmd="$cmd $(printf '%q' "$a")"
		done
		$PVTEST_EXEC "$cmd"
	else
		command "$prog" "$@"
	fi
}

pvcontrol() { _pv_exec pvcontrol "$@"; }
pventer()   { _pv_exec pventer   "$@"; }
pvcurl()    { _pv_exec pvcurl    "$@"; }
# Routes via PVTEST_EXEC; stdin is forwarded too, so `pvtx add - < file` streams.
pvtx()      { _pv_exec pvtx      "$@"; }

# SIGTERM, not SIGKILL: appengine PV catches it and reboots cleanly (SIGKILL leaves stale pv-ctrl sockets).
# Caller must wait for READY after.
crash_pv() { _pv_exec killall pantavisor; }

# wait for a cmd stdout
wait_for_value() {
	local cmd="$1"
	local value="$2"
	local timeout="$3"

	local counter=0
	while [ $counter -lt $timeout ]; do
		local result="$(eval "$cmd" 2>/dev/null)"
		if [ "$result" = "$value" ]; then
			return 0
		else
			sleep 1
			counter=$((counter+1))
		fi
	done
	return 1
}

# wait for a cmd exit status code
wait_for_status() {
	local cmd="$1"
	local status="$2"
	local timeout="$3"

	local counter=0
	while [ $counter -lt $timeout ]; do
		cmd_status=0
		eval "$cmd" || cmd_status=$?
		if [ "$cmd_status" = "$status" ]; then
			return 0
		else
			sleep 1
			counter=$((counter+1))
		fi
	done
	return 1
}

# wait for a path to appear or dissapear
wait_for_path() {
	local control_container="$1"
	local path="$2"
	local action="$3"
	local status=0

	if [ "$action" = "-a" ]; then
		status=0
	elif [ "$action" = "-d" ]; then
		status=1
	fi

	wait_for_status "pventer -c $control_container ls $path" "$status" 30
}

# wait for a process to appear or dissapear
wait_for_process() {
	local cmd="$1"
	local timeout="$2"
	local action="$3"

	local counter=0
	local cmd_pid=
	while [ $counter -lt $timeout ]; do
		cmd_pid=$(ps | grep "$cmd" | awk 'NR==1 {print $1}')
		if [ "$action" = "-a" ]; then
			if [ -n "$cmd_pid" ]; then
				return 0
			fi
		elif [ "$action" = "-d" ]; then
			if [ -z "$cmd_pid" ]; then
				return 0
			fi
		fi

		sleep 1
		counter=$((counter+1))
	done

	return 1
}

# wait for pv-ctrl up, rev current, step DONE/UPDATED, (optional) READY.
# require_ready=false for BSP-only revisions (never reach READY).
wait_for_new_revision() {
	local rev="$1"
	local require_ready="${2:-true}"

	wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120 || return 1
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.revision\"]'" "$rev" 120 || return 1

	local counter=0 st
	while [ $counter -lt 120 ]; do
		st=$(pvcontrol steps show-progress "$rev" 2>/dev/null | jq -r '.status' 2>/dev/null)
		case "$st" in
			DONE|UPDATED) break ;;
			ERROR|WONTGO) return 1 ;;
		esac
		sleep 1
		counter=$((counter + 1))
	done
	[ $counter -lt 120 ] || return 1

	[ "$require_ready" != "true" ] && return 0
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" 60
}

# drain previous test's activity: wait for current rev DONE/UPDATED (+READY best-effort).
# ERROR/rollback is transient, not terminal — keep waiting.
wait_for_current_settled() {
	local require_ready="${1:-true}"
	local term_timeout="${2:-180}" ready_timeout="${3:-120}"

	wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120 || return 1

	local counter=0 st
	while [ $counter -lt $term_timeout ]; do
		st=$(pvcontrol steps show-progress current 2>/dev/null | jq -r '.status' 2>/dev/null)
		case "$st" in DONE|UPDATED) break ;; esac
		sleep 1
		counter=$((counter + 1))
	done
	[ $counter -lt $term_timeout ] || return 1

	[ "$require_ready" = "true" ] || return 0
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" "$ready_timeout" || true
	return 0
}

# wait for Pantavisor to get to a given revision and update state
wait_for_revision_state() {
	local control_container="$1"
	local rev="$2"
	local state="$3"

	# generous timeouts: long trail/no-reset suites can exceed 30s
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.revision\"]'" "$rev" 120 || return 1
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" 60 || return 1
	wait_for_value "pvcontrol steps show-progress $rev | jq -r '.status'" "$state" 120 || return 1
}

# posts checkout, echoes assigned Hub revision number — never hardcode it, trail is shared.
# usage: rev=$(pvr_post_rev -m "msg" "$trail_url")
pvr_post_rev() {
	pvr post "$@" 2>&1 \
		| sed -n 's/.*Successfully posted Revision \([0-9][0-9]*\).*/\1/p' \
		| head -n1
}

# wait for Pantahub to get to a given status
wait_for_pantahub_state() {
	local control_container="$1"
	local state="$2"

	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantahub.state\"]'" "$state" 30
}
