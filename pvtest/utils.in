#!/bin/sh

pvtest_log() {
	local level=$1; shift
	local line
	# leading tag is the device/container this line concerns (PVTEST_AE, bound
	# per-attach in pool/single-device mode); falls back to this tester
	# container's own name (PVTEST_TESTER_NAME, set by test.docker.sh) for
	# dispatcher-level lines that aren't about any one device yet.
	line=$(printf '[%s] %s %s -- [%s]: %s' "${PVTEST_AE:-${PVTEST_TESTER_NAME:-pvtest}}" "$(date +%s)" "$level" "${PVTEST_LOG_SOURCE:-pvtest}" "$*")
	printf '%s\n' "$line"
	# When a test is active, mirror the message into its per-test test.log so the
	# log holds the whole test (setup -> script -> teardown), not just the script.
	[ -n "$PVTEST_ACTIVE_TESTLOG" ] && printf '%s\n' "$line" >> "$PVTEST_ACTIVE_TESTLOG" 2>/dev/null
	return 0
}

# args are shell-quoted (printf %q) since SSH flattens them into one remote command
_pv_exec() {
	local prog="$1"; shift
	if [ -n "$PVTEST_EXEC" ]; then
		local cmd="$prog"
		for a in "$@"; do
			cmd="$cmd $(printf '%q' "$a")"
		done
		# tester-side wall bound: a device-side call can block forever on a
		# ctrl socket that accepts but never answers (boot/shutdown windows),
		# or on a TCP connection black-holed by a device reboot, wedging
		# every wait_for_* loop on a single poll. --foreground keeps ssh in
		# our process group so it isn't SIGTTIN-stopped under the test pty.
		timeout --foreground "${PVTEST_EXEC_TIMEOUT:-60}" $PVTEST_EXEC "$cmd"
	else
		command "$prog" "$@"
	fi
}

pvcontrol() { _pv_exec pvcontrol "$@"; }
pventer()   { _pv_exec pventer   "$@"; }
pvcurl()    { _pv_exec pvcurl    "$@"; }
# Routes via PVTEST_EXEC; stdin is forwarded too, so `pvtx add - < file` streams.
# Longer bound: adds stream whole tarballs to low-spec devices.
pvtx()      { PVTEST_EXEC_TIMEOUT="${PVTEST_EXEC_TIMEOUT:-600}" _pv_exec pvtx "$@"; }

# Stage a tester-local file where a forwarded command can read it; echoes the
# path to pass as the file arg (device-side copy when PVTEST_EXEC is set).
pv_stage_file() {
	if [ -n "$PVTEST_EXEC" ]; then
		local remote="/tmp/pvtest_stage.$$.${1##*/}"
		$PVTEST_EXEC "cat > '$remote'" < "$1" || return 1
		printf '%s\n' "$remote"
	else
		printf '%s\n' "$1"
	fi
}

# Remove a path previously echoed by pv_stage_file (no-op when it was local).
pv_unstage_file() {
	[ -n "$PVTEST_EXEC" ] && $PVTEST_EXEC "rm -f '$1'" > /dev/null 2>&1
	return 0
}

# Fetch a file from the exec target into tester path $2 (plain copy when local).
pv_fetch_file() {
	if [ -n "$PVTEST_EXEC" ]; then
		$PVTEST_EXEC "cat '$1'" > "$2"
	else
		cat "$1" > "$2"
	fi
}

# True if pvtx can be run on the exec target (the device rootfs). pvtx is a
# compiled binary a device's runtime BSP may not ship, unlike the pvcontrol/
# pvcurl/pventer POSIX-shell wrappers — probe before choosing the install path.
# Requires PVTEST_EXEC: without it there is no device to run pvtx on (a local
# pvtx would target the tester's own pantavisor, not the device under test).
_have_pvtx() {
	[ -n "$PVTEST_EXEC" ] || return 1
	$PVTEST_EXEC "command -v pvtx >/dev/null 2>&1"
}

# SIGTERM, not SIGKILL: appengine PV catches it and reboots cleanly (SIGKILL leaves stale pv-ctrl sockets).
# Caller must wait for READY after.
crash_pv() { _pv_exec killall pantavisor; }

# wait for a cmd stdout
wait_for_value() {
	local cmd="$1"
	local value="$2"
	local timeout="$3"

	local counter=0
	while [ $counter -lt $timeout ]; do
		local result="$(eval "$cmd" 2>/dev/null)"
		if [ "$result" = "$value" ]; then
			return 0
		else
			sleep 1
			counter=$((counter+1))
		fi
	done
	return 1
}

# wait for a cmd exit status code
wait_for_status() {
	local cmd="$1"
	local status="$2"
	local timeout="$3"

	local counter=0
	while [ $counter -lt $timeout ]; do
		cmd_status=0
		eval "$cmd" || cmd_status=$?
		if [ "$cmd_status" = "$status" ]; then
			return 0
		else
			sleep 1
			counter=$((counter+1))
		fi
	done
	return 1
}

# wait for pv-ctrl to stop responding — the "down" half of a reboot/crash fence.
# Only needed when whatever you check right after has no way to tell a stale
# response from the dying instance apart from the real thing (e.g. a bare
# command with no gating check, or a wait on a value the old instance could
# already have shown before the trigger). Not needed when the following wait
# is keyed on a revision name/state the old instance could never report.
wait_for_down() {
	local timeout="${1:-30}"

	local counter=0
	while [ $counter -lt $timeout ]; do
		pvcontrol devmeta ls > /dev/null 2>&1 || return 0
		sleep 1
		counter=$((counter+1))
	done
	return 1
}

# storage root from PV_STORAGE_MNTPOINT (target-dependent), cached after first read
storage_dir() {
	if [ -z "$_PVTEST_STORAGE_DIR" ]; then
		_PVTEST_STORAGE_DIR=$(pvcontrol conf ls 2>/dev/null \
			| jq -r '.[] | select(.key == "PV_STORAGE_MNTPOINT") | .value')
	fi
	printf '%s' "$_PVTEST_STORAGE_DIR"
}

# wait for a device path to appear or dissapear: wait_for_path <path> -a|-d
# (legacy leading container arg ignored; test -e because ls exit codes vary per libc)
wait_for_path() {
	[ $# -eq 3 ] && shift
	local path="$1"
	local action="$2"
	local status=0

	if [ "$action" = "-a" ]; then
		status=0
	elif [ "$action" = "-d" ]; then
		status=1
	fi

	wait_for_status "_pv_exec test -e $path" "$status" 30
}

# wait for a process to appear or dissapear
wait_for_process() {
	local cmd="$1"
	local timeout="$2"
	local action="$3"

	local counter=0
	local cmd_pid=
	while [ $counter -lt $timeout ]; do
		cmd_pid=$(ps | grep "$cmd" | awk 'NR==1 {print $1}')
		if [ "$action" = "-a" ]; then
			if [ -n "$cmd_pid" ]; then
				return 0
			fi
		elif [ "$action" = "-d" ]; then
			if [ -z "$cmd_pid" ]; then
				return 0
			fi
		fi

		sleep 1
		counter=$((counter+1))
	done

	return 1
}

wait_for_target_ready() {
	local label="$1" rev="$2" status="${3:-}"
	local _l="${label:+$label: }"

	# stage 1: SSH — tells "container/board not up" apart from "pv-ctrl not up"
	if [ -n "$PVTEST_EXEC" ]; then
		pvtest_log INFO "${_l}waiting for SSH..."
		# fail fast on permanent auth errors instead of polling the full timeout
		local _err _rc=0
		_err=$(_pv_exec true 2>&1 > /dev/null) || _rc=$?
		if [ "$_rc" = 255 ] && printf '%s\n' "$_err" | grep -qiE 'permission denied|identity file|no such identity'; then
			pvtest_log ERROR "${_l}SSH to target failed: $(printf '%s\n' "$_err" | tail -n 2 | tr '\n' ' ')"
			pvtest_log ERROR "${_l}check the key referenced by the device manifest's exec= line (try running that command with 'true')"
			return 1
		fi
		if ! wait_for_status "_pv_exec true > /dev/null 2>&1" 0 120; then
			pvtest_log ERROR "${_l}timed out waiting for SSH"
			return 1
		fi
	fi

	# stage 2: pv-ctrl answering
	pvtest_log INFO "${_l}waiting for pv-ctrl..."
	if ! wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120; then
		local _probe
		_probe=$(pvcontrol devmeta ls 2>&1 > /dev/null | tail -n 2 | tr '\n' ' ')
		pvtest_log ERROR "${_l}timed out waiting for pv-ctrl${_probe:+ — last error: $_probe}"
		return 1
	fi

	# stage 3: the expected revision is the current one
	if [ -n "$rev" ]; then
		pvtest_log INFO "${_l}waiting for $rev to become current..."
		if ! wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.revision\"]'" "$rev" 120; then
			pvtest_log ERROR "${_l}timed out waiting for $rev to become current"
			return 1
		fi
	fi

	# stage 4: terminal-good step status (ERROR/WONTGO fail fast unless asked for)
	if [ -n "$status" ]; then
		pvtest_log INFO "${_l}waiting for ${rev:-current} $status..."
		local counter=0 st
		while [ $counter -lt 120 ]; do
			st=$(pvcontrol steps show-progress "${rev:-current}" 2>/dev/null | jq -r '.status' 2>/dev/null)
			case "|$status|" in *"|$st|"*) break ;; esac
			case "$st" in
				ERROR|WONTGO)
					pvtest_log ERROR "${_l}${rev:-current} reached $st, expected $status"
					return 1
					;;
			esac
			sleep 1
			counter=$((counter + 1))
		done
		if [ $counter -ge 120 ]; then
			pvtest_log ERROR "${_l}timed out waiting for ${rev:-current} $status"
			return 1
		fi
	fi

	# stage 5: containers up
	pvtest_log INFO "${_l}waiting for READY..."
	if ! wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" 120; then
		pvtest_log ERROR "${_l}timed out waiting for READY"
		return 1
	fi

	# stage 6: pvr HTTP endpoint — served by the pv-pvr-sdk container, so it
	# comes up after READY; a pvr call issued before this races it
	pvtest_log INFO "${_l}waiting for pvr HTTP endpoint [via pvr HTTP]..."
	if ! wait_for_pvr_endpoint; then
		pvtest_log ERROR "${_l}pvr HTTP endpoint not ready"
		return 1
	fi

	return 0
}

wait_for_pvr_endpoint() {
	wait_for_status "curl -s 'http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr' > /dev/null 2>&1; ec=\$?; [ \$ec -eq 0 ] || [ \$ec -eq 52 ]" 0 "${1:-60}"
}

wait_for_current_settled() {
	local term_timeout="${1:-180}" ready_timeout="${2:-120}"

	wait_for_status "pvcontrol devmeta ls > /dev/null 2>&1" 0 120 || return 1

	local counter=0 st
	while [ $counter -lt $term_timeout ]; do
		st=$(pvcontrol steps show-progress current 2>/dev/null | jq -r '.status' 2>/dev/null)
		case "$st" in DONE|UPDATED) break ;; esac
		sleep 1
		counter=$((counter + 1))
	done
	[ $counter -lt $term_timeout ] || return 1

	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" "$ready_timeout" \
		|| pvtest_log WARN "settle: not READY after ${ready_timeout}s; continuing"
	# pv-pvr-sdk comes up after READY, so a caller that posts/clones right
	# after this (_install_initial_pvr) would otherwise race it
	wait_for_pvr_endpoint \
		|| pvtest_log WARN "settle: pvr endpoint not up; continuing"
	return 0
}

# wait for Pantavisor to get to a given revision and update state:
# wait_for_revision_state <rev> <state> (legacy leading container arg ignored)
wait_for_revision_state() {
	[ $# -eq 3 ] && shift
	local rev="$1"
	local state="$2"

	# generous timeouts: long trail/no-reset suites can exceed 30s
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.revision\"]'" "$rev" 120 || return 1
	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantavisor.status\"]'" "READY" 60 || return 1
	wait_for_value "pvcontrol steps show-progress $rev | jq -r '.status'" "$state" 120 || return 1
}

pvr_clone_local_or_die() {
	local dest="$1" label="${2:+ ($2)}"
	local out
	out=$(pvr clone "http://${PVTEST_HOST:-localhost}:12368/cgi-bin/pvr" "$dest" 2>&1) \
		|| { echo "ERROR: pvr clone${label} failed: $out" >&2; exit 1; }
}

# posts checkout, echoes assigned Hub revision number — never hardcode it, trail is shared.
# usage: rev=$(pvr_post_rev -m "msg" "$trail_url")
pvr_post_rev() {
	pvr post "$@" 2>&1 \
		| sed -n 's/.*Successfully posted Revision \([0-9][0-9]*\).*/\1/p' \
		| head -n1
}

# wait for Pantahub to get to a given status: wait_for_pantahub_state <state>
# (legacy leading container arg ignored)
wait_for_pantahub_state() {
	[ $# -eq 2 ] && shift
	local state="$1"

	wait_for_value "pvcontrol devmeta ls | jq -r '.[\"pantahub.state\"]'" "$state" 30
}
