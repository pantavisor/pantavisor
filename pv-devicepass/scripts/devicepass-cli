#!/bin/sh
# devicepass-cli — DevicePass device identity and onboarding

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
LIB_DIR="${SCRIPT_DIR}/../lib/devicepass"

. "${LIB_DIR}/display.sh"
. "${LIB_DIR}/config.sh"

GUARDIAN_LIB_DIR="${LIB_DIR}/guardian"

DEVICEPASS_CLI_VERSION="0.3.0"

usage() {
	printf "Usage: devicepass-cli <command> [options]\n\n"
	printf "Subcommands:\n"
	printf "  dev          Device-side commands (identity, onboarding)\n"
	printf "  guardian     Guardian/fleet management commands\n"
	printf "\nDevice commands (shorthand):\n"
	printf "  init         Alias for 'dev init'\n"
	printf "  onboard      Alias for 'dev onboard'\n"
	printf "  status       Alias for 'dev status'\n"
	printf "  serve        Alias for 'dev serve'\n"
	printf "\nOptions:\n"
	printf "  --version    Show version\n"
	printf "\nRun 'devicepass-cli dev' or 'devicepass-cli guardian' for subcommand help.\n"
	exit 1
}

dev_usage() {
	printf "Usage: devicepass-cli dev <subcommand> [options]\n\n"
	printf "Subcommands:\n"
	printf "  init         Generate device identity (keypair + address)\n"
	printf "  onboard      Create signed onboard claim blob\n"
	printf "  status       Show device identity status\n"
	printf "  export-key   Export public key in various formats\n"
	printf "  serve        Start pv-devicepass daemon\n"
	exit 1
}

guardian_usage() {
	printf "Usage: devicepass-cli guardian <subcommand> [options]\n\n"
	printf "Subcommands:\n"
	printf "  claim     <BLOB_FILE>              Submit claim blob on-chain\n"
	printf "  deploy                             Deploy registry contract via forge\n"
	printf "  list      [--json]                 List owned devices\n"
	printf "  status    <DEVICE> [--json]        Show passport + balance\n"
	printf "  fund      <DEVICE> <AMOUNT>        Send ETH to device\n"
	printf "  balance   <DEVICE>                 Check device balance\n"
	printf "  transfer  <DEVICE> <NEW_GUARDIAN>  Transfer ownership\n"
	printf "  revoke    <DEVICE>                 Deactivate passport\n"
	exit 1
}

cmd_guardian() {
	subcmd="${1:-}"
	[ -n "$subcmd" ] && shift

	. "${GUARDIAN_LIB_DIR}/common.sh"

	case "$subcmd" in
		claim)
			. "${GUARDIAN_LIB_DIR}/claim.sh"
			cmd_guardian_claim "$@"
			;;
		deploy)
			. "${GUARDIAN_LIB_DIR}/deploy.sh"
			cmd_guardian_deploy "$@"
			;;
		list)
			. "${GUARDIAN_LIB_DIR}/list.sh"
			cmd_guardian_list "$@"
			;;
		status)
			. "${GUARDIAN_LIB_DIR}/status.sh"
			cmd_guardian_status "$@"
			;;
		fund)
			. "${GUARDIAN_LIB_DIR}/fund.sh"
			cmd_guardian_fund "$@"
			;;
		balance)
			. "${GUARDIAN_LIB_DIR}/balance.sh"
			cmd_guardian_balance "$@"
			;;
		transfer)
			. "${GUARDIAN_LIB_DIR}/transfer.sh"
			cmd_guardian_transfer "$@"
			;;
		revoke)
			. "${GUARDIAN_LIB_DIR}/revoke.sh"
			cmd_guardian_revoke "$@"
			;;
		*)
			guardian_usage
			;;
	esac
}

cmd_status() {
	check_deps

	if ! identity_exists; then
		log_warn "No device identity found"
		log_info "Run 'devicepass-cli dev init' to generate one"
		exit 1
	fi

	address=$(cat "$DEVICEPASS_ADDR")
	devid=$(cat "$DEVICEPASS_ID")

	printf "Device Identity\n"
	printf "  Address:   %s\n" "$address"
	printf "  ID:        %s\n" "$devid"
	printf "  Chain ID:  %s\n" "$DEVICEPASS_CHAIN_ID"
	printf "  Contract:  %s\n" "$DEVICEPASS_CONTRACT"
	printf "  Key dir:   %s\n" "$DEVICEPASS_DIR"
}

cmd_export_key() {
	fmt="hex"
	for arg in "$@"; do
		case "$arg" in
			--format=*) fmt="${arg#--format=}" ;;
			*) log_error "Unknown option: $arg"; exit 1 ;;
		esac
	done

	if ! identity_exists; then
		log_error "No device identity found"
		exit 1
	fi

	case "$fmt" in
		hex)
			cat "$DEVICEPASS_PUB"
			;;
		bin)
			# Convert hex pubkey to binary
			keccak256sum --help >/dev/null 2>&1  # just checking it exists
			# Use printf to output binary from hex
			pub=$(cat "$DEVICEPASS_PUB" | tr -d '\n')
			i=0
			while [ $i -lt ${#pub} ]; do
				byte=$(echo "$pub" | cut -c$((i+1))-$((i+2)))
				printf "\\x$byte"
				i=$((i+2))
			done
			;;
		*)
			log_error "Unknown format: $fmt (use hex or bin)"
			exit 1
			;;
	esac
}

cmd_dev() {
	subcmd="${1:-}"
	[ -n "$subcmd" ] && shift

	case "$subcmd" in
		init)
			. "${LIB_DIR}/identity.sh"
			cmd_init "$@"
			;;
		onboard)
			. "${LIB_DIR}/identity.sh"
			. "${LIB_DIR}/signing.sh"
			cmd_onboard "$@"
			;;
		status)
			cmd_status "$@"
			;;
		export-key)
			cmd_export_key "$@"
			;;
		serve)
			exec pv-devicepass "$@"
			;;
		*)
			dev_usage
			;;
	esac
}

case "${1:-}" in
	--version|version)
		printf "devicepass-cli %s\n" "$DEVICEPASS_CLI_VERSION"
		exit 0
		;;
	dev)
		shift
		cmd_dev "$@"
		;;
	guardian)
		shift
		cmd_guardian "$@"
		;;
	# Backwards-compatible aliases (top-level shortcuts for dev commands)
	init)
		shift
		cmd_dev init "$@"
		;;
	onboard)
		shift
		cmd_dev onboard "$@"
		;;
	status)
		shift
		cmd_dev status "$@"
		;;
	export-key)
		shift
		cmd_dev export-key "$@"
		;;
	serve)
		shift
		cmd_dev serve "$@"
		;;
	*)
		usage
		;;
esac
