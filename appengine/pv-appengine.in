#!/bin/bash
# re-exec as bash (PID 1) so SIGTERM/EXIT traps fire — sh defers them, missing Docker's SIGKILL window
[ -z "$_PV_APPENGINE_REEXEC" ] && exec env _PV_APPENGINE_REEXEC=1 /bin/bash "$0" "$@"

set -e

interrupt='false'
manual='false'
valgrind="${VALGRIND:-false}"

pvtest_log() { local level=$1; shift; printf '[pvtest] %s %s -- [pv-appengine]: %s\n' "$(date +%s)" "$level" "$*"; }

usage() {
	echo "Usage: $0 [options]"
	echo "Run Pantavisor in an existing OS"
	echo "options:"
	echo "       -h         show help"
	echo "       -i         interrupt auto reboot and wait for user confirmation"
	echo "       -m         drop to shell without starting Pantavisor (manual mode)"
	echo "       -c CMDLINE additional cmdline arguments (incl. legacy configs)"
	echo "       -e ENVS envs to set (incl. new config format)"
	echo "       -V         run with valgrind"
	echo "       -d SECS    restart delay in seconds (default: 5)"
}

cleanup_cgroup() {
	if [ -d /sys/fs/cgroup/lxc ]; then
		find /sys/fs/cgroup/lxc/ -mindepth 1 -maxdepth 1 -type d -exec rmdir {} \; > /dev/null 2>&1 || true
		rmdir /sys/fs/cgroup/lxc* > /dev/null 2>&1 || true
	fi
}

deploy_rev() {
	local dir="$1"; shift
	local d a

	pvtx abort > /dev/null 2>&1 || true
	pvtx begin empty @PV_INSTALL_FULL_STORAGEDIR@/objects
	for d in @PV_INSTALL_FULL_PVTXDIR@ "$@"; do
		for a in "$d"/*; do
			[ -f "$a" ] || continue
			pvtx add "$a"
		done
	done
	# rm only the .pvr stub, keeping the revision dir for deploy's rename swap
	rm -rf "$dir/.pvr"
	mkdir -p "$dir"
	pvtx deploy "$dir"
}

# pantavisor only commits the revision it boots into when that revision is
# literally named "0" (update.c:_is_factory), so a renamed initial revision
# would come up with no progress on disk and never reach DONE. Write what that
# factory path would have written.
mark_rev_factory() {
	local dir="$1"

	mkdir -p "$dir/.pv"
	: > "$dir/.pv/done"
	printf '{"status":"DONE","status-msg":"Factory revision","progress":100,"retries":0}' \
		> "$dir/.pv/progress"
	chmod 644 "$dir/.pv/done" "$dir/.pv/progress"
}

init_storage() {
	# pre-create /dev/loopN nodes: no udev here, so losetup fails otherwise for whatever index the kernel picks.
	# parallel-safe (LOOP_CTL_GET_FREE is host-global/atomic) and idempotent.
	if [ -e /dev/loop-control ]; then
		i=0
		while [ "$i" -lt 1024 ]; do
			[ -e "/dev/loop$i" ] || mknod "/dev/loop$i" b 7 "$i" 2>/dev/null
			i=$((i + 1))
		done

		# self-heal PV_LOOP_INDEX_BASE's band (see config.h) left dirty by a
		# prior generation that didn't shut down cleanly: only reaps devices
		# whose backing file shows "(deleted)", so unrelated host loop users
		# sharing the same minor range are never touched.
		if [ -n "$PV_LOOP_INDEX_BASE" ] && [ "$PV_LOOP_INDEX_BASE" -ge 0 ] 2>/dev/null; then
			i="$PV_LOOP_INDEX_BASE"
			end=$((PV_LOOP_INDEX_BASE + 64))
			while [ "$i" -lt "$end" ]; do
				[ -e "/dev/loop$i" ] || mknod "/dev/loop$i" b 7 "$i" 2>/dev/null
				bf="/sys/class/block/loop$i/loop/backing_file"
				if [ -f "$bf" ]; then
					case "$(cat "$bf" 2>/dev/null)" in
						*" (deleted)") losetup -d "/dev/loop$i" 2>/dev/null ;;
					esac
				fi
				i=$((i + 1))
			done
		fi
	fi

	if [ ! -f "@CMAKE_INSTALL_FULL_SYSCONFDIR@/pantavisor-appengine.config" ]; then
		pvtest_log ERROR "installation path '@CMAKE_INSTALL_FULL_SYSCONFDIR@/pantavisor-appengine.config' not found"
		exit 1
	fi

	# write authorized_keys from env — avoids host sudo chown for dropbear-pv's root-ownership requirement
	if [ -n "$PV_DEBUG_SSH_PUBKEY" ]; then
		mkdir -p "@CMAKE_INSTALL_FULL_SYSCONFDIR@/pantavisor/ssh"
		local _ak="@CMAKE_INSTALL_FULL_SYSCONFDIR@/pantavisor/ssh/${PV_DEBUG_SSH_AUTHORIZED_KEYS:-pvtest-authorized_keys}"
		printf '%s\n' "$PV_DEBUG_SSH_PUBKEY" > "$_ak"
		chmod 600 "$_ak"
	fi

	if ! cat /proc/mounts | awk '{ print $2}' | grep -q '^@PV_INSTALL_FULL_STORAGEDIR@$' ; then
		pvtest_log WARN "@PV_INSTALL_FULL_STORAGEDIR@ is not a mountpoint. Automatic installation might fail."
	fi

	if ! [ -f @PV_INSTALL_FULL_STORAGEDIR@/.created ]; then
		pvtest_log DEBUG "first boot: initialising storage skeleton"
		cp -a @PV_INSTALL_FULL_SKELDIR@/* @PV_INSTALL_FULL_STORAGEDIR@/ || true
		touch @PV_INSTALL_FULL_STORAGEDIR@/.created || true
	fi

	if ! [ -f @PV_INSTALL_FULL_STORAGEDIR@/.pvtx-done ]; then
		if [ -n "$PV_APPENGINE_INITIAL_REV" ]; then
			pvtest_log DEBUG "first boot: deploying initial revision $PV_APPENGINE_INITIAL_REV"
			rm -rf @PV_INSTALL_FULL_STORAGEDIR@/trails/0
			deploy_rev "@PV_INSTALL_FULL_STORAGEDIR@/trails/$PV_APPENGINE_INITIAL_REV" \
				@PV_INSTALL_FULL_PVTXEXTRADIR@
			mark_rev_factory "@PV_INSTALL_FULL_STORAGEDIR@/trails/$PV_APPENGINE_INITIAL_REV"
		else
			pvtest_log DEBUG "first boot: running pvtx deploy"
			deploy_rev @PV_INSTALL_FULL_STORAGEDIR@/trails/0
		fi
		touch @PV_INSTALL_FULL_STORAGEDIR@/.pvtx-done
	fi

	if ! [ -f @PV_INSTALL_FULL_STORAGEDIR@/boot/uboot.txt ]; then
		pvtest_log DEBUG "first boot: initialising boot state"
		mkdir -p @PV_INSTALL_FULL_STORAGEDIR@/boot
		printf 'pv_rev=%s\0\0' "${PV_APPENGINE_INITIAL_REV:-0}" \
			> @PV_INSTALL_FULL_STORAGEDIR@/boot/uboot.txt
	fi
}

exec_run() {
	scriptpath=`readlink -f "$0"`

	init_storage

	cleanup_cgroup

	pv_trying=""
	shutdown=0
	restart_delay="${restart_delay:-5}"
	# forward SIGINT/SIGTERM to the pantavisor child before Docker's SIGKILL fallback
	_do_shutdown() {
		shutdown=1
		pvtest_log INFO "received $1, shutting down pantavisor ..."
		local _pv
		_pv=$(ps | awk '$4 == "@CMAKE_INSTALL_FULL_BINDIR@/pantavisor" {print $1; exit}')
		[ -n "$_pv" ] && kill "$_pv" 2>/dev/null || true
	}
	trap '_do_shutdown SIGINT'  SIGINT
	trap '_do_shutdown SIGTERM' TERM
	trap 'cleanup_cgroup' EXIT

	while [ "$shutdown" -eq 0 ]; do
		revs=$(tr -d '\0' < "@PV_INSTALL_FULL_STORAGEDIR@/boot/uboot.txt")
		pv_rev=`echo "$revs" | awk -v FS="(pv_rev=|pv_try=)" '{print $2}' `
		pv_try=`echo "$revs" | awk -v FS="(pv_rev=|pv_try=)" '{print $3}' `

		if [ -n "$pv_try" ]; then
			if [ -n "$pv_trying" ] && [ "$pv_trying" = "$pv_try" ]; then
				pv_trying=""
			else
				pv_trying="$pv_try"
				pv_rev="$pv_try"
			fi
		fi

		pvtest_log INFO "launching pantavisor rev=$pv_rev${pv_try:+ (try=$pv_try)}"
		set +e
		if ! grep -q "cgroup2" /proc/mounts | grep -q "/sys/fs/cgroup"; then
			if [ -z "$(ls -A /sys/fs/cgroup 2>/dev/null)" ]; then
				mount -t cgroup2 none /sys/fs/cgroup || true
			fi
		fi
		mkdir -p /sys/fs/cgroup/pantavisor
		echo 1 > /sys/fs/cgroup/pantavisor/cgroup.procs || true
		echo 0 > /sys/fs/cgroup/pantavisor/cgroup.procs
		mount -t cgroup2 none /sys/fs/cgroup || true
		mkdir -p /storage
		mount --bind @PV_INSTALL_FULL_STORAGEDIR@ /storage || true
		mkdir -p /volumes @CMAKE_INSTALL_RUNSTATEDIR@/pv/volumes
		mount --bind @CMAKE_INSTALL_RUNSTATEDIR@/pv/volumes /volumes || true
		if [ "$valgrind" = "true" ]; then
			mkdir -p /tmp/valgrind
			eval $envs valgrind --tool=memcheck --leak-check=full --show-leak-kinds=all --track-fds=yes --log-file=/tmp/valgrind/valgrind.log.%p \
				@CMAKE_INSTALL_FULL_BINDIR@/pantavisor --config @CMAKE_INSTALL_FULL_SYSCONFDIR@/pantavisor-appengine.config --cmdline \"pv_rev=$pv_rev pv_try=$pv_try $cmdline\"
		else
			eval $envs @CMAKE_INSTALL_FULL_BINDIR@/pantavisor --config @CMAKE_INSTALL_FULL_SYSCONFDIR@/pantavisor-appengine.config --cmdline \"pv_rev=$pv_rev pv_try=$pv_try $cmdline\"
		fi
		_pv_exit=$?
		umount -l /volumes || true
		umount -l /storage || true
		cleanup_cgroup
		pvtest_log DEBUG "pantavisor exited"

		set -e
		# Intentional stops — leave the loop so the container exits:
		#   exit 3:      pantavisor powered off gracefully (pv_shutdown POWEROFF)
		#   shutdown==1: SIGINT/SIGTERM to the wrapper (Docker stop / Ctrl-C)
		if [ "$shutdown" -eq 1 ] || [ "$_pv_exit" -eq 3 ]; then
			break
		fi
		# reboot-loop on crash: exit>=128 (killed by signal) or exit 0 via graceful SIGTERM->reboot (crash_pv path).
		# other non-zero exits fail fast (broken build), except valgrind (unreliable exit codes).
		if [ "$_pv_exit" -ge 128 ]; then
			pvtest_log WARN "pantavisor crashed (signal $((_pv_exit - 128))); rebooting device..."
		elif [ "$valgrind" != "true" ] && [ "$_pv_exit" -ne 0 ]; then
			break
		fi
		if [ "$interrupt" = 'true' ]; then
			# let's consume all buffered input first
			while read -d "" -t 0.01; do
				:
			done
			# wait for user input or continue
			if read -t 5 -p "$(pvtest_log INFO "Will restart Pantavisor in 5 sec. Press ENTER to abort")"; then
				pvtest_log INFO "Exiting..."
				break
			fi
		fi
		if [ "$restart_delay" -gt 0 ] 2>/dev/null; then
			pvtest_log DEBUG "restarting in $restart_delay seconds..."
			sleep "$restart_delay" || true
		fi
	done

	pvtest_log INFO "Pantavisor stopped"

	if [ -d @PV_INSTALL_FULL_STORAGEDIR@-ovl ]; then
		umount /var/pantavisor/storage
	fi

	cleanup_cgroup
}
while [ $# -gt 0 ]; do
	case "$1" in
	-h)
		usage
		exit 0
		;;
	-i)
		interrupt='true'
		;;
	-c)
		shift
		cmdline="$1"
		;;
	-e)
		shift
		envs="$1"
		;;
	-V)
		valgrind='true'
		;;
	-m)
		manual='true'
		;;
	-d)
		shift
		restart_delay="$1"
		;;
	*)
		break
		;;
	esac
	shift
done

if [ "${VERBOSE:-false}" = "true" ]; then set -x; fi

if [ "$manual" = "true" ]; then
	init_storage
	mkdir -p /storage
	mount --bind @PV_INSTALL_FULL_STORAGEDIR@ /storage 2>/dev/null || true
	echo ""
	echo "Welcome to Pantavisor appengine!"
	echo ""
	echo "Pantavisor is not running. You are in the appengine container shell."
	echo "To run Pantavisor with stdout logs:"
	echo "pv-appengine -i -e \"PV_LOG_SERVER_OUTPUTS=filetree,stdout_direct\""
	echo ""
	echo "Pantavisor reads PV_* config keys straight from the environment, so pass a"
	echo "device's required-config directly, e.g.:"
	echo "pv-appengine -i -e \"PV_CONTROL_REMOTE=0 PV_SECUREBOOT_MODE=disabled PV_LOG_SERVER_OUTPUTS=filetree,stdout_direct\""
	echo ""
	exec bash
fi

exec_run
